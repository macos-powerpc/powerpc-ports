index a7e826e5..f3a91dd2 100644
--- a/src/meson.build
+++ b/src/meson.build
@@ -293,6 +293,7 @@ if is_asm_enabled
             arch_flags += {'altivec': altivec_flags}
             libdav1d_arch_tmpl_sources += {'altivec': files(
