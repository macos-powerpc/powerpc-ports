diff --git a/src/ppc/cdef_tmpl.c b/src/ppc/cdef_tmpl.c
index 6ef87ad4..a4a6140c 100644
--- a/src/ppc/cdef_tmpl.c
+++ b/src/ppc/cdef_tmpl.c
@@ -56,6 +56,15 @@ static inline void copy4xN(uint16_t *tmp,
 
     int y_start = -2, y_end = h + 2;
 
+    /*
+     * All stores here go to tmp-relative addresses. tmp is NOT 16-byte
