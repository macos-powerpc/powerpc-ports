From 6a8618db5d3c0a28a60b569d4ac31e7fb6321cb4 Mon Sep 17 00:00:00 2001
From: Developer <dev@localhost>
Date: Tue, 14 Jul 2026 18:42:24 +0000
Subject: [PATCH] ppc: pass -arch/-force_cpusubtype_ALL to as(1) for the darwin
 toolchain

Darwin's as(1) doesn't share ASFLAGS with the CFLAGS passed to cc, and
by default treats AltiVec-only opcodes (lvx, stvx, vspltisb, ...) as
"optional" instructions it refuses to assemble for the base ppc
cpusubtype. The four AltiVec .S files (loopfilter_filters_altivec.S,
etc.) failed to assemble as soon as they started actually being built
after the prior .s -> .S rename fix. Pass the same -arch ppc and
-force_cpusubtype_ALL flags already used for cc in this toolchain.

Co-Authored-By: Claude Sonnet 5 <noreply@anthropic.com>
Claude-Session: https://claude.ai/code/session_01DLC53yuiz8taQDNndUp4rs
---
 build/make/configure.sh | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/build/make/configure.sh b/build/make/configure.sh
index 47a59d08b..5e3516e9b 100644
--- a/build/make/configure.sh
+++ b/build/make/configure.sh
@@ -902,6 +902,12 @@ process_common_toolchain() {
           # VSX is POWER7+/ppc64 only; there is no VSX build support for
           # this toolchain, so keep RTCD from referencing *_vsx symbols.
           enabled vsx || RTCD_OPTIONS="${RTCD_OPTIONS}--disable-vsx "
+          # Darwin's as(1) rejects AltiVec-only opcodes (lvx, stvx, etc.)
+          # as "optional" instructions unless told to allow them for this
+          # cpusubtype, and it needs -arch to know which architecture it's
+          # assembling for at all -- mirror what is already passed to cc.
+          add_asflags -arch ${tgt_isa}
+          add_asflags -force_cpusubtype_ALL
           ;;
       esac
       ;;
