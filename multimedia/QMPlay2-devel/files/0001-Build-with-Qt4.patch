-option(BUILD_WITH_QT6 "Build with Qt6" ON)
-add_feature_info(Qt6 BUILD_WITH_QT6 "Build with Qt6")
-
-if(BUILD_WITH_QT6)
-    set(QT_PREFIX Qt6)
-    find_package(Qt6Widgets 6.1 REQUIRED)
-    find_package(Qt6Core5Compat 6.1 REQUIRED)
+option(BUILD_WITH_QT4 "Build with Qt4 (for macOS 10.5/10.6 PowerPC compatibility)" OFF)
+add_feature_info(Qt4 BUILD_WITH_QT4 "Build with Qt4")
+
+if(BUILD_WITH_QT4)
+    set(QT_PREFIX Qt)
+    find_package(Qt4 4.8 REQUIRED QtCore QtGui QtSvg QtOpenGL QtNetwork)
+    include(${QT_USE_FILE})
+
+    if(APPLE)
+        # moc doesn't get the compiler's predefined macros (no __APPLE__),
+        # so #ifdef Q_OS_MAC guards around slots would otherwise be silently
+        # dropped from the meta-object at moc time even though the real
+        # compiler sees them fine. Feed moc the define directly instead of
+        # relying on CMAKE_AUTOMOC_COMPILER_PREDEFINES (which needs a newer
+        # CMake than some Qt4/macOS toolchains ship with).
+        add_definitions(-DQ_OS_MAC)
+    endif()
 else()
-    set(QT_PREFIX Qt5)
-    find_package(Qt5Widgets 5.15.2 REQUIRED)
+    option(BUILD_WITH_QT6 "Build with Qt6" ON)
+    add_feature_info(Qt6 BUILD_WITH_QT6 "Build with Qt6")
+
+    if(BUILD_WITH_QT6)
+        set(QT_PREFIX Qt6)
+        find_package(Qt6Widgets 6.1 REQUIRED)
+        find_package(Qt6Core5Compat 6.1 REQUIRED)
+    else()
+        set(QT_PREFIX Qt5)
+        find_package(Qt5Widgets 5.15.2 REQUIRED)
+    endif()
+endif()
+
+# Add QJson4 for JSON support (Qt4 doesn't have native JSON)
+# QJson4 library from https://github.com/eteran/qjson4
+set(QJSON4_INCLUDE_DIR "" CACHE PATH "Path to QJson4 headers")
+if(QJSON4_INCLUDE_DIR)
+    include_directories(${QJSON4_INCLUDE_DIR})
+    add_definitions(-DUSE_QJSON4)
+    set(QJSON4_LIBRARY QJson4)
+    message(STATUS "QJson4 enabled: headers at ${QJSON4_INCLUDE_DIR}")
+elseif(BUILD_WITH_QT4)
+    message(WARNING "QJSON4_INCLUDE_DIR not set. Qt4 builds require QJson4 from https://github.com/eteran/qjson4")
 endif()
 
