     // Parse version string (e.g., "2.1 ..." or "3.0 ...")
     int majorVersion = 2;
@@ -92,17 +77,10 @@ bool OpenGLInstance::init()
                  ((majorVersion >= 2) || extensionSet.contains("GL_ARB_pixel_buffer_object"));
     }
 
-#ifndef Q_OS_MAC
-    glVer = majorVersion * 10 + minorVersion;
-#else
-    // macOS 10.6.8 has OpenGL 2.0/2.1
-    glVer = 20;
-#endif
-
-#if QT_VERSION < QT_VERSION_CHECK(5, 0, 0)
-    // Clean up temporary widget
-    delete tempWidget;
-#endif
+    // Use the detected version rather than hardcoding 2.0, so a newer
+    // macOS/driver reporting 2.1+ (or 3.0+) is reflected accurately; falls
+    // back to 2.0 only if somehow the parsed version is below that.
+    glVer = (majorVersion >= 2) ? (majorVersion * 10 + minorVersion) : 20;
 
     return true;
 }
