# https://github.com/Greedysky/TTKMusicPlayer/issues/130
post-patch {
    reinplace "s|\${CMAKE_CACHEFILE_DIR}|${cmake.build_dir}|g" ${worksrcpath}/CMakeLists.txt
    reinplace "s|if(UNIX)|if(UNIX AND NOT APPLE)|" ${worksrcpath}/CMakeLists.txt
    reinplace "s|qshortcut/qglobalshortcut_x11.cpp|qshortcut/qglobalshortcut_mac.cpp|" ${worksrcpath}/TTKThirdParty/TTKExtras/CMakeLists.txt
}

