From: Sergey Fedorov <barracuda@macos-powerpc.org>
Date: Sat, 5 Jul 2025 18:04:47 +0800
Subject: [PATCH 3/5] qglobalshortcut_dummy.cpp: just to satisfy the build

---
 .../qshortcut/qglobalshortcut_dummy.cpp       | 41 +++++++++++++++++++
 1 file changed, 41 insertions(+)
 create mode 100644 TTKThirdParty/TTKExtras/qshortcut/qglobalshortcut_dummy.cpp

diff --git TTKThirdParty/TTKExtras/qshortcut/qglobalshortcut_dummy.cpp TTKThirdParty/TTKExtras/qshortcut/qglobalshortcut_dummy.cpp
new file mode 100644
index 000000000..0049581e7
--- /dev/null
+++ TTKThirdParty/TTKExtras/qshortcut/qglobalshortcut_dummy.cpp
@@ -0,0 +1,41 @@
+#include "qglobalshortcut_p.h"
+#include <Qt>
+
+/* Carbon API not supported on recent macOS. This file exists as a hack
+   to allow everything else to compile. */
+
+#if defined(__APPLE__)
+
+quint32 QGlobalShortcutPrivate::nativeModifiers(Qt::KeyboardModifiers)
+{
+    return 0;
+}
+
+quint32 QGlobalShortcutPrivate::nativeKeycode(Qt::Key)
+{
+    return 0;
+}
+
+bool QGlobalShortcutPrivate::registerShortcut(quint32, quint32)
+{
+    return false;
+}
+
+bool QGlobalShortcutPrivate::unregisterShortcut(quint32, quint32)
+{
+    return false;
+}
+
+#if !TTK_QT_VERSION_CHECK(5,0,0)
+bool QGlobalShortcutPrivate::eventFilter(void *)
+{
+    return false;
+}
+#else
+bool QGlobalShortcutPrivate::nativeEventFilter(const QByteArray &, void *, qint *)
+{
+    return false;
+}
+#endif
+
+#endif // __APPLE__
