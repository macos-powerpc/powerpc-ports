From 0ae3bc4ecc44686daecc43cd065b0c3ab45f2fe1 Mon Sep 17 00:00:00 2001
From: Sergey Fedorov <barracuda@macos-powerpc.org>
Date: Sat, 5 Jul 2025 21:02:16 +0800
Subject: [PATCH 1/3] CMakeLists: use standard Qt4 linklibs, use QtMultimedia
 instead of QtMultimediaKit

---
 CMakeLists.txt           | 5 -----
 TTKModule/CMakeLists.txt | 4 ++--
 2 files changed, 2 insertions(+), 7 deletions(-)

diff --git CMakeLists.txt CMakeLists.txt
index e5ded72cc..2035dd63d 100644
--- CMakeLists.txt
+++ CMakeLists.txt
@@ -272,11 +272,6 @@ find_library(TTK_QMMP_LIBRARY
 
 # qmmp include
 include_directories(${TTK_THIRDPARTY_DIR}/TTKqmmp)
-if(TTK_QT_VERSION VERSION_EQUAL "4" AND UNIX)
-  include_directories(
-    /usr/include/QtMultimediaKit
-    /usr/include/QtMobility)
-endif()
 
 
 add_subdirectory(TTKCommon)
diff --git TTKModule/CMakeLists.txt TTKModule/CMakeLists.txt
index aeee1bdc6..a1cb165a1 100644
--- TTKModule/CMakeLists.txt
+++ TTKModule/CMakeLists.txt
@@ -136,10 +136,10 @@ if(TTK_QT_VERSION VERSION_EQUAL "4")
   qt4_wrap_cpp(MOC_FILES ${HEADER_FILES})
 
   if(UNIX)
-    list(APPEND QT_LINK_LIBS ${QT_QTDBUS_LIBRARY} QtMultimediaKit)
+    list(APPEND QT_LINK_LIBS Qt4::QtDBus)
   endif()
 
-  list(APPEND QT_LINK_LIBS ${QT_QTCORE_LIBRARY} ${QT_QTMULTIMEDIA_LIBRARY} ${QT_QTXML_LIBRARY} ${QT_QTGUI_LIBRARY} ${QT_QTNETWORK_LIBRARY})
+  list(APPEND QT_LINK_LIBS Qt4::QtCore Qt4::QtMultimedia Qt4::QtXml Qt4::QtGui Qt4::QtNetwork)
 elseif(TTK_QT_VERSION VERSION_EQUAL "5")
   qt5_wrap_ui(UIC_FILES ${UI_FILES})
   qt5_wrap_cpp(MOC_FILES ${HEADER_FILES})
-- 
