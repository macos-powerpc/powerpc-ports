+/* Helper function for dispatch_async_f - cleanup views on main thread */
+struct cleanup_context {
+    id container;
+    VLCVideoLayerView *videoView;
+    VLCCAOpenGLLayer *videoLayer;
+};
+
+static void cleanup_views_on_main_thread(void *context)
+{
+    struct cleanup_context *ctx = (struct cleanup_context *)context;
+    
+    // Remove vout subview from container
+    if ([ctx->container respondsToSelector:@selector(removeVoutSubview:)]) {
+        [ctx->container removeVoutSubview:ctx->videoView];
+    }
+    [ctx->videoView removeFromSuperview];
+
+    [ctx->videoView release];
+    [ctx->container release];
+    [ctx->videoLayer release];
+    
+    free(ctx);
 }
 
