-    NCURSES_CFLAGS :=
-    NCURSES_LIBS := -lncursesw
-else
-    # Linux: Use pkg-config
-    NCURSES_LIBS := $(shell pkg-config --libs ncursesw 2>/dev/null || echo "-lncursesw")
