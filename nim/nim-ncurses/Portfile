PortSystem          1.0
PortGroup           nim 1.0

nim.vcs_revision    1027fe13d091583608e7e7da3c3e0d13aceb4b11
nim.setup           github walkre-niboshi nim-ncurses ${nim.vcs_revision}
version             1.0.2
revision            0
categories-append   devel
license             MIT
maintainers         {@barracuda156 macos-powerpc.org:barracuda} openmaintainer

description         Nim wrapper for ncurses terminal library
long_description    nim-ncurses provides Nim bindings for the ncurses library, \
                    enabling terminal-based user interface development in Nim. \
                    It wraps ncurses functions for window management, input \
                    handling, colors and text formatting.

checksums           rmd160  d8629f424e9dc457ca4fb88d9ede6357b81999e8 \
                    sha256  2d9eb7f1b808b437a4ee5bedeed219689958bd1f73a2542a3452505874154b25 \
                    size    28253

depends_lib-append  port:ncurses

post-patch {
    set ncurses_files [glob -nocomplain ${worksrcpath}/*.nim ${worksrcpath}/src/*.nim]

    foreach nim_file ${ncurses_files} {
        # Replace relative library name with absolute MacPorts path
        # to ensure the correct library is picked.
        reinplace "s|\"libncurses\\.dylib\"|\"${prefix}/lib/libncurses.dylib\"|g" ${nim_file}
        reinplace "s|\"libncurses\\.\[0-9\]\\+\\.dylib\"|\"${prefix}/lib/libncurses.dylib\"|g" ${nim_file}
        reinplace "s|libncurses\\.\[0-9\]\\+|${prefix}/lib/libncurses|g" ${nim_file}
    }
}
