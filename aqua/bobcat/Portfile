# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           github 1.0

github.setup        ismail-yilmaz Bobcat 0.9.9
name                [string tolower ${github.project}]
revision            0
categories          aqua shells
license             GPL-3
maintainers         {@barracuda156 macos-powerpc.org:barracuda}
description         Modern cross-platform terminal emulator built with U++
long_description    Bobcat is a modern, cross-platform terminal emulator built with \
                    Ultimate++. It provides a clean interface with support for multiple \
                    profiles, custom color schemes, split views and extensive keyboard \
                    shortcuts. Features include regex search, link detection, quick text \
                    snippets and session management.

checksums           rmd160  85a92d231013a28154a624684a64a73e60afe394 \
                    sha256  71dfb9ed77ed89440205935f4c04e0eff194a471552173b98b5ccf4d0055ec1f \
                    size    7685351
github.tarball_from archive

depends_build-append \
                    port:makeicns
depends_lib-append  port:ultimatepp

# Compiler requirements: C++17 support (inherited from U++)
compiler.cxx_standard   2017

# No configure phase - uses umk directly
use_configure       no

# Build using umk from ultimatepp port
build.cmd           ${prefix}/bin/umk
build.args          ${worksrcpath},${prefix}/share/upp/uppsrc \
                    Bobcat \
                    CLANG \
                    -brh \
                    +GUI,SHARED \
                    Bobcat
build.env           CXX=${configure.cxx}
build.target

pre-build {
    # Determine build method based on compiler:
    if {[string match "*gcc*" ${configure.compiler}]} {
        build.args-delete CLANG
        build.args-append GCC
        ui_debug "Building Bobcat with GCC build method"
    } else {
        ui_debug "Building Bobcat with CLANG build method"
    }
}

post-build {
    set icon_source ${worksrcpath}/Bobcat/data/bobcat128x128.png
    # umk builds the .app in ${worksrcpath}/Bobcat/Bobcat.app
    set app_resources ${worksrcpath}/Bobcat/Bobcat.app/Contents/Resources

    # Generate .icns file using makeicns
    system "makeicns -in ${icon_source} -out ${app_resources}/bobcat.icns"

    # Update Info.plist to reference the icon
    set plist ${worksrcpath}/Bobcat/Bobcat.app/Contents/Info.plist
    system "plutil -replace CFBundleIconFile -string bobcat ${plist}"

    ui_debug "Created app icon: ${app_resources}/bobcat.icns"
}

destroot {
    # Install Bobcat.app bundle to MacPorts Applications directory
    copy ${worksrcpath}/Bobcat/Bobcat.app ${destroot}${applications_dir}/Bobcat.app

    # Create symlink for command-line access
    ln -s ${applications_dir}/Bobcat.app/Contents/MacOS/Bobcat ${destroot}${prefix}/bin/bobcat

    # Install documentation
    xinstall -d ${destroot}${prefix}/share/doc/${name}
    xinstall -m 644 ${worksrcpath}/README.md ${destroot}${prefix}/share/doc/${name}/
    xinstall -m 644 ${worksrcpath}/LICENSE ${destroot}${prefix}/share/doc/${name}/
}

notes "
Bobcat Terminal has been installed.

You can now:
  - Open Bobcat.app from ${applications_dir}
  - Run `bobcat` from the command line
"
