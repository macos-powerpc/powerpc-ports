PortSystem          1.0
PortGroup           cmake 1.1
PortGroup           github 1.0
PortGroup           legacysupport 1.1

# CLOCK_MONOTONIC
legacysupport.newest_darwin_requires_legacy 15

github.setup        redis hiredis 1.4.0 v
revision            0
categories          databases
license             BSD
maintainers         nomaintainer
description         Hiredis is a minimalistic C client library \
                    for the Redis database
long_description    {*}${description}
checksums           rmd160  e0f3ece27bdbe2ae957842f70799bca0caecfbc3 \
                    sha256  5fa6e719e59cd4f8ae435c52a18ac4035d135251f9ee54e7a045bccf59107ed8 \
                    size    171943
github.tarball_from archive

configure.args-append   -DDISABLE_TESTS=ON \
                        -DENABLE_NUGET=OFF

compiler.c_standard     1999
configure.cflags-append -std=c99

variant universal   {}

# Pragmas inside functions
if {[string match *gcc-4.* ${configure.compiler}]} {
    patchfiles-append   patch-gcc4.diff
}

platform darwin 8 {
    patchfiles-append   patch-hiredis-tiger.diff
}

# exclude pre-release versions
github.livecheck.regex  {([0-9.]+)}
