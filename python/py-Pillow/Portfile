PortSystem          1.0
PortGroup           python 1.0

name                py-Pillow
version             12.3.0
revision            0
categories-append   devel
license             BSD

python.versions     27 310 311 312 313 314

maintainers         {stromnov @stromnov} openmaintainer

description         Python Imaging Library (fork)
long_description    {*}${description}

homepage            https://github.com/python-imaging/Pillow

checksums           rmd160  1371c731efe856275fa0efd5c8f6b7469ca711c2 \
                    sha256  3b8182a766685eaa002637e28b4ec8d6b18819a0c71f579bf0dbaa5830297cce \
                    size    47025035

if {${subport} ne ${name}} {
    if {${python.version} == 27} {
        conflicts   py${python.version}-pil
        version             6.2.2
        checksums           rmd160 22b39d6d4dff18415340df080e1b598ee204a97e \
                            sha256 db9ff0c251ed066d367f53b64827cc9e18ccea001b986d08c265e53625dab950 \
                            size   37811273

        python.pep517       no

        patchfiles-append   patch-setup.py_v6.2.1.diff

        build.target        build_ext
    } else {
        distname            pillow-${version}
        patchfiles-append   patch-setup.py.diff patch-ImageQt.py.diff

        build.args-append   -C imagequant=disable

        depends_build-append \
                            port:py${python.version}-pybind11

        variant raqm description "Build with raqm feature" {
            depends_lib-append     port:libraqm
        }
        if {![variant_isset raqm]} {
            build.args-append      -C raqm=disable
        }

        variant x11 {
            depends_lib-append     port:xorg-libxcb
        }
        if {![variant_isset x11]} {
            build.args-append      -C xcb=disable
        }
    }

    depends_build-append \
                        port:py${python.version}-setuptools
    depends_lib-append  path:lib/pkgconfig/freetype2.pc:freetype \
                        port:lcms2 \
                        port:libavif \
                        path:include/turbojpeg.h:libjpeg-turbo \
                        port:openjpeg \
                        port:py${python.version}-olefile \
                        port:py${python.version}-tkinter \
                        port:tiff \
                        port:webp \
                        port:zlib

    if {${python.version} < 312} {
        # Mode.c:30: error: ‘for’ loop initial declaration used outside C99 mode
        compiler.c_standard 1999
        configure.cflags-append \
                        -std=c99
    }

    post-patch {
        reinplace "s|@prefix@|${prefix}|g" ${worksrcpath}/setup.py
    }

    livecheck.type      none
}
