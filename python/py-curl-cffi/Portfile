python.versions     310 311 312 313 314

if {${subport} ne ${name}} {
    # Fix build:
    patchfiles          macports-curl-impersonate.patch \
                        patch-libs.json

    post-patch {
        reinplace "s|@PREFIX@|${prefix}|g" ${worksrcpath}/scripts/build.py
        if {${configure.cxx_stdlib} eq "libc++"} {
            reinplace "s|@CXXLIB@|c++|g" ${worksrcpath}/scripts/build.py
        } else {
            reinplace "s|@CXXLIB@|stdc++|g" ${worksrcpath}/scripts/build.py
        }
    }

    depends_build-append \
                        port:py${python.version}-build \
                        port:py${python.version}-installer \
                        port:py${python.version}-wheel

    depends_lib-append  port:curl-impersonate \
                        port:py${python.version}-certifi \
                        port:py${python.version}-cffi \
                        port:py${python.version}-eventlet \
                        port:py${python.version}-gevent \
                        port:py${python.version}-rich \
                        port:py${python.version}-typing_extensions
}
