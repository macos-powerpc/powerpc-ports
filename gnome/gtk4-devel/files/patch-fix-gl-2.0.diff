+
+GDK_AVAILABLE_IN_4_2
+GskRenderer *gsk_gl_legacy_renderer_new      (void);
+
+G_DEFINE_AUTOPTR_CLEANUP_FUNC (GskGLLegacyRenderer, g_object_unref)
+
+G_END_DECLS
