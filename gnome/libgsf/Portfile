# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           gobject_introspection 1.0

name                libgsf
version             1.14.58
revision            0
license             LGPL-2.1
set branch          [join [lrange [split $version .] 0 1] .]
maintainers         nomaintainer
categories          gnome

description         An I/O abstraction library for dealing with file formats
long_description    ${name} aims to provide an efficient extensible \
                    I/O abstraction for dealing with different \
                    structured file formats.

homepage            https://www.gnome.org
master_sites        gnome:sources/$name/$branch/

use_xz              yes

checksums           rmd160  6bed8f9e7bbced620dd14b6c61c13b0dd5947e90 \
                    sha256  06e07ea12b7a52b9e316faddfecb640b1717a4875c59f0efb3b0cec1e2ccf35a \
                    size    718972

depends_build       port:gettext \
                    port:gtk-doc \
                    path:bin/pkg-config:pkgconfig

depends_lib         port:bzip2 \
                    path:lib/pkgconfig/gdk-pixbuf-2.0.pc:gdk-pixbuf2 \
                    port:gettext-runtime \
                    path:lib/pkgconfig/glib-2.0.pc:glib2 \
                    port:libxml2 \
                    port:zlib

gobject_introspection yes

configure.args      --disable-silent-rules

post-destroot {
    set docdir ${prefix}/share/doc/${name}
    xinstall -d ${destroot}${docdir}
    xinstall -m 644 -W ${worksrcpath} AUTHORS COPYING NEWS README \
        ${destroot}${docdir}
}

livecheck.type      gnome
