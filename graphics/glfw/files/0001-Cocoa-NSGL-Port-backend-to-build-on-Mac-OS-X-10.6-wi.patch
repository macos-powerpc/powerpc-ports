 src/cocoa_monitor.m  |  41 +++---
 src/cocoa_platform.h |  10 +-
 src/cocoa_window.m   | 311 +++++++++++++++++++++++++++----------------
 src/nsgl_context.m   |  80 +++++------
 5 files changed, 309 insertions(+), 206 deletions(-)

