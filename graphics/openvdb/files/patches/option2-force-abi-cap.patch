From: OpenVDB Contributors
Subject: [PATCH] Cap ABI version to 11 on 32-bit platforms

On 32-bit platforms, ABI version 12+ causes template explosion with TBB
due to Index64 usage in node counting methods, leading to compiler memory
exhaustion. This patch forces ABI version 11 on 32-bit systems.

Fixes: https://github.com/AcademySoftwareFoundation/openvdb/issues/2172

---
 openvdb/openvdb/version.h.in | 15 +++++++++++++++
 1 file changed, 15 insertions(+)

diff --git a/openvdb/openvdb/version.h.in b/openvdb/openvdb/version.h.in
index abcdef1..1234567 100644
--- a/openvdb/openvdb/version.h.in
+++ b/openvdb/openvdb/version.h.in
@@ -43,6 +43,8 @@
 #ifndef OPENVDB_VERSION_HAS_BEEN_INCLUDED
 #define OPENVDB_VERSION_HAS_BEEN_INCLUDED

+#include <cstdint>
+
 #include "openvdb/Platform.h"

 #include <cstddef> // size_t
@@ -75,6 +77,19 @@
 #define OPENVDB_ABI_VERSION_NUMBER ${OPENVDB_ABI_VERSION_NUMBER}
 #endif

+/// @brief On 32-bit platforms, cap ABI version to 11 to avoid template
+/// explosion with TBB caused by Index64 usage in node counting methods.
+/// @details ABI 12+ changed leafCount(), nodeCount(), and nonLeafCount()
+/// to return Index64, which causes excessive template instantiation with
+/// TBB's parallel constructs on 32-bit systems, leading to compiler memory
+/// exhaustion.
+/// @see https://github.com/AcademySoftwareFoundation/openvdb/issues/2172
+#if INTPTR_MAX == INT32_MAX && OPENVDB_ABI_VERSION_NUMBER >= 12
+    #undef OPENVDB_ABI_VERSION_NUMBER
+    #define OPENVDB_ABI_VERSION_NUMBER 11
+    #pragma message("OpenVDB: 32-bit platform detected, forcing ABI version 11 for compatibility")
+#endif
+
 /// @brief Library version number string of the form "<major>.<minor>.<patch>"
 /// @details This is a macro rather than a static constant because we typically
 /// want the compile-time version number, not the runtime version number
--
2.39.0
