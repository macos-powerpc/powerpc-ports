From: OpenVDB Contributors
Subject: [PATCH] Use platform-appropriate index type for node counts on 32-bit systems

This patch introduces OPENVDB_INDEX_COUNT_TYPE which resolves to Index32
on 32-bit platforms and Index64 on 64-bit platforms. This prevents
template explosion and compiler memory exhaustion when building with TBB
on 32-bit systems (e.g., 32-bit PowerPC).

Fixes: https://github.com/AcademySoftwareFoundation/openvdb/issues/2172

---
 openvdb/openvdb/Platform.h           | 10 ++++++++++
 openvdb/openvdb/Types.h              |  8 ++++++++
 openvdb/openvdb/tree/InternalNode.h  | 10 +++++-----
 openvdb/openvdb/tree/LeafManager.h   |  2 +-
 openvdb/openvdb/tree/LeafNode.h      |  6 +++---
 openvdb/openvdb/tree/LeafNodeBool.h  |  6 +++---
 openvdb/openvdb/tree/LeafNodeMask.h  |  6 +++---
 openvdb/openvdb/tree/RootNode.h      |  8 ++++----
 8 files changed, 37 insertions(+), 19 deletions(-)

diff --git a/openvdb/openvdb/Platform.h b/openvdb/openvdb/Platform.h
index abcdef1..1234567 100644
--- a/openvdb/openvdb/Platform.h
+++ b/openvdb/openvdb/Platform.h
@@ -6,6 +6,16 @@
 #ifndef OPENVDB_PLATFORM_HAS_BEEN_INCLUDED
 #define OPENVDB_PLATFORM_HAS_BEEN_INCLUDED

+/// @brief Detect 32-bit platforms
+/// @details On 32-bit platforms, using Index64 for node counts can cause
+/// template instantiation explosion with TBB, leading to compiler memory
+/// exhaustion. This macro allows selecting an appropriate index type.
+#include <cstdint>
+#if INTPTR_MAX == INT32_MAX
+    #define OPENVDB_32BIT_PLATFORM 1
+#else
+    #define OPENVDB_32BIT_PLATFORM 0
+#endif

 #define PRAGMA(x) _Pragma(#x)

diff --git a/openvdb/openvdb/Types.h b/openvdb/openvdb/Types.h
index abcdef2..1234568 100644
--- a/openvdb/openvdb/Types.h
+++ b/openvdb/openvdb/Types.h
@@ -33,6 +33,14 @@ using Index64 = uint64_t;
 using Index   = Index32;
 using Int16   = int16_t;
 using Int32   = int32_t;
+
+/// @brief Index type for node/leaf counts
+/// @details On 32-bit platforms, use Index32 to avoid template explosion
+/// with TBB that can exhaust compiler memory.
+#if OPENVDB_32BIT_PLATFORM
+using IndexCount = Index32;
+#else
+using IndexCount = Index64;
+#endif
 using Int64   = int64_t;
 using Int     = Int32;
 using Byte    = unsigned char;
diff --git a/openvdb/openvdb/tree/InternalNode.h b/openvdb/openvdb/tree/InternalNode.h
index abcdef3..1234569 100644
--- a/openvdb/openvdb/tree/InternalNode.h
+++ b/openvdb/openvdb/tree/InternalNode.h
@@ -277,7 +277,7 @@ public:
     /// Set the transient data value.
     void setTransientData(Index32 transientData) { mTransientData = transientData; }

-    Index64 leafCount() const;
+    IndexCount leafCount() const;
     Index64 nonLeafCount() const;
     void nodeCount(std::vector<Index64> &vec) const;
     OPENVDB_DEPRECATED_MESSAGE("Use input type std::vector<Index64> for nodeCount.")
@@ -1111,12 +1111,12 @@ inline Index64

 template<typename ChildT, Index Log2Dim>
-inline Index64
+inline IndexCount
 InternalNode<ChildT, Log2Dim>::leafCount() const
 {
-    if (ChildNodeType::getLevel() == 0) return mChildMask.countOn();
-    Index64 sum = 0;
+    if (ChildNodeType::getLevel() == 0) return static_cast<IndexCount>(mChildMask.countOn());
+    IndexCount sum = 0;
     for (ChildOnCIter iter = this->cbeginChildOn(); iter; ++iter) {
         sum += iter->leafCount();
     }
diff --git a/openvdb/openvdb/tree/LeafManager.h b/openvdb/openvdb/tree/LeafManager.h
index abcdef4..123456a 100644
--- a/openvdb/openvdb/tree/LeafManager.h
+++ b/openvdb/openvdb/tree/LeafManager.h
@@ -597,7 +597,7 @@ private:

         // Compute the leaf counts for each node

-        std::vector<Index64> leafCounts;
+        std::vector<IndexCount> leafCounts;
         if (serial) {
             leafCounts.reserve(leafParents.size());
             for (LeafParentT* leafParent : leafParents) {
diff --git a/openvdb/openvdb/tree/LeafNode.h b/openvdb/openvdb/tree/LeafNode.h
index abcdef5..123456b 100644
--- a/openvdb/openvdb/tree/LeafNode.h
+++ b/openvdb/openvdb/tree/LeafNode.h
@@ -129,11 +129,11 @@ public:
     /// Return the dimension of child nodes of this LeafNode, which is one for voxels.
     static Index getChildDim() { return 1; }
     /// Return the leaf count for this node, which is one.
-    static Index64 leafCount() { return 1; }
+    static IndexCount leafCount() { return 1; }
     /// no-op
     void nodeCount(std::vector<Index64> &) const {}
     OPENVDB_DEPRECATED_MESSAGE("Use input type std::vector<Index64> for nodeCount.")
     void nodeCount(std::vector<Index32> &) const {}
     /// Return the non-leaf count for this node, which is zero.
-    static Index64 nonLeafCount() { return 0; }
+    static IndexCount nonLeafCount() { return 0; }
     /// Return the child count for this node, which is zero.
diff --git a/openvdb/openvdb/tree/LeafNodeBool.h b/openvdb/openvdb/tree/LeafNodeBool.h
index abcdef6..123456c 100644
--- a/openvdb/openvdb/tree/LeafNodeBool.h
+++ b/openvdb/openvdb/tree/LeafNodeBool.h
@@ -114,12 +114,12 @@ public:
     static void getNodeLog2Dims(std::vector<Index>& dims) { dims.push_back(Log2Dim); }
     static Index getChildDim() { return 1; }

-    static Index64 leafCount() { return 1; }
+    static IndexCount leafCount() { return 1; }
     /// no-op
     void nodeCount(std::vector<Index64> &) const {}
     OPENVDB_DEPRECATED_MESSAGE("Use input type std::vector<Index64> for nodeCount.")
     void nodeCount(std::vector<Index32> &) const {}
-    static Index64 nonLeafCount() { return 0; }
+    static IndexCount nonLeafCount() { return 0; }

     /// Return the number of active voxels.
diff --git a/openvdb/openvdb/tree/LeafNodeMask.h b/openvdb/openvdb/tree/LeafNodeMask.h
index abcdef7..123456d 100644
--- a/openvdb/openvdb/tree/LeafNodeMask.h
+++ b/openvdb/openvdb/tree/LeafNodeMask.h
@@ -112,12 +112,12 @@ public:
     static void getNodeLog2Dims(std::vector<Index>& dims) { dims.push_back(Log2Dim); }
     static Index getChildDim() { return 1; }
     /// Return the leaf count for this node, which is one.
-    static Index64 leafCount() { return 1; }
+    static IndexCount leafCount() { return 1; }
     /// no-op
     void nodeCount(std::vector<Index64> &) const {}
     OPENVDB_DEPRECATED_MESSAGE("Use input type std::vector<Index64> for nodeCount.")
     void nodeCount(std::vector<Index32> &) const {}
     /// Return the non-leaf count for this node, which is zero.
-    static Index64 nonLeafCount() { return 0; }
+    static IndexCount nonLeafCount() { return 0; }

diff --git a/openvdb/openvdb/tree/RootNode.h b/openvdb/openvdb/tree/RootNode.h
index abcdef8..123456e 100644
--- a/openvdb/openvdb/tree/RootNode.h
+++ b/openvdb/openvdb/tree/RootNode.h
@@ -487,7 +487,7 @@ public:
     template<typename OtherChildType>
     static bool hasCompatibleValueType(const RootNode<OtherChildType>& other);

-    Index64 leafCount() const;
+    IndexCount leafCount() const;
     Index64 nonLeafCount() const;
     Index32 childCount() const;
     Index32 tileCount() const;
@@ -1544,10 +1544,10 @@ RootNode<ChildT>::evalActiveBoundingBox(CoordBBox& bbox, bool visitVoxels) const


 template<typename ChildT>
-inline Index64
+inline IndexCount
 RootNode<ChildT>::leafCount() const
 {
-    Index64 sum = 0;
+    IndexCount sum = 0;
     for (MapCIter i = mTable.begin(), e = mTable.end(); i != e; ++i) {
         if (isChild(i)) sum += getChild(i).leafCount();
     }
