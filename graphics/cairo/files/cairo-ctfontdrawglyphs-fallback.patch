From: Sergey Fedorov <vital.had@gmail.com>
Subject: Add fallback for CTFontDrawGlyphs on macOS < 10.7

CTFontDrawGlyphs was introduced in macOS 10.7. For older systems,
fall back to CGContextShowGlyphsWithAdvances.

diff --git a/configure.ac b/configure.ac
--- a/configure.ac
+++ b/configure.ac
@@ -206,6 +206,24 @@ AC_SUBST(quartz_LIBS)
 
 CAIRO_ENABLE_FONT_BACKEND(quartz_font, Quartz, auto, [
   use_quartz_font=$use_quartz
+  if test "x$use_quartz_font" = "xyes"; then
+    dnl Check for CTFontDrawGlyphs (macOS 10.7+)
+    save_LIBS="$LIBS"
+    LIBS="$LIBS $quartz_LIBS"
+    AC_MSG_CHECKING([for CTFontDrawGlyphs])
+    AC_LINK_IFELSE([AC_LANG_PROGRAM([[
+#include <ApplicationServices/ApplicationServices.h>
+    ]], [[
+CTFontDrawGlyphs(0, 0, 0, 0, 0);
+    ]])],
+    [have_ctfont_draw_glyphs=yes],
+    [have_ctfont_draw_glyphs=no])
+    AC_MSG_RESULT([$have_ctfont_draw_glyphs])
+    if test "x$have_ctfont_draw_glyphs" = "xyes"; then
+      AC_DEFINE([HAVE_CTFONT_DRAW_GLYPHS], 1, [Define to 1 if CTFontDrawGlyphs is available])
+    fi
+    LIBS="$save_LIBS"
+  fi
 ])
 
 CAIRO_ENABLE_SURFACE_BACKEND(quartz_image, Quartz Image, no, [
diff --git a/src/cairo-quartz-font.c b/src/cairo-quartz-font.c
--- a/src/cairo-quartz-font.c
+++ b/src/cairo-quartz-font.c
@@ -657,7 +657,16 @@ _cairo_quartz_init_glyph_surface (cairo_quartz_scaled_font_t *font,
 	CGContextSetAlpha (cgContext, 1.0);
 	CGContextTranslateCTM (cgContext, -glyphOrigin.x, -glyphOrigin.y);
 	CGContextConcatCTM (cgContext, textMatrix);
+#if HAVE_CTFONT_DRAW_GLYPHS
 	CTFontDrawGlyphs (font->ctFont, &glyph, &CGPointZero, 1, cgContext);
+#else
+	CGGlyph cg_glyph = glyph;
+	CGSize zero_advance = { 0.0, 0.0 };
+	CGContextSetFont (cgContext, font->cgFont);
+	CGContextSetFontSize (cgContext, 1.0);
+	CGContextSetTextMatrix (cgContext, CGAffineTransformIdentity);
+	CGContextShowGlyphsWithAdvances (cgContext, &cg_glyph, &zero_advance, 1);
+#endif
 	CGContextRelease (cgContext);
 	CGColorSpaceRelease (colorspace);
     }
diff --git a/src/cairo-quartz-surface.c b/src/cairo-quartz-surface.c
--- a/src/cairo-quartz-surface.c
+++ b/src/cairo-quartz-surface.c
@@ -1941,7 +1941,39 @@ _cairo_quartz_cg_glyphs (const cairo_compositor_t *compositor,
     CGContextTranslateCTM (state.cgMaskContext, origin.x, origin.y);
     CGContextConcatCTM (state.cgMaskContext, textTransform);
 
+#if HAVE_CTFONT_DRAW_GLYPHS
     CTFontDrawGlyphs (ctFont, cg_glyphs, cg_positions, num_glyphs, state.cgMaskContext);
+#else
+    {
+	CGFontRef cgFont = _cairo_quartz_scaled_font_get_cg_font_ref (scaled_font);
+	CGSize *cg_advances;
+	CGSize cg_advances_static[CAIRO_STACK_ARRAY_LENGTH (CGSize)];
+
+	if (num_glyphs > ARRAY_LENGTH (cg_advances_static))
+	    cg_advances = (CGSize*) _cairo_malloc_ab (num_glyphs, sizeof (CGSize));
+	else
+	    cg_advances = &cg_advances_static[0];
+
+	if (likely (cg_advances)) {
+	    /* Convert positions to advances (deltas between consecutive glyphs) */
+	    for (int i = 0; i < num_glyphs - 1; ++i) {
+		cg_advances[i].width = cg_positions[i + 1].x - cg_positions[i].x;
+		cg_advances[i].height = cg_positions[i + 1].y - cg_positions[i].y;
+	    }
+	    cg_advances[num_glyphs - 1].width = 0;
+	    cg_advances[num_glyphs - 1].height = 0;
+
+	    CGContextSetFont (state.cgMaskContext, cgFont);
+	    CGContextSetFontSize (state.cgMaskContext, 1.0);
+	    CGContextSetTextMatrix (state.cgMaskContext, CGAffineTransformIdentity);
+	    CGContextSetTextPosition (state.cgMaskContext, cg_positions[0].x, cg_positions[0].y);
+	    CGContextShowGlyphsWithAdvances (state.cgMaskContext, cg_glyphs, cg_advances, num_glyphs);
+
+	    if (cg_advances != cg_advances_static)
+		free (cg_advances);
+	}
+    }
+#endif
 
     CGContextConcatCTM (state.cgMaskContext, invTextTransform);
     CGContextTranslateCTM (state.cgMaskContext, -origin.x, -origin.y);
