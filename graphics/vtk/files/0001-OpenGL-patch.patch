+      // Fallback: parse GL_VERSION string for GL 2.x
+      const char* versionStr = (const char*)glGetString(GL_VERSION);
+      if (!vtkParseOpenGLVersionString(versionStr, glMajorVersion, glMinorVersion))
+      {
+        glMajorVersion = 2;
+        glMinorVersion = 0;
+      }
+    }
   }
 
