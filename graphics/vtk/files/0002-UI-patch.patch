From 873c70693362f24ccfa99861a758e3d9536b0b7c Mon Sep 17 00:00:00 2001
From: Sergey Fedorov <barracuda@macos-powerpc.org>
Date: Sun, 3 May 2026 18:00:13 +0800
Subject: [PATCH 2/2] UI patch

---
 Rendering/UI/vtkCocoaMacOSXSDKCompatibility.h | 231 +++++++++++++++++-
 .../UI/vtkCocoaRenderWindowInteractor.mm      |   5 +-
 2 files changed, 226 insertions(+), 10 deletions(-)

diff --git a/Rendering/UI/vtkCocoaMacOSXSDKCompatibility.h b/Rendering/UI/vtkCocoaMacOSXSDKCompatibility.h
index 4153d7f704..a2c922868c 100644
--- a/Rendering/UI/vtkCocoaMacOSXSDKCompatibility.h
+++ b/Rendering/UI/vtkCocoaMacOSXSDKCompatibility.h
@@ -4,20 +4,36 @@
  * @class   vtkCocoaMacOSXSDKCompatibility
  * @brief   Compatibility header
  *
- * VTK requires the Mac OS X 10.7 SDK or later.
+ * VTK requires the Mac OS X 10.5 SDK or later.
  * However, this file is meant to allow us to use features from newer
  * SDKs by adding workarounds to still support the minimum SDK.
  * It is safe to include this header multiple times.
+ *
+ * This version includes compatibility for:
+ * - gcc (non-clang) compilers: __has_feature fallback
+ * - Mac OS X 10.5/10.6 SDK: backing scale factor helpers
+ * - Portable diagnostic pragma macros for gcc and clang
  */
 
 #include <AvailabilityMacros.h>
 
-#if MAC_OS_X_VERSION_MAX_ALLOWED < 1070
-#error VTK requires the Mac OS X 10.7 SDK or later
+//------------------------------------------------------------------------------
+// Provide __has_feature fallback for non-clang compilers (e.g., gcc)
+//------------------------------------------------------------------------------
+#ifndef __has_feature
+#define __has_feature(x) 0
+#endif
+
+//------------------------------------------------------------------------------
+// Minimum SDK version check - support 10.5+
+//------------------------------------------------------------------------------
+#if MAC_OS_X_VERSION_MAX_ALLOWED < 1050
+#error VTK requires the Mac OS X 10.5 SDK or later
 #endif
 
-#if MAC_OS_X_VERSION_MIN_REQUIRED < 1070
-#error VTK requires a deployment target of Mac OS X 10.7 or later
+// Deployment target check - we support 10.5+
+#if defined(MAC_OS_X_VERSION_MIN_REQUIRED) && MAC_OS_X_VERSION_MIN_REQUIRED < 1050
+#error VTK requires a deployment target of Mac OS X 10.5 or later
 #endif
 
 // Stop AssertMacros.h from defining its macros without underscore prefixes,
@@ -27,9 +43,39 @@
 #define __ASSERT_MACROS_DEFINE_VERSIONS_WITHOUT_UNDERSCORES 0
 #endif
 
+//------------------------------------------------------------------------------
+// Portable diagnostic pragma macros
+// These work with both gcc and clang to suppress specific warnings
+//------------------------------------------------------------------------------
+#define VTK_DIAG_STR(s) #s
+#define VTK_DIAG_JOINSTR(x, y) VTK_DIAG_STR(x##y)
+#define VTK_DIAG_PRAGMA(x) _Pragma(VTK_DIAG_STR(x))
+
+#ifdef __clang__
+#define VTK_DIAG_OFF(x)                                                                            \
+  VTK_DIAG_PRAGMA(clang diagnostic push)                                                           \
+  VTK_DIAG_PRAGMA(clang diagnostic ignored VTK_DIAG_JOINSTR(-W, x))
+#define VTK_DIAG_ON(x) VTK_DIAG_PRAGMA(clang diagnostic pop)
+#elif defined(__GNUC__)
+#if (__GNUC__ * 100 + __GNUC_MINOR__) >= 406
+#define VTK_DIAG_OFF(x)                                                                            \
+  VTK_DIAG_PRAGMA(GCC diagnostic push)                                                             \
+  VTK_DIAG_PRAGMA(GCC diagnostic ignored VTK_DIAG_JOINSTR(-W, x))
+#define VTK_DIAG_ON(x) VTK_DIAG_PRAGMA(GCC diagnostic pop)
+#else
+#define VTK_DIAG_OFF(x) VTK_DIAG_PRAGMA(GCC diagnostic ignored VTK_DIAG_JOINSTR(-W, x))
+#define VTK_DIAG_ON(x) VTK_DIAG_PRAGMA(GCC diagnostic warning VTK_DIAG_JOINSTR(-W, x))
+#endif
+#else
+#define VTK_DIAG_OFF(x)
+#define VTK_DIAG_ON(x)
+#endif
+
+//------------------------------------------------------------------------------
+// SDK 10.12+ enum name mappings
+// The 10.12 SDK made a bunch of enum names more logical, map old names to new
+//------------------------------------------------------------------------------
 #if (MAC_OS_X_VERSION_MAX_ALLOWED < 101200) && !defined(VTK_DONT_MAP_10_12_ENUMS)
-// The 10.12 SDK made a bunch of enum names more logical, map old names to new names to continue
-// supporting old SDKs.
 #define NSWindowStyleMask NSUInteger
 #define NSWindowStyleMaskBorderless NSBorderlessWindowMask
 #define NSWindowStyleMaskTitled NSTitledWindowMask
@@ -50,8 +96,10 @@
 #define NSEventMaskAny NSAnyEventMask
 #endif
 
-// Create handy #defines that indicate the Objective-C memory management model.
-// Manual Retain Release, Automatic Reference Counting, or Garbage Collection.
+//------------------------------------------------------------------------------
+// Objective-C memory management model detection
+// Manual Retain Release, Automatic Reference Counting, or Garbage Collection
+//------------------------------------------------------------------------------
 #if defined(__OBJC_GC__)
 #define VTK_OBJC_IS_MRR 0
 #define VTK_OBJC_IS_ARC 0
@@ -70,4 +118,169 @@
 #error VTK does not yet support ARC memory management
 #endif
 
+//------------------------------------------------------------------------------
+// 10.6 compatibility helpers for backing scale factor APIs
+// These APIs were added in 10.7, so we provide fallbacks for 10.5/10.6
+//------------------------------------------------------------------------------
+#ifdef __OBJC__
+#import <AppKit/AppKit.h>
+
+/**
+ * Convert a point from view coordinates to backing store pixels.
+ * On 10.7+, uses convertPointToBacking:. On 10.6 and earlier, returns as-is.
+ */
+static inline NSPoint vtkCocoaConvertPointToBacking(NSView* view, NSPoint point)
+{
+#if MAC_OS_X_VERSION_MAX_ALLOWED >= 1070
+  if ([view respondsToSelector:@selector(convertPointToBacking:)])
+  {
+    return [view convertPointToBacking:point];
+  }
+#endif
+  (void)view;
+  return point;
+}
+
+/**
+ * Convert a point from backing store pixels to view coordinates.
+ * On 10.7+, uses convertPointFromBacking:. On 10.6 and earlier, returns as-is.
+ */
+static inline NSPoint vtkCocoaConvertPointFromBacking(NSView* view, NSPoint point)
+{
+#if MAC_OS_X_VERSION_MAX_ALLOWED >= 1070
+  if ([view respondsToSelector:@selector(convertPointFromBacking:)])
+  {
+    return [view convertPointFromBacking:point];
+  }
+#endif
+  (void)view;
+  return point;
+}
+
+/**
+ * Convert a rectangle from view coordinates to backing store pixels.
+ * On 10.7+, uses convertRectToBacking:. On 10.6 and earlier, returns as-is.
+ */
+static inline NSRect vtkCocoaConvertRectToBacking(NSView* view, NSRect rect)
+{
+#if MAC_OS_X_VERSION_MAX_ALLOWED >= 1070
+  if ([view respondsToSelector:@selector(convertRectToBacking:)])
+  {
+    return [view convertRectToBacking:rect];
+  }
+#endif
+  (void)view;
+  return rect;
+}
+
+/**
+ * Convert a rectangle from backing store pixels to view coordinates.
+ * On 10.7+, uses convertRectFromBacking:. On 10.6 and earlier, returns as-is.
+ */
+static inline NSRect vtkCocoaConvertRectFromBacking(NSView* view, NSRect rect)
+{
+#if MAC_OS_X_VERSION_MAX_ALLOWED >= 1070
+  if ([view respondsToSelector:@selector(convertRectFromBacking:)])
+  {
+    return [view convertRectFromBacking:rect];
+  }
+#endif
+  (void)view;
+  return rect;
+}
+
+/**
+ * Get the backing scale factor for a window.
+ * On 10.7+, uses backingScaleFactor. On 10.6 and earlier, returns 1.0.
+ */
+static inline CGFloat vtkCocoaBackingScaleFactor(NSWindow* window)
+{
+#if MAC_OS_X_VERSION_MAX_ALLOWED >= 1070
+  if ([window respondsToSelector:@selector(backingScaleFactor)])
+  {
+    return [window backingScaleFactor];
+  }
+#endif
+  (void)window;
+  return 1.0;
+}
+
+/**
+ * Get the backing scale factor for a screen.
+ * On 10.7+, uses backingScaleFactor. On 10.6 and earlier, returns 1.0.
+ */
+static inline CGFloat vtkCocoaScreenBackingScaleFactor(NSScreen* screen)
+{
+#if MAC_OS_X_VERSION_MAX_ALLOWED >= 1070
+  if ([screen respondsToSelector:@selector(backingScaleFactor)])
+  {
+    return [screen backingScaleFactor];
+  }
+#endif
+  (void)screen;
+  return 1.0;
+}
+
+/**
+ * NSWindow convertRectToBacking: helper (10.7+)
+ */
+static inline NSRect vtkCocoaWindowConvertRectToBacking(NSWindow* window, NSRect rect)
+{
+#if MAC_OS_X_VERSION_MAX_ALLOWED >= 1070
+  if ([window respondsToSelector:@selector(convertRectToBacking:)])
+  {
+    return [window convertRectToBacking:rect];
+  }
+#endif
+  (void)window;
+  return rect;
+}
+
+/**
+ * NSWindow convertRectFromBacking: helper (10.7+)
+ */
+static inline NSRect vtkCocoaWindowConvertRectFromBacking(NSWindow* window, NSRect rect)
+{
+#if MAC_OS_X_VERSION_MAX_ALLOWED >= 1070
+  if ([window respondsToSelector:@selector(convertRectFromBacking:)])
+  {
+    return [window convertRectFromBacking:rect];
+  }
+#endif
+  (void)window;
+  return rect;
+}
+
+/**
+ * NSScreen convertRectToBacking: helper (10.7+)
+ */
+static inline NSRect vtkCocoaScreenConvertRectToBacking(NSScreen* screen, NSRect rect)
+{
+#if MAC_OS_X_VERSION_MAX_ALLOWED >= 1070
+  if ([screen respondsToSelector:@selector(convertRectToBacking:)])
+  {
+    return [screen convertRectToBacking:rect];
+  }
+#endif
+  (void)screen;
+  return rect;
+}
+
+/**
+ * NSScreen convertRectFromBacking: helper (10.7+)
+ */
+static inline NSRect vtkCocoaScreenConvertRectFromBacking(NSScreen* screen, NSRect rect)
+{
+#if MAC_OS_X_VERSION_MAX_ALLOWED >= 1070
+  if ([screen respondsToSelector:@selector(convertRectFromBacking:)])
+  {
+    return [screen convertRectFromBacking:rect];
+  }
+#endif
+  (void)screen;
+  return rect;
+}
+
+#endif // __OBJC__
+
 // VTK-HeaderTest-Exclude: vtkCocoaMacOSXSDKCompatibility.h
diff --git a/Rendering/UI/vtkCocoaRenderWindowInteractor.mm b/Rendering/UI/vtkCocoaRenderWindowInteractor.mm
index af99efa8b6..1919032857 100644
--- a/Rendering/UI/vtkCocoaRenderWindowInteractor.mm
+++ b/Rendering/UI/vtkCocoaRenderWindowInteractor.mm
@@ -203,7 +203,10 @@ vtkCocoaRenderWindowInteractor::vtkCocoaRenderWindowInteractor()
 vtkCocoaRenderWindowInteractor::~vtkCocoaRenderWindowInteractor()
 {
   NSMutableDictionary* timerDict = (NSMutableDictionary*)(this->GetTimerDictionary());
-  for (NSString* key in timerDict)
+  // Use NSEnumerator instead of fast enumeration for gcc compatibility
+  NSEnumerator* keyEnumerator = [timerDict keyEnumerator];
+  NSString* key;
+  while ((key = [keyEnumerator nextObject]) != nil)
   {
     vtkCocoaTimer* cocoaTimer = [timerDict objectForKey:key];
     [cocoaTimer stopTimer];
-- 
2.54.0

