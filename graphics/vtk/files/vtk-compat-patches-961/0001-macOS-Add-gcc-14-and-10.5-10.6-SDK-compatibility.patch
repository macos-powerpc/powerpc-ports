 #define NSWindowStyleMaskBorderless NSBorderlessWindowMask
 #define NSWindowStyleMaskTitled NSTitledWindowMask
@@ -50,8 +96,10 @@
 #define NSEventMaskAny NSAnyEventMask
 #endif
 
