+//------------------------------------------------------------------------------
+// 10.6 compatibility helpers for backing scale factor APIs
+// These APIs were added in 10.7, so we provide fallbacks for 10.5/10.6
+//------------------------------------------------------------------------------
+#ifdef __OBJC__
+#import <AppKit/AppKit.h>
+
+/**
+ * Convert a point from view coordinates to backing store pixels.
+ * On 10.7+, uses convertPointToBacking:. On 10.6 and earlier, returns as-is.
+ */
+static inline NSPoint vtkCocoaConvertPointToBacking(NSView* view, NSPoint point)
+{
+#if MAC_OS_X_VERSION_MAX_ALLOWED >= 1070
+  if ([view respondsToSelector:@selector(convertPointToBacking:)])
+  {
+    return [view convertPointToBacking:point];
+  }
+#endif
+  (void)view;
+  return point;
+}
+
+/**
+ * Convert a point from backing store pixels to view coordinates.
+ * On 10.7+, uses convertPointFromBacking:. On 10.6 and earlier, returns as-is.
+ */
+static inline NSPoint vtkCocoaConvertPointFromBacking(NSView* view, NSPoint point)
+{
+#if MAC_OS_X_VERSION_MAX_ALLOWED >= 1070
+  if ([view respondsToSelector:@selector(convertPointFromBacking:)])
+  {
+    return [view convertPointFromBacking:point];
+  }
+#endif
+  (void)view;
+  return point;
+}
+
+/**
+ * Convert a rectangle from view coordinates to backing store pixels.
+ * On 10.7+, uses convertRectToBacking:. On 10.6 and earlier, returns as-is.
+ */
+static inline NSRect vtkCocoaConvertRectToBacking(NSView* view, NSRect rect)
+{
+#if MAC_OS_X_VERSION_MAX_ALLOWED >= 1070
+  if ([view respondsToSelector:@selector(convertRectToBacking:)])
+  {
+    return [view convertRectToBacking:rect];
+  }
+#endif
+  (void)view;
+  return rect;
+}
+
+/**
+ * Convert a rectangle from backing store pixels to view coordinates.
+ * On 10.7+, uses convertRectFromBacking:. On 10.6 and earlier, returns as-is.
+ */
+static inline NSRect vtkCocoaConvertRectFromBacking(NSView* view, NSRect rect)
+{
+#if MAC_OS_X_VERSION_MAX_ALLOWED >= 1070
+  if ([view respondsToSelector:@selector(convertRectFromBacking:)])
+  {
+    return [view convertRectFromBacking:rect];
+  }
+#endif
+  (void)view;
+  return rect;
+}
+
+/**
+ * Get the backing scale factor for a window.
+ * On 10.7+, uses backingScaleFactor. On 10.6 and earlier, returns 1.0.
+ */
