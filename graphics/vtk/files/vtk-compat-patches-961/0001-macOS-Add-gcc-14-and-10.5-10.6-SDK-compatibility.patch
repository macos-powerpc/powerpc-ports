@@ -27,9 +43,39 @@
 #define __ASSERT_MACROS_DEFINE_VERSIONS_WITHOUT_UNDERSCORES 0
 #endif
 
+//------------------------------------------------------------------------------
+// Portable diagnostic pragma macros
+// These work with both gcc and clang to suppress specific warnings
+//------------------------------------------------------------------------------
+#define VTK_DIAG_STR(s) #s
+#define VTK_DIAG_JOINSTR(x, y) VTK_DIAG_STR(x##y)
+#define VTK_DIAG_PRAGMA(x) _Pragma(VTK_DIAG_STR(x))
+
+#ifdef __clang__
+#define VTK_DIAG_OFF(x)                                                                            \
+  VTK_DIAG_PRAGMA(clang diagnostic push)                                                           \
+  VTK_DIAG_PRAGMA(clang diagnostic ignored VTK_DIAG_JOINSTR(-W, x))
+#define VTK_DIAG_ON(x) VTK_DIAG_PRAGMA(clang diagnostic pop)
+#elif defined(__GNUC__)
+#if (__GNUC__ * 100 + __GNUC_MINOR__) >= 406
+#define VTK_DIAG_OFF(x)                                                                            \
+  VTK_DIAG_PRAGMA(GCC diagnostic push)                                                             \
+  VTK_DIAG_PRAGMA(GCC diagnostic ignored VTK_DIAG_JOINSTR(-W, x))
+#define VTK_DIAG_ON(x) VTK_DIAG_PRAGMA(GCC diagnostic pop)
+#else
+#define VTK_DIAG_OFF(x) VTK_DIAG_PRAGMA(GCC diagnostic ignored VTK_DIAG_JOINSTR(-W, x))
+#define VTK_DIAG_ON(x) VTK_DIAG_PRAGMA(GCC diagnostic warning VTK_DIAG_JOINSTR(-W, x))
+#endif
+#else
+#define VTK_DIAG_OFF(x)
+#define VTK_DIAG_ON(x)
+#endif
+
+//------------------------------------------------------------------------------
+// SDK 10.12+ enum name mappings
+// The 10.12 SDK made a bunch of enum names more logical, map old names to new
+//------------------------------------------------------------------------------
 #if (MAC_OS_X_VERSION_MAX_ALLOWED < 101200) && !defined(VTK_DONT_MAP_10_12_ENUMS)
-// The 10.12 SDK made a bunch of enum names more logical, map old names to new names to continue
-// supporting old SDKs.
