+//------------------------------------------------------------------------------
+// Objective-C memory management model detection
+// Manual Retain Release, Automatic Reference Counting, or Garbage Collection
+//------------------------------------------------------------------------------
 #if defined(__OBJC_GC__)
 #define VTK_OBJC_IS_MRR 0
