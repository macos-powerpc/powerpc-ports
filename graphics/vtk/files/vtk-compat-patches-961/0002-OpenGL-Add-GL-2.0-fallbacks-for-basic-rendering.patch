 Rendering/OpenGL2/vtkOSOpenGLRenderWindow.cxx |  38 +++++-
 Rendering/OpenGL2/vtkOpenGLRenderWindow.cxx   | 128 +++++++++++++++---
 2 files changed, 142 insertions(+), 24 deletions(-)

diff --git a/Rendering/OpenGL2/vtkOSOpenGLRenderWindow.cxx b/Rendering/OpenGL2/vtkOSOpenGLRenderWindow.cxx
index 649afafd11..0a72520126 100644
