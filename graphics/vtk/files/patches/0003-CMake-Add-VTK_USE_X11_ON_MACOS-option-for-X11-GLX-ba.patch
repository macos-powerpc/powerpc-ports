From 2f9933871e2973d00f43f8fe944ff77a4f0b9b0f Mon Sep 17 00:00:00 2001
From: VTK Compatibility <vtk@vtk.org>
Date: Fri, 1 May 2026 00:11:20 +0000
Subject: [PATCH 3/3] CMake: Add VTK_USE_X11_ON_MACOS option for X11/GLX
 backend on macOS

This patch adds a new CMake option VTK_USE_X11_ON_MACOS that allows
building VTK with the X11/GLX backend instead of Cocoa on macOS.

This can be useful for:
- Older macOS systems where the Cocoa backend doesn't work properly
- Systems with XQuartz that prefer X11 rendering
- Cross-compilation or compatibility testing scenarios

When VTK_USE_X11_ON_MACOS is ON:
- VTK_USE_COCOA is automatically disabled
- VTK_USE_X is automatically enabled
- vtkXOpenGLRenderWindow and vtkXRenderWindowInteractor are used
  instead of vtkCocoaRenderWindow and vtkCocoaRenderWindowInteractor

Usage:
  cmake -DVTK_USE_X11_ON_MACOS=ON ...

Note: This requires XQuartz or another X11 implementation to be
installed and properly configured on the macOS system.
---
 CMake/vtkOpenGLOptions.cmake | 15 ++++++++++++---
 1 file changed, 12 insertions(+), 3 deletions(-)

diff --git a/CMake/vtkOpenGLOptions.cmake b/CMake/vtkOpenGLOptions.cmake
index c97dec3a91..aadffde1ec 100644
--- a/CMake/vtkOpenGLOptions.cmake
+++ b/CMake/vtkOpenGLOptions.cmake
@@ -8,13 +8,22 @@ libraries are used.
 include(CMakeDependentOption)
 
 # For each platform specific API, we define VTK_USE_<API> options.
+
+# Option to use X11/GLX instead of Cocoa on macOS
+# This can be useful for older macOS systems or when using XQuartz
+option(VTK_USE_X11_ON_MACOS "Use X11/GLX instead of Cocoa on macOS (requires XQuartz)" OFF)
+mark_as_advanced(VTK_USE_X11_ON_MACOS)
+
 cmake_dependent_option(VTK_USE_COCOA "Use Cocoa for VTK render windows" ON
-  "APPLE;NOT APPLE_IOS" OFF)
+  "APPLE;NOT APPLE_IOS;NOT VTK_USE_X11_ON_MACOS" OFF)
 mark_as_advanced(VTK_USE_COCOA)
 
 set(default_use_x OFF)
-if(UNIX AND NOT ANDROID AND NOT APPLE AND NOT APPLE_IOS AND NOT CMAKE_SYSTEM_NAME STREQUAL "Emscripten")
-  set(default_use_x ON)
+if(UNIX AND NOT ANDROID AND NOT APPLE_IOS AND NOT CMAKE_SYSTEM_NAME STREQUAL "Emscripten")
+  # Enable X11 by default on non-Apple UNIX, or on Apple if VTK_USE_X11_ON_MACOS is set
+  if(NOT APPLE OR VTK_USE_X11_ON_MACOS)
+    set(default_use_x ON)
+  endif()
 endif()
 option(VTK_USE_X "Use X for VTK render windows" "${default_use_x}")
 mark_as_advanced(VTK_USE_X)
