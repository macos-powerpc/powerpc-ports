From 2ced9665ac9775e712aa4bd3d5aa9e98fc768a17 Mon Sep 17 00:00:00 2001
From: VTK Compatibility <vtk@vtk.org>
Date: Fri, 1 May 2026 00:11:11 +0000
Subject: [PATCH 2/3] OpenGL: Add OpenGL 2.0 fallback support for legacy
 systems

This patch allows VTK to run on systems with OpenGL 2.0/2.1 contexts
(such as older macOS systems that don't support OpenGL 3.2+).

Changes to vtkOpenGLRenderWindow.cxx:

- Add vtkParseOpenGLVersionString() helper function to parse the GL_VERSION
  string for systems where GL_MAJOR_VERSION/GL_MINOR_VERSION queries fail
  (these are only available in OpenGL 3.0+)

- Modify OpenGLInitContext() to:
  - Fall back to GL_VERSION string parsing when GL_MAJOR_VERSION fails
  - Lower minimum requirement from 3.2 to 2.0 with a warning
  - Allow initialization to proceed for 2.x contexts with limited functionality

- Modify GetOpenGLVersion() to use the same GL_VERSION string parsing
  fallback for GL 2.x contexts

- Modify ReportCapabilities() to use glGetString(GL_EXTENSIONS) for GL 2.x
  since GL_NUM_EXTENSIONS and glGetStringi() are only available in GL 3.0+

Note: Many VTK features require OpenGL 3.2+ and will not work correctly
on GL 2.x systems. This patch only enables basic functionality.
---
 Rendering/OpenGL2/vtkOpenGLRenderWindow.cxx | 118 ++++++++++++++++----
 1 file changed, 99 insertions(+), 19 deletions(-)

diff --git a/Rendering/OpenGL2/vtkOpenGLRenderWindow.cxx b/Rendering/OpenGL2/vtkOpenGLRenderWindow.cxx
index 5e45d57d89..94f719217b 100644
--- a/Rendering/OpenGL2/vtkOpenGLRenderWindow.cxx
+++ b/Rendering/OpenGL2/vtkOpenGLRenderWindow.cxx
@@ -61,6 +61,23 @@ using std::ostringstream;
 
 #include <cassert>
 
+// Helper function to parse OpenGL version from GL_VERSION string
+// This is needed for GL 2.x where GL_MAJOR_VERSION/GL_MINOR_VERSION don't exist
+// Returns true if version was successfully parsed
+static bool vtkParseOpenGLVersionString(int& major, int& minor)
+{
+  const char* version = reinterpret_cast<const char*>(glGetString(GL_VERSION));
+  if (!version)
+  {
+    return false;
+  }
+
+  // GL_VERSION format: "major.minor" or "major.minor.release" followed by optional vendor info
+  // e.g. "2.1 NVIDIA-10.4.5 535.113.01" or "3.3.0 NVIDIA 535.113.01"
+  int scanned = sscanf(version, "%d.%d", &major, &minor);
+  return (scanned == 2);
+}
+
 // Initialize static member that controls global maximum number of multisamples
 // (off by default on Apple because it causes problems on some Mac models).
 #if defined(__APPLE__)
@@ -697,12 +714,34 @@ const char* vtkOpenGLRenderWindow::ReportCapabilities()
   }
 
   strm << "OpenGL extensions:  " << endl;
-  GLint n, i;
-  glGetIntegerv(GL_NUM_EXTENSIONS, &n);
-  for (i = 0; i < n; i++)
+  // GL_NUM_EXTENSIONS and glGetStringi are only available in GL 3.0+
+  // For GL 2.x, use the old glGetString(GL_EXTENSIONS) method
+  int glMajor = 0, glMinor = 0;
+  vtkParseOpenGLVersionString(glMajor, glMinor);
+  if (glMajor >= 3)
   {
-    const char* ext = (const char*)glGetStringi(GL_EXTENSIONS, i);
-    strm << "  " << ext << endl;
+    GLint n, i;
+    glGetIntegerv(GL_NUM_EXTENSIONS, &n);
+    for (i = 0; i < n; i++)
+    {
+      const char* ext = (const char*)glGetStringi(GL_EXTENSIONS, i);
+      strm << "  " << ext << endl;
+    }
+  }
+  else
+  {
+    // GL 2.x fallback: parse space-separated extension string
+    const char* extString = (const char*)glGetString(GL_EXTENSIONS);
+    if (extString)
+    {
+      std::string extensions(extString);
+      std::istringstream iss(extensions);
+      std::string ext;
+      while (iss >> ext)
+      {
+        strm << "  " << ext << endl;
+      }
+    }
   }
 
   delete[] this->Capabilities;
@@ -880,8 +919,22 @@ void vtkOpenGLRenderWindow::GetOpenGLVersion(int& major, int& minor)
 
   if (this->Initialized)
   {
+    // GL_MAJOR_VERSION/GL_MINOR_VERSION are only available in GL 3.0+
+    // First try to get them directly
     this->GetState()->vtkglGetIntegerv(GL_MAJOR_VERSION, &glMajorVersion);
-    this->GetState()->vtkglGetIntegerv(GL_MINOR_VERSION, &glMinorVersion);
+    if (glGetError() != GL_NO_ERROR || glMajorVersion == 0)
+    {
+      // Fall back to parsing GL_VERSION string for GL 2.x
+      if (!vtkParseOpenGLVersionString(glMajorVersion, glMinorVersion))
+      {
+        glMajorVersion = 2;
+        glMinorVersion = 0;
+      }
+    }
+    else
+    {
+      this->GetState()->vtkglGetIntegerv(GL_MINOR_VERSION, &glMinorVersion);
+    }
   }
 
   major = glMajorVersion;
@@ -921,22 +974,32 @@ void vtkOpenGLRenderWindow::OpenGLInitContext()
     }
     int major = 0;
     int minor = 0;
+    // GL_MAJOR_VERSION/GL_MINOR_VERSION are only available in GL 3.0+
     glGetIntegerv(GL_MAJOR_VERSION, &major);
-    glGetIntegerv(GL_MINOR_VERSION, &minor);
-    // Require at least OpenGL 3.2
+    if (glGetError() != GL_NO_ERROR || major == 0)
+    {
+      // Fall back to parsing GL_VERSION string for GL 2.x
+      if (!vtkParseOpenGLVersionString(major, minor))
+      {
+        major = 2;
+        minor = 0;
+      }
+    }
+    else
+    {
+      glGetIntegerv(GL_MINOR_VERSION, &minor);
+    }
+    // Warn if below 3.2, but allow 2.0+ to proceed with limited functionality
     if (major < 3 || (major == 3 && minor < 2))
     {
-      vtkWarningMacro(<< "Unable to find a valid OpenGL 3.2 or later implementation. "
-                      << "(" << major << "." << minor
-                      << " found). "
-                         "Please update your video card driver to the latest version. "
-                         "If you are using Mesa please make sure you have version 11.2 or "
-                         "later and make sure your driver in Mesa supports OpenGL 3.2 such "
-                         "as llvmpipe or openswr. If you are on windows and using Microsoft "
-                         "remote desktop note that it only supports OpenGL 3.2 with nvidia "
-                         "quadro cards. You can use other remoting software such as nomachine "
-                         "to avoid this issue.");
-      return;
+      if (major < 2)
+      {
+        vtkWarningMacro(<< "Unable to find a valid OpenGL 2.0 or later implementation. "
+                        << "(" << major << "." << minor << " found).");
+        return;
+      }
+      vtkWarningMacro(<< "OpenGL " << major << "." << minor << " found, but 3.2 or later "
+                      << "is recommended. Some features may not work correctly.");
     }
 #else // gles
     this->Initialized = true;
@@ -1086,6 +1149,23 @@ int vtkOpenGLRenderWindow::GetColorBufferSizes(int* rgba)
   if (this->Initialized)
   {
     this->MakeCurrent();
+
+    // For OpenGL 2.x (legacy), use the old GL_RED_BITS etc. queries
+    // glGetFramebufferAttachmentParameteriv is OpenGL 3.0+ and may not be available
+    if (glGetFramebufferAttachmentParameteriv == nullptr)
+    {
+      // Legacy OpenGL 2.x path using deprecated but functional queries
+      glGetIntegerv(GL_RED_BITS, &size);
+      rgba[0] = static_cast<int>(size);
+      glGetIntegerv(GL_GREEN_BITS, &size);
+      rgba[1] = static_cast<int>(size);
+      glGetIntegerv(GL_BLUE_BITS, &size);
+      rgba[2] = static_cast<int>(size);
+      glGetIntegerv(GL_ALPHA_BITS, &size);
+      rgba[3] = static_cast<int>(size);
+      return rgba[0] + rgba[1] + rgba[2] + rgba[3];
+    }
+
     GLint attachment = GL_BACK_LEFT;
 #ifdef GL_DRAW_BUFFER
     glGetIntegerv(GL_DRAW_BUFFER, &attachment);
-- 
