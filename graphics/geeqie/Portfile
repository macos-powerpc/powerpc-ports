# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           active_variants 1.1
PortGroup           github 1.0
PortGroup           legacysupport 1.1
PortGroup           meson 1.0

# strndup
legacysupport.newest_darwin_requires_legacy 10

github.setup        BestImageViewer geeqie 2.9 v
revision            1
categories          graphics x11
maintainers         nomaintainer
license             GPL-2+
# only used at build
license_noconflict  graphviz openssl11

description         Image viewer and organiser
long_description    Geeqie is a lightweight Gtk+-based image viewer and browser. \
                    Provides slideshow function and supports MANY image formats.

homepage            https://www.geeqie.org
use_xz              yes
checksums           rmd160  0cf5962471fb3d6127a1a3539cc6ecedf99ea8b3 \
                    sha256  5f0214778112da6daf3736a6ea04c10b093ea339dcc54676435a097ef8dfcd2d \
                    size    1920800
github.tarball_from releases

# Do not override linker flags with Linux-specific one, it breaks legacysupport linking.
patchfiles          patch-meson.build.diff

post-patch {
    reinplace "s|awk -W posix|gawk -W posix|g" ${worksrcpath}/build-aux/translators.sh
}

depends_build-append \
                    port:gawk \
                    path:bin/pkg-config:pkgconfig

depends_lib-append  port:cfitsio \
                    port:djvulibre \
                    port:exiv2 \
                    port:ffmpegthumbnailer \
                    path:lib/pkgconfig/gtk+-3.0.pc:gtk3 \
                    port:lcms \
                    port:libarchive \
                    port:libheif \
                    path:include/turbojpeg.h:libjpeg-turbo \
                    port:libjxl \
                    port:libraw \
                    port:openexr \
                    port:openjpeg \
                    path:lib/pkgconfig/poppler.pc:poppler \
                    port:tiff \
                    port:webp

depends_run         port:desktop-file-utils

# dependencies needed by plugins (not checked by configure) -
depends_run-append  port:exiftool \
                    port:exiftran \
                    port:gphoto2 \
                    port:ImageMagick

# geeqie(23119,0x26fc408) malloc: *** error for object 0x246f700: Non-aligned pointer being freed (2)
legacysupport.redirect_bins geeqie

compiler.cxx_standard   2017

configure.args      -Ddoxygen=disabled \
                    -Dgtk4=disabled \
                    -Dlua=disabled \
                    -Dpandoc=disabled \
                    -Dunit_tests=disabled \
                    -Dyelp-build=disabled

variant docs description "Build documentation" {
     depends_build-append   path:bin/doxygen:doxygen
     configure.args-replace -Ddoxygen=disabled -Ddoxygen=enabled
}

variant quartz conflicts x11 {
    require_active_variants path:lib/pkgconfig/gtk+-3.0.pc:gtk3 quartz x11

    # meson.build looks for clutter-gtk and libchamplain unless gps-map is disabled
    # if clutter-gtk and libchamplain are found, the quartz version of the port builds
    # against them but crashes on launch with "unsupported backend"
    configure.args-append   -Dgps-map=disabled
}

variant x11 conflicts quartz {
    require_active_variants path:lib/pkgconfig/gtk+-3.0.pc:gtk3 x11 quartz
    require_active_variants path:lib/pkgconfig/gtk4.0.pc:gtk4 x11 quartz

    notes "
        GTK-based app should be launched from the terminal.
    "
}

# This is currently the only working variant.
variant gtk3 conflicts gtk4 description "Build with GTK3" {
    depends_lib-append      port:clutter-gtk \
                            port:gspell \
                            port:libchamplain
    depends_run-append      port:adwaita-icon-theme \
                            port:zenity
}

# FIXME: broken at the moment: https://github.com/BestImageViewer/geeqie/issues/2464
# compat.h:77:53: error: 'GtkCallback' has not been declared; did you mean 'GCallback'?
# compat.h:80:81: error: 'GtkShadowType' has not been declared; did you mean 'GtkArrowType'?
# compat.h:84:52: error: 'GtkWindowPosition' has not been declared
# layout-util.h:86:6: error: variable or field 'layout_menu_close_cb' declared void
# layout-util.h:86:27: error: 'GtkAction' was not declared in this scope; did you mean 'GAction'?
# view-file-icon.cc:330:49: error: 'GTK_WINDOW_POPUP' was not declared in this scope; did you mean 'GTK_WINDOW_GROUP'?
variant gtk4 conflicts gtk3 description "Build with GTK4" {
    depends_lib-replace     path:lib/pkgconfig/gtk+-3.0.pc:gtk3 \
                            path:lib/pkgconfig/gtk4.pc:gtk4
    configure.args-replace  -Dgtk4=disabled -Dgtk4=enabled
    # Avoid gtk3-relying ports:
    configure.args-append   -Dgps-map=disabled -Dspell=disabled
}

if {![variant_isset quartz]} {
    default_variants-append +x11
}

if {![variant_isset gtk4]} {
    default_variants-append +gtk3
}

post-activate {
    system "${prefix}/bin/update-desktop-database ${prefix}/share/applications"
}
