+static BOOL
+IS_SNOW_LEOPARD_OR_LATER()
+{
+#if FORCE_OLD_API
+    return NO;
+#else
+    return floor(NSAppKitVersionNumber) > NSAppKitVersionNumber10_5;
+#endif
+}
