+static void
+Cocoa_ReleaseDisplayMode(_THIS, const void *moderef)
+{
+    if (IS_SNOW_LEOPARD_OR_LATER()) {
+        CGDisplayModeRelease((CGDisplayModeRef) moderef);  /* NULL is ok */
+    }
+}
