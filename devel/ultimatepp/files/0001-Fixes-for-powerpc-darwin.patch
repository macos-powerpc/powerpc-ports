@@ -454,13 +463,20 @@ void JsonizeBySerialize(JsonIO& jio, T& x)
 	if(jio.IsStoring())
 	   h = HexString(StoreAsString(x));
 	jio("data", h);
-	if(jio.IsLoading())
+	if(jio.IsLoading()) {
+#if defined(__OBJC__) && defined(__GNUC__) && !defined(__clang__)
+		// Workaround for GCC ICE in objc_eh_runtime_type when compiling Objective-C++
+		// with C++ exception handling in templates (GCC bug with ObjC ABI 1)
+		LoadFromString(x, ScanHexString(h));
+#else
 		try {
