 {
+#if defined(__OBJC__) && defined(__GNUC__) && !defined(__clang__)
+	// Workaround for GCC ICE in objc_eh_runtime_type when compiling Objective-C++
+	Value jv = ParseJSON(json);
+	if(jv.IsError())
+		return false;
+	LoadFromJsonValue(var, jv);
+	return true;
+#else
 	try {
 		Value jv = ParseJSON(json);
 		if(jv.IsError())
