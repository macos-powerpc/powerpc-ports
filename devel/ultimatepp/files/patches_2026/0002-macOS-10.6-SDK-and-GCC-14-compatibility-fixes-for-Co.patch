diff --git a/uppsrc/CtrlLib/Cocoa.mm b/uppsrc/CtrlLib/Cocoa.mm
index ae9f3ed76..95ba1b980 100644
--- a/uppsrc/CtrlLib/Cocoa.mm
+++ b/uppsrc/CtrlLib/Cocoa.mm
@@ -41,15 +41,25 @@ bool FileSelNative::Execute0(int open, const char *title)
 		}
 		if([panel runModal] == NSModalResponseOK) {
 			NSArray* urls = [panel URLs];
-			for(int i = 0; i < urls.count; i++)
-				path.Add([[urls objectAtIndex:i] fileSystemRepresentation]);
+			// Use traditional loop instead of for-in (GCC compatibility)
+			// Use [url path] then fileSystemRepresentation (NSURL method returns const char*)
+			for(NSUInteger i = 0; i < [urls count]; i++) {
+				NSURL *url = [urls objectAtIndex:i];
+				const char *fs = [[url path] fileSystemRepresentation];
+				if(fs)
+					path.Add(fs);
+			}
 		}
 	}
 	else {
 		NSSavePanel *panel = [NSSavePanel savePanel];
 		[panel setMessage:(NSString *)~mmtitle];
-		if([panel runModal] == NSModalResponseOK)
-			path.Add([[panel URL] fileSystemRepresentation]);
+		if([panel runModal] == NSModalResponseOK) {
+			NSURL *url = [panel URL];
+			const char *fs = [[url path] fileSystemRepresentation];
+			if(fs)
+				path.Add(fs);
+		}
 	}
 	return path.GetCount();
 }
