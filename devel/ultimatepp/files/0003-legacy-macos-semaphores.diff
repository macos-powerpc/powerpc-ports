diff --git a/uppsrc/Core/Mt.cpp b/uppsrc/Core/Mt.cpp
index 33b5f3d41..70a1dfb51 100644
--- a/uppsrc/Core/Mt.cpp
+++ b/uppsrc/Core/Mt.cpp
@@ -2,6 +2,11 @@
 
 #ifdef PLATFORM_OSX
 #include <sys/time.h>
+  #if !defined(MAC_OS_X_VERSION_MIN_REQUIRED) || MAC_OS_X_VERSION_MIN_REQUIRED >= 1060
+#include <dispatch/dispatch.h>  // For dispatch semaphores (10.6+)
+  #else
+#include <mach/mach.h>          // For Mach semaphores (10.5 and earlier)
+  #endif
 #endif
 
 namespace Upp {
@@ -716,7 +721,9 @@ bool ConditionVariable::Wait(Mutex& m, int timeout_ms)
 	return pthread_cond_timedwait(cv, m.mutex, &until) == 0;
 }
 
-#ifdef PLATFORM_OSX
+#if defined(PLATFORM_OSX) && (!defined(MAC_OS_X_VERSION_MIN_REQUIRED) || MAC_OS_X_VERSION_MIN_REQUIRED >= 1060)
+
+// macOS 10.6+ (Snow Leopard and later) - libdispatch semaphores
 
 void Semaphore::Release()
 {
@@ -739,6 +746,39 @@ Semaphore::~Semaphore()
 	dispatch_release(sem);
 }
 
+#elif defined(PLATFORM_OSX)
+
+// macOS 10.5 and earlier (Leopard) - Mach semaphores
+
+void Semaphore::Release()
+{
+	semaphore_signal(sem);
+}
+
+bool Semaphore::Wait(int timeout_ms)
+{
+	if(timeout_ms < 0) {
+		return semaphore_wait(sem) == KERN_SUCCESS;
+	}
+
+	// Convert milliseconds to mach_timespec_t
+	mach_timespec_t wait_time;
+	wait_time.tv_sec = timeout_ms / 1000;
+	wait_time.tv_nsec = (timeout_ms % 1000) * 1000000;
+
+	return semaphore_timedwait(sem, wait_time) == KERN_SUCCESS;
+}
+
+Semaphore::Semaphore()
+{
+	semaphore_create(mach_task_self(), &sem, SYNC_POLICY_FIFO, 0);
+}
+
+Semaphore::~Semaphore()
+{
+	semaphore_destroy(mach_task_self(), sem);
+}
+
 #else
 
 void Semaphore::Release()
