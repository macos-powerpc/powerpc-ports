################################################################################
# Ultimate++ 2025.1.1 - Cocoa macOS 10.6 Complete Fixes (v9-COMPLETE-FINAL)
################################################################################
#
# Files Modified (8 total):
#   Core (2 files):
#   1. JSON.h - Fix template try-catch blocks (2 templates, ICE fix!)
#   2. Xmlize.h - Fix template try-catch blocks (2 templates, ICE fix!)
#
#   CtrlCore (5 files):
#   3. CocoClip.mm - Lambda inline + missing ~ operator fix
#   4. CocoApp.mm - ObjC method call parsing fixes (5 functions, 6 call sites)
#   5. CocoWin.mm - ObjC method call + property access parsing fix
#   6. CocoImage.mm - Forward declarations for 10.6 SDK
#   7. CocoProc.mm - Protocol fixes + forward declarations
#
#   CtrlLib (1 file):
#   8. ChCocoMM.mm - Lambda wrapper removal + forward declarations
#
# COMPREHENSIVE FIXES - Three Types of GCC 14 PowerPC Issues:
#
#   Issue #1: try-catch ICE in objc_eh_runtime_type
#   Issue #2: Lambda Bus error in GIMPLE modref pass
#   Issue #3: ObjC method call parsing + type conversions in C++ expressions
#
# Issue #1: Template try-catch ICE - 4 templates fixed
# Issue #2: Lambda function ICE - 2 lambdas removed
# Issue #3: ObjC parsing + types - 6 call sites fixed
#
# ObjC Method Call Parsing + Type Conversion Fixes:
#
# Problem: GCC confused by nested ObjC calls in C++ expressions + NSRect/CGRect
#          are distinct types on macOS 10.6
#
# CocoApp.mm - 5 functions, 6 call sites:
#   1. Ctrl::GetWorkArea() - NSRect → CGRect conversion
#   2. Ctrl::GetVirtualScreenArea() - NSRect → CGRect conversion
#   3. Ctrl::GetScreenArea(Point pt) - NSRect → CGRect conversion
#   4. Ctrl::GetPrimaryScreenArea() - NSRect → CGRect conversion
#   5. MMCtrl::SyncRect() - Deeply nested ObjC calls broken into steps
#
# CocoWin.mm - 1 function:
#   6. MMFrameSize() - NSSize → CGSize manual conversion
#
# Pattern Applied:
#   Before:
#     rc.Add(MakeScreenRect(screen, [screen visibleFrame]));
#     view->ctrl->SetWndRect(MakeScreenRect([win screen], 
#                                            [win contentRectForFrameRect:[win frame]]));
#
#   After:
#     NSRect nsframe = [screen visibleFrame];
#     rc.Add(MakeScreenRect(screen, NSRectToCGRect(nsframe)));
#
#     NSScreen *screen = [win screen];
#     NSRect winFrame = [win frame];
#     NSRect contentRect = [win contentRectForFrameRect:winFrame];
#     view->ctrl->SetWndRect(MakeScreenRect(screen, NSRectToCGRect(contentRect)));
#
# Apply:
#   patch -p1 < patch-cocoa2-10.6-complete.diff
#   patch -p1 < patch-cocoa2-additional-10.6-fixes-v9-COMPLETE-FINAL.diff
#   patch -p1 < patch-bmp-endian-fix.diff
#
# Expected Result:
#   ✓ No GCC ICE errors
#   ✓ No type conversion errors
#   ✓ No parsing errors
#   ✓ All .mm files compile cleanly
#
################################################################################

