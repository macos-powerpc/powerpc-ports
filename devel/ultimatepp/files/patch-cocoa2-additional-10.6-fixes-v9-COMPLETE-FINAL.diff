@@ -213,13 +213,21 @@ void XmlizeBySerialize(XmlIO& xio, T& x)
 	if(xio.IsStoring())
 		h = HexString(StoreAsString(x));
 	xio.Attr("data", h);
-	if(xio.IsLoading())
+	if(xio.IsLoading()) {
+#if defined(__OBJC__) && defined(__cplusplus)
+		// Objective-C++ mode: Avoid try-catch to prevent GCC ICE in objc_eh_runtime_type
+		// This is a workaround for GCC 14 on macOS 10.6 PowerPC
+		LoadFromString(x, ScanHexString(h));
+#else
+		// Regular C++ mode: Use exception handling
 		try {
 			LoadFromString(x, ScanHexString(h));
 		}
 		catch(LoadingError) {
 			throw XmlError("xmlize by serialize error");
 		}
+#endif
+	}
 }
 
 void  StoreJsonValue(XmlIO& xio, const Value& v);
@@ -231,12 +239,18 @@ void XmlizeByJsonize(XmlIO& xio, T& x)
 	if(xio.IsStoring())
 		StoreJsonValue(xio, StoreAsJsonValue(x));
 	else {
+#if defined(__OBJC__) && defined(__cplusplus)
+		// Objective-C++ mode: Avoid try-catch to prevent GCC ICE in objc_eh_runtime_type
+		LoadFromJsonValue(x, LoadJsonValue(xio.Node()));
+#else
+		// Regular C++ mode: Use exception handling
 		try {
 			LoadFromJsonValue(x, LoadJsonValue(xio.Node()));
 		}
 		catch(JsonizeError e) {
 			throw XmlError("xmlize by jsonize error: " + e);
 		}
+#endif
 	}
 }
 
