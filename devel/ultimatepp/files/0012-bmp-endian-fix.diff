################################################################################
# Ultimate++ 2025.1.1 - BMP Plugin Big-Endian Fix
################################################################################
#
# File Modified:
#   plugin/bmp/bmphdr.h - Fix endian swap function calls
#
# Problem:
#   Code was calling UPP::SwapEndian() which doesn't exist.
#   Should use Upp::SwapEndian16/32/64 with correct namespace case.
#
# Fixes:
#   1. Changed UPP:: to Upp:: (correct namespace case)
#   2. Changed SwapEndian() to SwapEndian16() for word (16-bit) fields
#   3. Changed SwapEndian() to SwapEndian32() for dword/int32 (32-bit) fields
#
# Field Type Mapping:
#   BMP_FILEHEADER:
#     - bfType (word) → SwapEndian16
#     - bfSize (dword) → SwapEndian32
#     - bfOffBits (dword) → SwapEndian32
#
#   BMP_INFOHEADER:
#     - biSize (dword) → SwapEndian32
#     - biWidth (int32) → SwapEndian32
#     - biHeight (int32) → SwapEndian32
#     - biPlanes (word) → SwapEndian16
#     - biBitCount (word) → SwapEndian16
#     - biCompression (dword) → SwapEndian32
#     - biSizeImage (dword) → SwapEndian32
#     - biXPelsPerMeter (int32) → SwapEndian32
#     - biYPelsPerMeter (int32) → SwapEndian32
#     - biClrUsed (dword) → SwapEndian32
#     - biClrImportant (dword) → SwapEndian32
#
# Apply:
#   patch -p1 < patch-bmp-endian-fix.diff
#
################################################################################

diff --git a/uppsrc/plugin/bmp/bmphdr.h b/uppsrc/plugin/bmp/bmphdr.h
index 1a4cfaef6..19cfc8279 100644
--- a/uppsrc/plugin/bmp/bmphdr.h
+++ b/uppsrc/plugin/bmp/bmphdr.h
@@ -15,9 +15,9 @@ struct BMP_FILEHEADER {
 	void    SwapEndian()
 	{
 #ifdef CPU_BIG_ENDIAN
-		bfType = UPP::SwapEndian(bfType);
-		bfSize = UPP::SwapEndian(bfSize);
-		bfOffBits = UPP::SwapEndian(bfOffBits);
+		bfType = Upp::SwapEndian16(bfType);
+		bfSize = Upp::SwapEndian32(bfSize);
+		bfOffBits = Upp::SwapEndian32(bfOffBits);
 #endif
 	}
 }
@@ -43,17 +43,17 @@ struct BMP_INFOHEADER
 	void    SwapEndian()
 	{
 #ifdef CPU_BIG_ENDIAN
-		biSize = UPP::SwapEndian(biSize);
-		biWidth = UPP::SwapEndian(biWidth);
-		biHeight = UPP::SwapEndian(biHeight);
-		biPlanes = UPP::SwapEndian(biPlanes);
-		biBitCount = UPP::SwapEndian(biBitCount);
-		biCompression = UPP::SwapEndian(biCompression);
-		biSizeImage = UPP::SwapEndian(biSizeImage);
-		biXPelsPerMeter = UPP::SwapEndian(biXPelsPerMeter);
-		biYPelsPerMeter = UPP::SwapEndian(biYPelsPerMeter);
-		biClrUsed = UPP::SwapEndian(biClrUsed);
-		biClrImportant = UPP::SwapEndian(biClrImportant);
+		biSize = Upp::SwapEndian32(biSize);
+		biWidth = Upp::SwapEndian32(biWidth);
+		biHeight = Upp::SwapEndian32(biHeight);
+		biPlanes = Upp::SwapEndian16(biPlanes);
+		biBitCount = Upp::SwapEndian16(biBitCount);
+		biCompression = Upp::SwapEndian32(biCompression);
+		biSizeImage = Upp::SwapEndian32(biSizeImage);
+		biXPelsPerMeter = Upp::SwapEndian32(biXPelsPerMeter);
+		biYPelsPerMeter = Upp::SwapEndian32(biYPelsPerMeter);
+		biClrUsed = Upp::SwapEndian32(biClrUsed);
+		biClrImportant = Upp::SwapEndian32(biClrImportant);
 #endif
 	}
 }
