    depends_lib-append \
                    port:cpp-httplib
    configure.args-replace \
                    -DBUILD_PLAYGROUND=OFF -DBUILD_PLAYGROUND=ON \
                    -DUSE_SYSTEM_HTTPLIB=OFF -DUSE_SYSTEM_HTTPLIB=ON
    configure.args-append \
                    -DUSE_SYSTEM_HTTPLIB=ON
