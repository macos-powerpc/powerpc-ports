From c0ca541d0fd1477e051a1cdb4b4978a0dc573fe8 Mon Sep 17 00:00:00 2001
From: Sergey Fedorov <vital.had@gmail.com>
Date: Mon, 2 Mar 2026 02:15:20 +0800
Subject: [PATCH 1/7] CMakeLists.txt: fix finding threads

---
 CMakeLists.txt | 7 ++-----
 1 file changed, 2 insertions(+), 5 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index d84e692..736717d 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -8,11 +8,8 @@ set(FREEOCL_VERSION_STRING	"${FREEOCL_VERSION_HI}.${FREEOCL_VERSION_LO}.${FREEOC
 set(FREEOCL_VENDOR	"FreeOCL developers")
 set(FREEOCL_MAINTAINER_CONTACT "FreeOCL developers <zuzuf86@gmail.com>")
 
-set(CMAKE_THREAD_PREFER_PTHREAD pthread)
-include(FindThreads)
-if(NOT CMAKE_THREAD_LIBS_INIT AND NOT CMAKE_HAVE_THREADS_LIBRARY)
-	message(FATAL_ERROR "thread library not found")
-endif(NOT CMAKE_THREAD_LIBS_INIT AND NOT CMAKE_HAVE_THREADS_LIBRARY)
+set(THREADS_PREFER_PTHREAD_FLAG TRUE)
+find_package(Threads REQUIRED)
 
 # Default is debug build
 if(NOT CMAKE_BUILD_TYPE)
