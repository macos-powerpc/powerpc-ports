From 528d2b845363ee90bb937c9bd2ba04941f37dd0c Mon Sep 17 00:00:00 2001
From: Sergey Fedorov <barracuda@macos-powerpc.org>
Date: Sat, 25 Apr 2026 21:03:38 +0800
Subject: [PATCH] detect_compiler_arch.h: fix PowerPC macros

Closes: https://github.com/google/highway/issues/3010
---
 hwy/detect_compiler_arch.h | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git hwy/detect_compiler_arch.h hwy/detect_compiler_arch.h
index 792ec5c7..9c953f4c 100644
--- hwy/detect_compiler_arch.h
+++ hwy/detect_compiler_arch.h
@@ -310,13 +310,13 @@
 #define HWY_ARCH_X86 0
 #endif
 
-#if defined(__powerpc64__) || defined(_M_PPC) || defined(__powerpc__)
+#if defined(__powerpc64__) || defined(_M_PPC) || defined(__powerpc__) || defined(__POWERPC__)
 #define HWY_ARCH_PPC 1
 #else
 #define HWY_ARCH_PPC 0
 #endif
 
-#if defined(__powerpc64__) || (HWY_ARCH_PPC && defined(__64BIT__))
+#if defined(__powerpc64__) || (HWY_ARCH_PPC && defined(__64BIT__)) || defined(__ppc64__)
 #define HWY_ARCH_PPC_64 1
 #else
 #define HWY_ARCH_PPC_64 0
