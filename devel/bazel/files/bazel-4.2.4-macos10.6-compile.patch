From: OpenVDB Contributors
Subject: [PATCH] Adjust Bazel 4.2.4 bootstrap for macOS 10.6, GCC, and OpenJDK

This patch modifies compile.sh and buildenv.sh to:
1. Require JAVA_HOME to be explicitly set (no Apple java_home fallback)
2. Allow using GCC instead of clang for xcode-locator
3. Support macOS 10.6 deployment target
4. Use manual reference counting instead of ARC

This is needed for PowerPC support where only OpenJDK is available,
not Apple's x86_64-only Java.

---
 scripts/bootstrap/buildenv.sh | 10 +++-------
 scripts/bootstrap/compile.sh  | 18 ++++++++++++++++--
 2 files changed, 19 insertions(+), 9 deletions(-)

diff --git a/scripts/bootstrap/buildenv.sh b/scripts/bootstrap/buildenv.sh
index abcdef1..1234567 100644
--- a/scripts/bootstrap/buildenv.sh
+++ b/scripts/bootstrap/buildenv.sh
@@ -97,13 +97,9 @@ openbsd)
   JAVA_HOME="${JAVA_HOME:-/usr/local/jdk-1.8.0}"
   ;;

 darwin)
-  if [[ -z "$JAVA_HOME" ]]; then
-    JAVA_HOME="$(/usr/libexec/java_home -v ${JAVA_VERSION}+ 2> /dev/null)" \
-      || fail "Could not find JAVA_HOME, please ensure a JDK (version ${JAVA_VERSION}+) is installed."
-  fi
+  # Require JAVA_HOME to be set explicitly for OpenJDK support on PPC
+  # Apple's java_home only finds Apple Java which is x86_64-only
+  [[ -n "$JAVA_HOME" ]] || fail "JAVA_HOME must be set to your OpenJDK installation path."
+  [[ -d "$JAVA_HOME" ]] || fail "JAVA_HOME ($JAVA_HOME) does not exist."
   ;;

 msys*|mingw*|cygwin*)
diff --git a/scripts/bootstrap/compile.sh b/scripts/bootstrap/compile.sh
index abcdef2..1234568 100644
--- a/scripts/bootstrap/compile.sh
+++ b/scripts/bootstrap/compile.sh
@@ -389,8 +389,22 @@ build_jni "${ARCHIVE_DIR}"
 cp $OUTPUT_DIR/libblaze.jar ${ARCHIVE_DIR}

 # TODO(b/28965185): Remove when xcode-locator is no longer required in embedded_binaries.
 log "Compiling xcode-locator..."
 if [[ $PLATFORM == "darwin" ]]; then
-  run /usr/bin/xcrun --sdk macosx clang -mmacosx-version-min=10.13 -fobjc-arc -framework CoreServices -framework Foundation -o ${ARCHIVE_DIR}/xcode-locator tools/osx/xcode_locator.m
+  # Allow overriding the compiler via XCODE_LOCATOR_CC
+  # Default to CC if set, otherwise try to find a usable compiler
+  XCODE_LOCATOR_CC="${XCODE_LOCATOR_CC:-${CC:-}}"
+  if [[ -z "$XCODE_LOCATOR_CC" ]]; then
+    if command -v gcc >/dev/null 2>&1; then
+      XCODE_LOCATOR_CC="gcc"
+    elif [[ -x /usr/bin/xcrun ]]; then
+      XCODE_LOCATOR_CC="/usr/bin/xcrun --sdk macosx clang"
+    else
+      fail "No compiler found for xcode-locator. Set CC or XCODE_LOCATOR_CC."
+    fi
+  fi
+
+  # Allow overriding deployment target and ARC flag
+  MACOSX_VERSION_MIN="${MACOSX_DEPLOYMENT_TARGET:-10.6}"
+  XCODE_LOCATOR_ARC="${XCODE_LOCATOR_ARC:--fno-objc-arc}"
+
+  run $XCODE_LOCATOR_CC -mmacosx-version-min=${MACOSX_VERSION_MIN} ${XCODE_LOCATOR_ARC} -framework CoreServices -framework Foundation -o ${ARCHIVE_DIR}/xcode-locator tools/osx/xcode_locator.m
 else
   cp tools/osx/xcode_locator_stub.sh ${ARCHIVE_DIR}/xcode-locator
 fi
