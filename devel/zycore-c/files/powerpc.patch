From 49171c8f53a893eedb67586ece17f9c28d12e5d9 Mon Sep 17 00:00:00 2001
From: Sergey Fedorov <vital.had@gmail.com>
Date: Thu, 4 Jun 2026 14:21:08 +0800
Subject: [PATCH] Defines.h: add missing powerpc macros

See: https://github.com/radareorg/radare2/issues/26030
---
 include/Zycore/Defines.h | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/include/Zycore/Defines.h b/include/Zycore/Defines.h
index 8ad8944..c24179d 100644
--- include/Zycore/Defines.h
+++ include/Zycore/Defines.h
@@ -148,9 +148,9 @@
 #   define ZYAN_WASM
 #elif defined(__loongarch__)
 #   define ZYAN_LOONGARCH
-#elif defined(__powerpc64__)
+#elif defined(__powerpc64__) || defined(__ppc64__)
 #   define ZYAN_PPC64
-#elif defined(__powerpc__)
+#elif defined(__powerpc__) || defined(__ppc__)
 #   define ZYAN_PPC
 #elif defined(__riscv) && __riscv_xlen == 64
 #   define ZYAN_RISCV64
