# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           fuse 1.0
PortGroup           github 1.0

github.setup        libyal libfsapfs 20240429
revision            0
categories          fuse
license             LGPL-3+
maintainers         {@barracuda156 macos-powerpc.org:barracuda} openmaintainer
description         Library and tools to access the Apple File System (APFS)
long_description    {*}${description}.
distname            ${name}-experimental-${version}
checksums           rmd160  cfbaf0de7c46dd0ec8e73f06e9dba3fab5e375ec \
                    sha256  665f70705e69ce90c87e0f9c185d47002e242b79b0a37ae52751cdfa8363a538 \
                    size    2171864
github.tarball_from releases

worksrcdir          ${name}-${version}

set py_ver          3.14
set py_ver_nodot    [string map {. {}} ${py_ver}]

depends_build-append \
                    port:gettext \
                    path:bin/pkg-config:pkgconfig \
                    port:py${py_ver_nodot}-setuptools

depends_lib-append  port:gettext-runtime \
                    port:libcaes \
                    port:libcdata \
                    port:libcerror \
                    port:libcfile \
                    port:libclocale \
                    port:libcnotify \
                    port:libcpath \
                    port:libcsplit \
                    port:libcthreads \
                    port:libhmac \
                    port:libiconv \
                    port:libuna \
                    port:python${py_ver_nodot} \
                    port:zlib

configure.python    ${prefix}/bin/python${py_ver}
set python_root     ${frameworks_dir}/Python.framework/Versions/${py_ver}

configure.env-append \
                    PYTHON_CONFIG=${configure.python}-config

# TODO: FreeBSD disable openssl in these ports (and MacPorts did not use it), but why?
# https://github.com/freebsd/freebsd-ports/blob/152bd88e17be1235de6f646cd8165b9b186b6860/filesystems/libfsapfs/Makefile#L20
configure.args-append \
                    --enable-python \
                    --with-libiconv-prefix=${prefix} \
                    --with-libintl-prefix=${prefix} \
                    --with-openssl=no \
                    --with-pyprefix=${python_root}
