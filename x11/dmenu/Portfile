PortSystem          1.0
PortGroup           legacysupport 1.1
PortGroup           makefile 1.0

# getline, strnlen
legacysupport.newest_darwin_requires_legacy 10

name                dmenu
version             5.4
revision            0
categories          x11
license             MIT
maintainers         nomaintainer
description         ${name} is a dynamic menu for X, originally designed for dwm. \
                    It manages large numbers of user-defined menu items efficiently.
long_description    ${description}

homepage            https://tools.suckless.org/${name}
master_sites        https://dl.suckless.org/tools/

checksums           rmd160  78a95fd26041a6cfb89cc7131ba143cf2d7d83af \
                    sha256  8fbace2a0847aa80fe861066b118252dcc7b4ca0a0a8f3a93af02da8fb6cd453 \
                    size    17001

depends_build-append \
                    path:bin/pkg-config:pkgconfig

depends_lib-append  path:lib/pkgconfig/freetype2.pc:freetype \
                    port:Xft2 \
                    port:xorg-libX11 \
                    port:xorg-libXinerama

patchfiles          config.mk.patch \
                    patch-_DARWIN_C_SOURCE.diff

makefile.override   CC PREFIX

compiler.c_standard 1999

build.args          FREETYPEINC=${prefix}/include/freetype2 \
                    X11INC=${prefix}/include/X11 \
                    X11LIB=${prefix}/lib

destroot.args       ${build.args}

livecheck.type      regex
livecheck.url       ${master_sites}
livecheck.regex     ${name}-(\\d+(?:\\.\\d+)*)
