Subject: [PATCH 2/9] xquartz/xpr/x-list.h: use __attribute__ if
 __private_extern__ is not defined

---
 hw/xquartz/xpr/x-list.h | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/hw/xquartz/xpr/x-list.h b/hw/xquartz/xpr/x-list.h
index 28385fd99..cf2f1fb68 100644
--- a/hw/xquartz/xpr/x-list.h
+++ b/hw/xquartz/xpr/x-list.h
@@ -45,7 +45,11 @@ struct x_list_struct {
 #endif
 
 #ifndef X_EXTERN
+#ifdef __private_extern__
 #define X_EXTERN __private_extern__
+#else
+#define X_EXTERN __attribute__((visibility("hidden")))
+#endif
 #endif
 
 X_EXTERN void X_PFX(list_free_1) (x_list * node);
