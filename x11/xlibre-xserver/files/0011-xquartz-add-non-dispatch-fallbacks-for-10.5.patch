 hw/xquartz/X11Application.m                 | 16 +++++++++
 hw/xquartz/mach-startup/bundle-main.c       | 33 +++++++++++++++++
 hw/xquartz/meson.build                      |  2 +-
 hw/xquartz/quartzKeyboard.c                 |  5 +++
 hw/xquartz/xpr/xprEvent.c                   |  7 ++--
