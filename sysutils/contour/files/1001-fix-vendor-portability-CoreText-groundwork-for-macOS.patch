diff --git a/cmake/CheckAtomic.cmake b/cmake/CheckAtomic.cmake
new file mode 100644
index 00000000..6f1cf21f
--- /dev/null
+++ b/cmake/CheckAtomic.cmake
@@ -0,0 +1,45 @@
+# Determines whether std::atomic operations (notably 64-bit ones on 32-bit targets such as
+# PowerPC) require linking against libatomic, and exposes the result as an INTERFACE target
+# `contour::atomic` that callers can link unconditionally. On targets where the compiler lowers
+# every atomic to a lock-free intrinsic (most 64-bit hosts) the target links nothing.
+#
+# Adapted from the well-established CheckAtomic idiom used by LLVM and others: probe by trying
+# to compile-and-link a program that exercises a 64-bit atomic, first with no extra library and
+# then with -latomic.
+
+include_guard(GLOBAL)
+include(CheckCXXSourceCompiles)
+
+set(_contour_atomic_test_source "
+#include <atomic>
+#include <cstdint>
+std::atomic<std::uint64_t> x(0);
+int main()
+{
+    std::uint64_t v = x.load(std::memory_order_relaxed);
+    x.store(v + 1, std::memory_order_relaxed);
+    x.fetch_add(1, std::memory_order_relaxed);
+    x.exchange(v, std::memory_order_relaxed);
+    return static_cast<int>(x.load(std::memory_order_relaxed));
+}
+")
+
+check_cxx_source_compiles("${_contour_atomic_test_source}" CONTOUR_ATOMIC_WITHOUT_LIB)
+
+if(NOT CONTOUR_ATOMIC_WITHOUT_LIB)
+    set(CMAKE_REQUIRED_LIBRARIES_SAVED "${CMAKE_REQUIRED_LIBRARIES}")
+    list(APPEND CMAKE_REQUIRED_LIBRARIES atomic)
+    check_cxx_source_compiles("${_contour_atomic_test_source}" CONTOUR_ATOMIC_WITH_LIBATOMIC)
+    set(CMAKE_REQUIRED_LIBRARIES "${CMAKE_REQUIRED_LIBRARIES_SAVED}")
+    if(NOT CONTOUR_ATOMIC_WITH_LIBATOMIC)
+        message(FATAL_ERROR "std::atomic requires a library this toolchain does not provide "
+                            "(neither builtin intrinsics nor libatomic satisfied the probe).")
+    endif()
+endif()
+
+if(NOT TARGET contour::atomic)
+    add_library(contour::atomic INTERFACE IMPORTED GLOBAL)
+    if(NOT CONTOUR_ATOMIC_WITHOUT_LIB)
+        set_target_properties(contour::atomic PROPERTIES INTERFACE_LINK_LIBRARIES atomic)
+    endif()
+endif()
