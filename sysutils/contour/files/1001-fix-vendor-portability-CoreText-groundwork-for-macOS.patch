index 63e57820..3a21faaa 100644
--- a/src/crispy/AlignedAllocator.h
+++ b/src/crispy/AlignedAllocator.h
@@ -2,6 +2,7 @@
 #pragma once
 
 #include <cstddef>
+#include <cstdint>
 #include <cstdlib>
 #include <limits>
 #include <new>
@@ -41,8 +42,18 @@ class aligned_allocator
 
 #ifdef _MSC_VER
         auto* ptr = static_cast<T*>(_aligned_malloc(alignedSize, Alignment));
-#else
+#elif defined(HAVE_ALIGNED_ALLOC)
         auto* ptr = static_cast<T*>(std::aligned_alloc(Alignment, alignedSize));
+#elif defined(HAVE_POSIX_MEMALIGN)
+        void* raw = nullptr;
+        if (posix_memalign(&raw, Alignment, alignedSize) != 0)
+            raw = nullptr;
+        auto* ptr = static_cast<T*>(raw);
+#else
+        // No aligned allocator available (e.g. macOS 10.5): over-allocate with plain malloc,
+        // align the returned block up, and stash the original malloc pointer in the word just
+        // before it so deallocate() can recover the exact pointer to free.
+        auto* ptr = alignedMallocFallback(alignedSize);
 #endif
         if (!ptr)
             throw std::bad_alloc();
@@ -55,8 +66,10 @@ class aligned_allocator
             return;
 #ifdef _MSC_VER
         _aligned_free(p);
-#else
+#elif defined(HAVE_ALIGNED_ALLOC) || defined(HAVE_POSIX_MEMALIGN)
         std::free(p);
+#else
+        std::free(static_cast<void**>(static_cast<void*>(p))[-1]);
 #endif
     }
 
@@ -71,6 +84,27 @@ class aligned_allocator
     {
         return false;
     }
+
+#if !defined(_MSC_VER) && !defined(HAVE_ALIGNED_ALLOC) && !defined(HAVE_POSIX_MEMALIGN)
+  private:
+    /// Aligned allocation on platforms with neither aligned_alloc nor posix_memalign.
+    ///
+    /// Over-allocates by Alignment (headroom to align up) plus one pointer (to store the
+    /// original malloc result), aligns the user block up, and writes the base pointer in the
+    /// word immediately preceding it. deallocate() reads that word back to free the exact
+    /// pointer malloc returned.
+    [[nodiscard]] static T* alignedMallocFallback(std::size_t alignedSize) noexcept
+    {
+        void* base = std::malloc(alignedSize + Alignment + sizeof(void*));
+        if (!base)
+            return nullptr;
+        auto const rawAddr = reinterpret_cast<std::uintptr_t>(base) + sizeof(void*);
+        auto const userAddr = (rawAddr + Alignment - 1) & ~(static_cast<std::uintptr_t>(Alignment) - 1);
+        auto* user = reinterpret_cast<void*>(userAddr);
+        static_cast<void**>(user)[-1] = base;
+        return static_cast<T*>(user);
+    }
+#endif
 };
 
 /// Convenience alias: std::vector with 64-byte cache-line aligned allocation.
