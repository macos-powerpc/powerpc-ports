@@ -0,0 +1,116 @@
+// SPDX-License-Identifier: Apache-2.0
+#pragma once
+
+// Thin, engine-free bridge between the AppKit Objective-C++ layer and the C++ engine.
+//
+// The contour engine headers cannot be included from an Objective-C++ (.mm) translation
+// unit: the engine uses `id` as an ordinary identifier, which collides with the `id`
+// keyword under the ObjC++ frontend. So the .mm files include ONLY this header (plus
+// AppKit/Foundation) and talk to the engine through the opaque handle and plain functions
+// below. The implementation (SessionBridge.cpp) is compiled as ordinary C++ and is the only
+// place that includes engine + session headers.
+
+#include <cstddef>
+#include <cstdint>
+
+namespace contour_macos
+{
+
+class TerminalSession; // opaque to the .mm side
+
+/// Host callbacks, invoked from the engine's parser thread. Each receives the opaque
+/// `userData` the bridge was created with (the TerminalView). Implementations must marshal
+/// any UI work onto the main thread themselves.
+struct BridgeCallbacks
+{
+    void* userData = nullptr;
+    void (*requestRedraw)(void* userData) = nullptr;
+    void (*setTitle)(void* userData, char const* utf8Title) = nullptr;
+    void (*bell)(void* userData) = nullptr;
+    void (*copyToClipboard)(void* userData, char const* utf8Data) = nullptr;
+    /// Returns a freshly malloc()'d UTF-8 C string the bridge will free(), or nullptr.
+    char* (*readClipboard)(void* userData) = nullptr;
+    void (*onClosed)(void* userData) = nullptr;
+};
+
+/// Font configuration passed across the boundary as primitives.
+struct BridgeFontConfig
+{
+    char const* family = "Menlo";
+    double sizePt = 14.0;
+    int dpiX = 96;
+    int dpiY = 96;
+};
+
+/// Creates a session sized to (widthPx, heightPx) and spawns the shell's read loop is NOT
+/// started yet — call bridge_start(). Returns nullptr on failure.
+TerminalSession* bridge_create(int widthPx,
+                               int heightPx,
+                               BridgeFontConfig const& font,
+                               BridgeCallbacks const& callbacks);
+
+void bridge_destroy(TerminalSession* session);
+
+/// Spawns the shell and starts the parser thread.
+void bridge_start(TerminalSession* session);
+
+/// Renders one frame into the internal buffer. Call on the main thread (from -drawRect:).
+void bridge_render_frame(TerminalSession* session);
+
+/// Returns a pointer to the current RGBA8, top-left-origin frame buffer, and its dimensions.
+/// The pointer is valid until the next bridge_render_frame()/bridge_resize() call.
+uint8_t const* bridge_output_buffer(TerminalSession* session, int* outWidth, int* outHeight);
+
+/// Resizes the render surface (and re-derives the page size). Call on the main thread.
+void bridge_resize(TerminalSession* session, int widthPx, int heightPx);
+
+// --- input (all coordinates in view pixels, top-left origin) ---
+
+/// Modifier bitmask matching the engine's Modifier enum: Shift=1 Alt=2 Control=4 Super=8.
+enum BridgeModifier : uint32_t
+{
+    BridgeMod_Shift = 1,
+    BridgeMod_Alt = 2,
+    BridgeMod_Control = 4,
+    BridgeMod_Super = 8,
+};
+
+/// Special (non-text) keys, matching a subset of vtbackend::Key.
+enum BridgeKey : int
+{
+    BridgeKey_None = 0,
+    BridgeKey_Up,
+    BridgeKey_Down,
+    BridgeKey_Left,
+    BridgeKey_Right,
+    BridgeKey_Home,
+    BridgeKey_End,
+    BridgeKey_PageUp,
+    BridgeKey_PageDown,
+    BridgeKey_Insert,
+    BridgeKey_Delete,
+    BridgeKey_F1,
+    BridgeKey_F2,
+    BridgeKey_F3,
+    BridgeKey_F4,
+    BridgeKey_F5,
+    BridgeKey_F6,
+    BridgeKey_F7,
+    BridgeKey_F8,
+    BridgeKey_F9,
+    BridgeKey_F10,
+    BridgeKey_F11,
+    BridgeKey_F12,
+};
+
+/// Sends a non-text key press (arrows, function keys, etc.).
+void bridge_send_key(TerminalSession* session, int bridgeKey, uint32_t modifiers);
+
+/// Sends a text codepoint (a printable character).
+void bridge_send_char(TerminalSession* session, uint32_t codepoint, uint32_t modifiers);
+
+void bridge_mouse_press(TerminalSession* session, int x, int y, uint32_t modifiers);
+void bridge_mouse_release(TerminalSession* session, int x, int y, uint32_t modifiers);
+void bridge_focus_in(TerminalSession* session);
+
+} // namespace contour_macos
