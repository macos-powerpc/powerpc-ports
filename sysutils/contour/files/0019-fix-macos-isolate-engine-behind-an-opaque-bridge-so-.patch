+// SPDX-License-Identifier: Apache-2.0
+//
+// Engine side of the AppKit bridge. Compiled as ordinary C++ (never ObjC++), so it may
+// freely include the engine headers that use `id` as an identifier.
+
+#include <contour_macos/SessionBridge.h>
+#include <contour_macos/TerminalSession.h>
+
+#include <vtbackend/InputGenerator.h>
+#include <vtbackend/Terminal.h>
+#include <vtrasterizer/FontDescriptions.h>
+
+#include <chrono>
+#include <cstdlib>
+#include <cstring>
+#include <string>
+
+namespace contour_macos
+{
+
+namespace
+{
+    vtbackend::KeyboardModifiers toKeyboardModifiers(uint32_t bits)
+    {
+        vtbackend::Modifiers mods {};
+        if (bits & BridgeMod_Shift)
+            mods.enable(vtbackend::Modifier::Shift);
+        if (bits & BridgeMod_Alt)
+            mods.enable(vtbackend::Modifier::Alt);
+        if (bits & BridgeMod_Control)
+            mods.enable(vtbackend::Modifier::Control);
+        if (bits & BridgeMod_Super)
+            mods.enable(vtbackend::Modifier::Super);
+        return vtbackend::KeyboardModifiers { mods };
+    }
+
+    bool toEngineKey(int bridgeKey, vtbackend::Key& out)
+    {
+        switch (bridgeKey)
+        {
+            case BridgeKey_Up: out = vtbackend::Key::UpArrow; return true;
+            case BridgeKey_Down: out = vtbackend::Key::DownArrow; return true;
+            case BridgeKey_Left: out = vtbackend::Key::LeftArrow; return true;
+            case BridgeKey_Right: out = vtbackend::Key::RightArrow; return true;
+            case BridgeKey_Home: out = vtbackend::Key::Home; return true;
+            case BridgeKey_End: out = vtbackend::Key::End; return true;
+            case BridgeKey_PageUp: out = vtbackend::Key::PageUp; return true;
+            case BridgeKey_PageDown: out = vtbackend::Key::PageDown; return true;
+            case BridgeKey_Insert: out = vtbackend::Key::Insert; return true;
+            case BridgeKey_Delete: out = vtbackend::Key::Delete; return true;
+            case BridgeKey_F1: out = vtbackend::Key::F1; return true;
+            case BridgeKey_F2: out = vtbackend::Key::F2; return true;
+            case BridgeKey_F3: out = vtbackend::Key::F3; return true;
+            case BridgeKey_F4: out = vtbackend::Key::F4; return true;
+            case BridgeKey_F5: out = vtbackend::Key::F5; return true;
+            case BridgeKey_F6: out = vtbackend::Key::F6; return true;
+            case BridgeKey_F7: out = vtbackend::Key::F7; return true;
+            case BridgeKey_F8: out = vtbackend::Key::F8; return true;
+            case BridgeKey_F9: out = vtbackend::Key::F9; return true;
+            case BridgeKey_F10: out = vtbackend::Key::F10; return true;
+            case BridgeKey_F11: out = vtbackend::Key::F11; return true;
+            case BridgeKey_F12: out = vtbackend::Key::F12; return true;
+            default: return false;
+        }
+    }
+} // namespace
+
+TerminalSession* bridge_create(int widthPx,
+                               int heightPx,
+                               BridgeFontConfig const& font,
+                               BridgeCallbacks const& cb)
+{
+    auto fonts = vtrasterizer::FontDescriptions {};
+    fonts.dpi = text::DPI { font.dpiX, font.dpiY };
+    fonts.size = text::font_size { font.sizePt };
+    std::string const family = font.family ? font.family : "Menlo";
+    for (text::font_description* fd: { &fonts.regular, &fonts.bold, &fonts.italic, &fonts.boldItalic })
+    {
+        fd->familyName = family;
+        fd->spacing = text::font_spacing::mono;
+    }
+    fonts.bold.weight = text::font_weight::bold;
+    fonts.italic.slant = text::font_slant::italic;
+    fonts.boldItalic.weight = text::font_weight::bold;
+    fonts.boldItalic.slant = text::font_slant::italic;
+
+    auto const surfaceSize = ImageSize { vtbackend::Width::cast_from(widthPx),
+                                         vtbackend::Height::cast_from(heightPx) };
+
+    TerminalSession::Callbacks callbacks;
+    auto const userData = cb.userData;
+    if (cb.requestRedraw)
+        callbacks.requestRedraw = [userData, fn = cb.requestRedraw]() { fn(userData); };
+    if (cb.setTitle)
+        callbacks.setTitle = [userData, fn = cb.setTitle](std::string title) { fn(userData, title.c_str()); };
+    if (cb.bell)
+        callbacks.bell = [userData, fn = cb.bell]() { fn(userData); };
+    if (cb.copyToClipboard)
+        callbacks.copyToClipboard = [userData, fn = cb.copyToClipboard](std::string data) {
+            fn(userData, data.c_str());
+        };
+    if (cb.readClipboard)
+        callbacks.readClipboard = [userData, fn = cb.readClipboard]() -> std::string {
+            char* s = fn(userData);
+            if (!s)
+                return std::string {};
+            std::string result(s);
+            std::free(s);
+            return result;
+        };
+    if (cb.onClosed)
+        callbacks.onClosed = [userData, fn = cb.onClosed]() { fn(userData); };
+
+    auto const pageSize = vtbackend::PageSize { vtbackend::LineCount(24), vtbackend::ColumnCount(80) };
+    return new TerminalSession(pageSize, std::move(fonts), surfaceSize, std::move(callbacks));
+}
+
+void bridge_destroy(TerminalSession* session)
+{
+    delete session;
+}
+
+void bridge_start(TerminalSession* session)
+{
+    session->start();
+}
+
+void bridge_render_frame(TerminalSession* session)
+{
+    session->renderFrame();
+}
+
+uint8_t const* bridge_output_buffer(TerminalSession* session, int* outWidth, int* outHeight)
+{
+    auto const& buffer = session->renderTarget().outputBuffer();
+    if (outWidth)
+        *outWidth = static_cast<int>(buffer.width());
+    if (outHeight)
+        *outHeight = static_cast<int>(buffer.height());
+    return buffer.data();
+}
+
+void bridge_resize(TerminalSession* session, int widthPx, int heightPx)
+{
+    session->resize(
+        ImageSize { vtbackend::Width::cast_from(widthPx), vtbackend::Height::cast_from(heightPx) });
+}
+
+void bridge_send_key(TerminalSession* session, int bridgeKey, uint32_t modifiers)
+{
+    vtbackend::Key key {};
+    if (!toEngineKey(bridgeKey, key))
+        return;
+    session->terminal().sendKeyEvent(key,
+                                     toKeyboardModifiers(modifiers),
+                                     vtbackend::KeyboardEventType::Press,
+                                     std::chrono::steady_clock::now());
+}
+
+void bridge_send_char(TerminalSession* session, uint32_t codepoint, uint32_t modifiers)
+{
+    session->terminal().sendCharEvent(static_cast<char32_t>(codepoint),
+                                      codepoint,
+                                      toKeyboardModifiers(modifiers),
+                                      vtbackend::KeyboardEventType::Press,
+                                      std::chrono::steady_clock::now());
+}
+
+void bridge_mouse_press(TerminalSession* session, int x, int y, uint32_t modifiers)
+{
+    session->terminal().sendMousePressEvent(toKeyboardModifiers(modifiers).chord,
+                                            vtbackend::MouseButton::Left,
+                                            vtbackend::PixelCoordinate { { x }, { y } },
+                                            false);
+}
+
+void bridge_mouse_release(TerminalSession* session, int x, int y, uint32_t modifiers)
+{
+    session->terminal().sendMouseReleaseEvent(toKeyboardModifiers(modifiers).chord,
+                                              vtbackend::MouseButton::Left,
+                                              vtbackend::PixelCoordinate { { x }, { y } },
+                                              false);
+}
+
+void bridge_focus_in(TerminalSession* session)
+{
+    session->terminal().sendFocusInEvent();
+}
+
+} // namespace contour_macos
