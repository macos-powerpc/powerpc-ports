From 8eb25e11a84f30322092068759bcd864fd82515e Mon Sep 17 00:00:00 2001
From: Sergey Fedorov <barracuda@macos-powerpc.org>
Date: Mon, 20 Jul 2026 02:46:09 +0000
Subject: [PATCH 56/67] fix(macos): suppress AppKit auto-window-open; drop
 diagnostic traces
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The trace confirmed contour never opens a second window when fastfetch runs
(openTerminalWindow fires once at launch, windows stays at 1). The "extra
window opening/closing" is an EXTERNAL helper fastfetch spawns for system
detection; contour merely lost and regained focus around it (two extra
applicationDidBecomeActive). Not a contour bug.

Keep the two AppKit suppressions as correct behavior for a document-less
terminal — applicationShouldHandleReopen: and applicationOpenUntitledFile:
return NO so AppKit never auto-creates a blank window (window creation stays
solely with openTerminalWindow). Remove the diagnostic NSLog traces and the
diagnostic-only applicationDidBecomeActive:.

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>
Claude-Session: https://claude.ai/code/session_01AeG2jwYMX5gdvvtUnx3PJa
---
 src/contour_macos/main.mm | 18 +++++-------------
 1 file changed, 5 insertions(+), 13 deletions(-)

diff --git a/src/contour_macos/main.mm b/src/contour_macos/main.mm
index 89f68988..3275c53f 100644
--- a/src/contour_macos/main.mm
+++ b/src/contour_macos/main.mm
@@ -20,7 +20,6 @@
 
 - (void)openTerminalWindow
 {
-    NSLog(@"[trace] openTerminalWindow called");
     NSRect const frame = NSMakeRect(0, 0, 720, 432);
     NSUInteger const style = NSTitledWindowMask | NSClosableWindowMask | NSMiniaturizableWindowMask
                              | NSResizableWindowMask;
@@ -84,30 +83,23 @@
     return YES;
 }
 
-// Trace + suppress the AppKit auto-open-a-window behaviors, in case one of these is what spawns the
-// spurious window when fastfetch runs (e.g. an activation/reopen). Returning NO / not opening a
-// window here prevents AppKit from creating an untitled document window on its own.
+// A terminal has no document model, so suppress AppKit's auto-open-a-blank-window behaviors: do not
+// create an untitled window at launch, and do not re-open one when the app is reactivated with no
+// visible windows (the Dock/reopen path). Returning NO here keeps window creation solely under our
+// control (openTerminalWindow, driven by launch and the Shell > New Window menu).
 - (BOOL)applicationShouldHandleReopen:(NSApplication*)app hasVisibleWindows:(BOOL)flag
 {
     (void) app;
-    NSLog(@"[trace] applicationShouldHandleReopen hasVisibleWindows=%d", flag);
+    (void) flag;
     return NO;
 }
 
 - (BOOL)applicationOpenUntitledFile:(NSApplication*)app
 {
     (void) app;
-    NSLog(@"[trace] applicationOpenUntitledFile");
     return NO;
 }
 
-- (void)applicationDidBecomeActive:(NSNotification*)note
-{
-    (void) note;
-    NSLog(@"[trace] applicationDidBecomeActive (windows=%lu)",
-          (unsigned long) [[NSApp windows] count]);
-}
-
 @end
 
 // Builds a minimal standard menu bar: application menu (Quit), Shell (New/Close), Edit
