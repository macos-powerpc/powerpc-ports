+void Terminal::captureLineGenerations(RenderBuffer& output,
+                                      Screen const& displayedScreen,
+                                      ScrollOffset scrollOffset,
+                                      LineCount extraLines) const
+{
+    // Mirrors Grid::render()'s own row range exactly (Grid.h): the scrolled-into-history start
+    // offset, the same extraLines widening for smooth scrolling, and the same page-size-driven
+    // row count -- so row N here is the SAME grid line Grid::render() just built RenderCells/
+    // RenderLines for.
+    auto const& grid = displayedScreen.grid();
+    auto const availableAbove = *grid.historyLineCount() - *scrollOffset;
+    auto const extraOffset = std::min(*extraLines, std::max(0, availableAbove));
+    auto const rowCount = *pageSize().lines + extraOffset;
+
+    output.lineGenerations.resize(static_cast<size_t>(rowCount));
+    auto i = -*scrollOffset - extraOffset;
+    for (auto row = size_t { 0 }; row < static_cast<size_t>(rowCount); ++row, ++i)
+        output.lineGenerations[row] = grid.lineAt(LineOffset(i)).generation();
+}
