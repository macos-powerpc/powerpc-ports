diff --git a/src/vtbackend/CellProxy.h b/src/vtbackend/CellProxy.h
index 2044afa3..2517513b 100644
--- a/src/vtbackend/CellProxy.h
+++ b/src/vtbackend/CellProxy.h
@@ -48,6 +48,26 @@ class BasicCellProxy
         assert(!line.codepoints.empty());
     }
 
+    BasicCellProxy(BasicCellProxy const&) noexcept = default;
+    BasicCellProxy(BasicCellProxy&&) noexcept = default;
+    BasicCellProxy& operator=(BasicCellProxy const&) noexcept = default;
+    BasicCellProxy& operator=(BasicCellProxy&&) noexcept = default;
+
+    /// Bumps the owning line's generation counter for the MUTABLE specialization only: every
+    /// `useCellAt()` call returns a proxy that exists so its caller can write through it (the
+    /// class's own name says so), so treating "a mutable proxy was destroyed" as "the cell may
+    /// have changed" catches every write path -- individual setters (write/reset/setCharacter/...),
+    /// LineSoA free functions called through them, everything -- without auditing each one, at the
+    /// cost of occasionally over-invalidating a line nothing actually changed on (e.g. useCellAt()
+    /// called only to read). That false-positive is a lost redraw-skip opportunity, never a
+    /// correctness bug, which is the right side to err on for dirty-tracking: the reverse mistake
+    /// (a missed bump on some overlooked mutation) would silently freeze stale content on screen.
+    ~BasicCellProxy() noexcept
+    {
+        if constexpr (!IsConst)
+            ++_line->generation;
+    }
+
     /// Implicit conversion from mutable proxy to const proxy.
     operator BasicCellProxy<true>() const noexcept
         requires(!IsConst)
