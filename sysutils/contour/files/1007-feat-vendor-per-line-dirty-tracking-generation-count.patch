+    ++line.generation;
 }
 
 void clearRange(LineSoA& line, size_t from, size_t count, GraphicsAttributes const& attrs)
@@ -114,6 +118,8 @@ void clearRange(LineSoA& line, size_t from, size_t count, GraphicsAttributes con
     // Partial clear may break SGR uniformity.
     if (from != 0 || count != line.codepoints.size())
         line.trivial = false;
+
+    ++line.generation;
 }
 
 void resetLine(LineSoA& line, ColumnCount cols, GraphicsAttributes const& fillAttrs)
@@ -147,6 +153,12 @@ void resetLine(LineSoA& line, ColumnCount cols, GraphicsAttributes const& fillAt
     line.usedColumns = {};
     line.trivial = true;
     line.fillAttrs = fillAttrs;
+
+    // (canSkipFill's fast path does not go through clearRange, so this function bumps its own
+    // generation regardless of which branch ran; the non-fast-path branch's clearRange() bump is
+    // therefore redundant with this one for that path, which is harmless -- one extra integer
+    // increment, not a correctness concern.)
+    ++line.generation;
 }
 
 void copyColumns(LineSoA const& src, size_t srcCol, LineSoA& dst, size_t dstCol, size_t count)
@@ -208,6 +220,7 @@ void copyColumns(LineSoA const& src, size_t srcCol, LineSoA& dst, size_t dstCol,
 
     // Copied SGR data may break uniformity on the destination line.
     dst.trivial = false;
+    ++dst.generation;
 }
 
 void moveColumns(LineSoA& line, size_t srcCol, size_t dstCol, size_t count)
@@ -234,6 +247,9 @@ void moveColumns(LineSoA& line, size_t srcCol, size_t dstCol, size_t count)
     // Callers must handle cluster pool entries if source cells have extras.
     // For insert/delete operations, the cluster pool entries remain valid
     // because the pool indices move with the clusterPoolIndex array.
+
+    if (count > 0)
+        ++line.generation;
 }
 
 size_t trimBlankRight(LineSoA const& line, size_t cols)
@@ -332,7 +348,10 @@ int appendCodepointToCluster(LineSoA& line, size_t col, char32_t codepoint, Clus
     // Under FirstCodepoint the codepoint still joins the cluster -- it is part of the text, and must
     // round-trip through a copy -- but it may not change how many columns the cluster occupies.
     if (policy == ClusterWidthPolicy::FirstCodepoint)
+    {
+        ++line.generation;
         return 0;
+    }
 
     // A cluster always occupies at least one column. grapheme_cluster_width answers 0 for a cluster
     // made only of zero-width codepoints -- a lone combining mark, ZWSP, a bare ZWJ -- and the base
@@ -343,6 +362,7 @@ int appendCodepointToCluster(LineSoA& line, size_t col, char32_t codepoint, Clus
         std::max(1u, unicode::grapheme_cluster_width(std::u32string_view(buffer.data(), count)));
     line.widths[col] = static_cast<uint8_t>(newWidth);
 
+    ++line.generation;
     return static_cast<int>(newWidth) - static_cast<int>(oldWidth);
 }
 
diff --git a/src/vtbackend/LineSoA.h b/src/vtbackend/LineSoA.h
index 03b0d974..252a6d77 100644
--- a/src/vtbackend/LineSoA.h
+++ b/src/vtbackend/LineSoA.h
@@ -124,6 +124,15 @@ struct LineSoA
     /// Used by writeAsciiToSoA and resetLine to skip redundant fill operations
     /// when the line is being rewritten with the same default attributes.
     GraphicsAttributes fillAttrs {};
+
+    /// Bumped by every function in this header/SoAClusterWriter.h that mutates this line's
+    /// content, and by every BasicCellProxy<false> (mutable CellProxy) destructor -- i.e. on
+    /// every real content change, from any call site, without each call site needing to know
+    /// about it. A frontend compares this against the value it saw last frame (per line) to
+    /// skip recompositing/reblitting lines that provably did not change, instead of redrawing
+    /// the whole page on every keystroke. Starts at 1, never 0, so a default-constructed
+    /// RenderLine::generation (0) never spuriously compares equal to a real line.
+    uint64_t generation = 1;
 };
 
