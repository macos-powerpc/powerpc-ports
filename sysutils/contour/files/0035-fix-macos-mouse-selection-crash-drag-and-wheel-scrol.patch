index de306073..3087ab5c 100644
--- a/src/contour_macos/TerminalSession.h
+++ b/src/contour_macos/TerminalSession.h
@@ -56,6 +56,9 @@ class TerminalSession: public vtbackend::Terminal::Events
     [[nodiscard]] vtrasterizer::Renderer& renderer() noexcept { return _renderer; }
     [[nodiscard]] SoftwareRenderTarget& renderTarget() noexcept { return _renderTarget; }
 
+    /// Maps a view pixel coordinate (top-left origin) to a grid cell location.
+    [[nodiscard]] vtbackend::CellLocation pixelToCell(int x, int y) const;
+
     /// Renders one frame into the render target's output buffer. Call on the main thread
