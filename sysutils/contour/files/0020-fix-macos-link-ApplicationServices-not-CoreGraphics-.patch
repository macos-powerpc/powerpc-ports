From fae4524a0461b2e0f8b641bfef7ed4407316d6d6 Mon Sep 17 00:00:00 2001
From: Sergey Fedorov <barracuda@macos-powerpc.org>
Date: Sun, 19 Jul 2026 12:06:26 +0000
Subject: [PATCH 20/67] fix(macos): link ApplicationServices, not CoreGraphics
 (10.6)

CoreGraphics is not a standalone linkable framework on 10.6 (same as CoreText);
its symbols come via ApplicationServices, so -framework CoreGraphics fails with
"framework not found". Drop it from the contour app link line (ApplicationServices
is already linked) and include <ApplicationServices/ApplicationServices.h>
explicitly in TerminalView.mm for the CGBitmapContext/CGImage APIs.

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>
Claude-Session: https://claude.ai/code/session_01AeG2jwYMX5gdvvtUnx3PJa
---
 src/contour_macos/CMakeLists.txt  | 3 ++-
 src/contour_macos/TerminalView.mm | 2 ++
 2 files changed, 4 insertions(+), 1 deletion(-)

diff --git a/src/contour_macos/CMakeLists.txt b/src/contour_macos/CMakeLists.txt
index c70b21f7..8b0d844b 100644
--- a/src/contour_macos/CMakeLists.txt
+++ b/src/contour_macos/CMakeLists.txt
@@ -64,10 +64,11 @@ if(APPLE)
         CXX_STANDARD 23
         OBJCXX_STANDARD 23
     )
+    # CoreGraphics is not a standalone linkable framework on 10.6 (like CoreText); its
+    # symbols come via ApplicationServices. Link ApplicationServices, not CoreGraphics.
     target_link_libraries(contour PRIVATE
         "-framework AppKit"
         "-framework Foundation"
         "-framework ApplicationServices"
-        "-framework CoreGraphics"
     )
 endif()
diff --git a/src/contour_macos/TerminalView.mm b/src/contour_macos/TerminalView.mm
index 9a137849..e0bcbd05 100644
--- a/src/contour_macos/TerminalView.mm
+++ b/src/contour_macos/TerminalView.mm
@@ -5,6 +5,8 @@
 
 #import <contour_macos/TerminalView.h>
 
+#import <ApplicationServices/ApplicationServices.h> // CoreGraphics (CGBitmapContext, CGImage) on 10.6
+
 #include <contour_macos/SessionBridge.h>
 
 #include <cstdlib>
-- 
