From 6578a84c4d713ac6aaa09d69ef7c856e28a982b3 Mon Sep 17 00:00:00 2001
From: Sergey Fedorov <barracuda@macos-powerpc.org>
Date: Tue, 21 Jul 2026 15:04:29 +0000
Subject: [PATCH 04/10] fix(vendor): force -std=c++23 explicitly for
 coretext_locator.mm (OBJCXX)

CMAKE_OBJCXX_STANDARD=23 (set globally in the root CMakeLists.txt) does not reliably
inject a -std= flag for every OBJCXX-compiler/CMake-version combination. Confirmed via
an actual MacPorts PPC build log: g++-mp-16 cross-compiling -arch ppc
-mmacosx-version-min=10.6 received NO -std= flag at all for coretext_locator.mm,
silently defaulting to an older C++ standard and hiding C++23 standard-library
additions -- concretely, std::string_view::contains() (used by crispy/utils.h, itself
new upstream code from the post-rebase commit range) failed to resolve because
__cplusplus never exceeded 202002L for this translation unit.

Fix: pass -std=c++23 directly via target_compile_options on the text_shaper target,
scoped to OBJCXX sources compiled by GNU (matching the project's existing pattern of
being explicit about compiler-specific flags rather than trusting CMake's standard-level
abstraction end-to-end). This guarantees coretext_locator.mm always builds at the same
C++ standard as the rest of the engine, regardless of whether CMAKE_OBJCXX_STANDARD's
automatic injection works for a given CMake/compiler pairing.

Co-Authored-By: Claude Sonnet 5 <noreply@anthropic.com>
Claude-Session: https://claude.ai/code/session_01LzTmVgP2ruMz987VJ78k77
---
 src/text_shaper/CMakeLists.txt | 9 +++++++++
 1 file changed, 9 insertions(+)

diff --git a/src/text_shaper/CMakeLists.txt b/src/text_shaper/CMakeLists.txt
index f5ac8f81..d39d5eb2 100644
--- a/src/text_shaper/CMakeLists.txt
+++ b/src/text_shaper/CMakeLists.txt
@@ -28,6 +28,15 @@ list(APPEND TEXT_SHAPER_LIBS Microsoft.GSL::GSL)
 if(APPLE)
     enable_language(OBJCXX)
     enable_language(OBJC)
+    # CMake's CMAKE_OBJCXX_STANDARD does not reliably inject a -std= flag for every
+    # OBJCXX-compiler/CMake-version combination (observed: g++-16 cross-compiling
+    # -arch ppc -mmacosx-version-min=10.6 received NO -std= at all, silently defaulting to
+    # an older standard and hiding C++23 library additions such as
+    # std::string_view::contains -- see the crispy/utils.h build failure this fixes). Pass
+    # the standard explicitly to coretext_locator.mm's compile so it always matches the
+    # rest of the C++23 engine, regardless of CMake's OBJCXX standard-injection support.
+    target_compile_options(text_shaper PRIVATE
+        $<$<AND:$<COMPILE_LANGUAGE:OBJCXX>,$<OBJCXX_COMPILER_ID:GNU>>:-std=c++23>)
     list(APPEND TEXT_SHAPER_LIBS "-framework Foundation")
     list(APPEND TEXT_SHAPER_LIBS "-framework AppKit")
     # CoreText became a standalone framework only in macOS 10.8; before that its symbols and
