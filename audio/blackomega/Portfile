# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           cmake 1.1
PortGroup           github 1.0
PortGroup           qt4 1.0

# github.setup      bonezuk blackomega 2.5.0 v
# Temporary, just to avoid enormous patch.
# TODO: switch back to the original upstream, once patches are merged.
github.setup        barracuda156 blackomega 2e5894f5c56621ead53ce68d9416042751e81b82
version             2.5.0
revision            0

categories          audio
license             BSD
maintainers         {@barracuda156 macos-powerpc.org:barracuda}

description         Black Omega, audiophile music player
long_description    {*}${description}
checksums           rmd160  7cb04ec1bef04e1891b6a9ae95d12c7944854698 \
                    sha256  61a15f1e288bcdb98057162f9286fead38375820940eb4329be7ce9c6e1530e4 \
                    size    32744976
github.tarball_from archive

cmake.out_of_source no

post-patch {
    reinplace "s|Qt6|Qt4|" ${worksrcpath}/CMakeLists.txt
    # Needed due to gtest:
    reinplace "s|CMAKE_CXX_STANDARD 11|CMAKE_CXX_STANDARD 14|" ${worksrcpath}/CMakeLists.txt
}

depends_build-append \
                    port:gtest

depends_lib-append  port:libmpcdec \
                    port:libxml2 \
                    port:QJson4 \
                    port:wavpack

# Most certainly TIGER_MAC_STORE is not what we need,
# however it may be worth reviewing if some code inside
# this macro is actually useful.
configure.args-append \
                    -DBLACKOMEGA_PREFIX=${prefix} \
                    -DOMEGA_QT4=ON \
                    -DQT_HOME=${qt_dir} \
                    -DTIGER_MAC_STORE=OFF \
                    -DTIGER_SYSTEM_DEPS=ON

compiler.cxx_standard 2014
# Due to gtest:
configure.cxxflags-append \
                    -std=gnu++14

if {${os.platform} eq "darwin" && ${os.major} < 11 && ${configure.cxx_stdlib} ne "libc++"} {
    # Modern gcc chokes on several ObjC++ sources here.
    pre-configure {
        configure.pre_args-append \
                    -DCMAKE_OBJCXX_COMPILER=/usr/bin/g++-4.2
    }
    # Otherwise linking fails when Xcode gcc is used.
    configure.ldflags-append \
                    -L${prefix}/lib/libgcc -lstdc++
    # The closest to C++11 for Xcode gcc?
    configure.objcxxflags \
                    -std=gnu++98
}

# This was an attempt to fix Qt bug with keywords conflicts,
# but apparently it has no effect on the outcome.
configure.cppflags-append \
                    -DQT_NO_KEYWORDS
# Ease the debugging for now:
configure.optflags

# source/remote/src/AppleRemoteService.mm:792:72: error: invalid conversion
# from 'unsigned int' to 'IOHIDElementCookie' {aka 'void*'} [-fpermissive]
if {[string match macports-gcc* ${configure.compiler}]} {
    configure.cxxflags-append \
                    -fpermissive
}

# FIXME: FireWire does not work. USB works.
# https://github.com/bonezuk/blackomega/issues/11

# FIXME: GUI still has some glitches.
