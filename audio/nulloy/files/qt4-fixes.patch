+void NActionManager::on_jumpForwardAction_triggered()
+{
+    qint64 num = 10 * 1000;
+    m_player->playbackEngine()->jump(num);
+}
+
+void NActionManager::on_jumpBackwardsAction_triggered()
+{
+    qint64 num = 10 * 1000;
+    m_player->playbackEngine()->jump(-num);
+}
