From 09a997953a5db4516f5eba2fdda4f89d64135044 Mon Sep 17 00:00:00 2001
From: Sergey Fedorov <barracuda@macos-powerpc.org>
Date: Thu, 3 Jul 2025 05:26:43 +0800
Subject: [PATCH 2/4] Fix linking

---
 qmmp/src/buld/buld.pro                             |  6 +++---
 qmmp/src/plugins/Input/Input.pri                   |  4 ++--
 qmmp/src/plugins/Input/main/cdaudio/cdaudio.pro    |  3 ++-
 qmmp/src/plugins/Input/main/ffap/ffap.pro          |  5 +----
 qmmp/src/plugins/Input/tracker/fc14/fc14.pro       |  2 +-
 qmmp/src/plugins/Input/tracker/stsound/stsound.pro |  2 +-
 qmmp/src/plugins/Input/zed/adplug/adplug.pro       |  2 +-
 qmmp/src/plugins/plugins.pri                       |  6 ++----
 qmmp/src/qmmp/qmmp.pro                             | 13 +++----------
 9 files changed, 16 insertions(+), 27 deletions(-)

diff --git qmmp/src/buld/buld.pro qmmp/src/buld/buld.pro
index bc2797ce3..4c4a18301 100644
--- qmmp/src/buld/buld.pro
+++ qmmp/src/buld/buld.pro
@@ -5,7 +5,7 @@ include($$PWD/../../qmmp.pri)
 greaterThan(QT_MAJOR_VERSION, 4): QT += widgets
 
 TARGET = app
-DESTDIR = $$OUT_PWD/../../bin/$$TTK_VERSION
+DESTDIR = $$OUT_PWD/../../lib/$$TTK_VERSION
 
 LIBS += -L$$DESTDIR -lTTKqmmp
 
@@ -17,12 +17,12 @@ win32:msvc:{
 }
 
 unix{
-    LIBS += -L$$PWD/../../../extra/gcc/libtaglib/lib -ltag$$STATIC_LIBRARY_SUFFIX
+    LIBS += -ltag
 }
 
 TEMPLATE = app
 
-SOURCES += main.cpp\
+SOURCES += main.cpp \
         mainwindow.cpp \
         musicplaylist.cpp \
         musicplayer.cpp
diff --git qmmp/src/plugins/Input/Input.pri qmmp/src/plugins/Input/Input.pri
index 2834a44b1..0a31390a3 100644
--- qmmp/src/plugins/Input/Input.pri
+++ qmmp/src/plugins/Input/Input.pri
@@ -1,4 +1,4 @@
 include($$PWD/../plugins.pri)
 
-QMAKE_LIBDIR += $$OUT_PWD/../../../../../bin/$$TTK_VERSION
-PLUGINS_PREFIX = $$OUT_PWD/../../../../../bin/$$TTK_VERSION/plugins
+QMAKE_LIBDIR += $$OUT_PWD/../../../../../lib/$$TTK_VERSION
+PLUGINS_PREFIX = $$OUT_PWD/../../../../../lib/$$TTK_VERSION/plugins
diff --git qmmp/src/plugins/Input/main/cdaudio/cdaudio.pro qmmp/src/plugins/Input/main/cdaudio/cdaudio.pro
index a5c838deb..ee27b53af 100644
--- qmmp/src/plugins/Input/main/cdaudio/cdaudio.pro
+++ qmmp/src/plugins/Input/main/cdaudio/cdaudio.pro
@@ -21,7 +21,8 @@ contains(CONFIG, WITH_LIBCDDB): DEFINES += WITH_LIBCDDB
 unix{
     QMAKE_CLEAN = $$DESTDIR/lib$${TARGET}.so
     LIBS += -L$$EXTRA_PREFIX/libcdio/lib -lcdio$$STATIC_LIBRARY_SUFFIX \
-            -L$$EXTRA_PREFIX/libcdio/lib -lcdio_paranoia$$STATIC_LIBRARY_SUFFIX -lcdio_cdda$$STATIC_LIBRARY_SUFFIX
+            -lcdio_cdda$$STATIC_LIBRARY_SUFFIX -lcdio_paranoia$$STATIC_LIBRARY_SUFFIX \
+            -lcddb$$STATIC_LIBRARY_SUFFIX
 }
 
 win32{
diff --git qmmp/src/plugins/Input/main/ffap/ffap.pro qmmp/src/plugins/Input/main/ffap/ffap.pro
index 8efb57dd4..b4c10c927 100644
--- qmmp/src/plugins/Input/main/ffap/ffap.pro
+++ qmmp/src/plugins/Input/main/ffap/ffap.pro
@@ -18,9 +18,6 @@ INCLUDEPATH += $$EXTRA_PREFIX/libtaglib/include
 
 unix{
     QMAKE_CLEAN = $$DESTDIR/lib$${TARGET}.so
-    LIBS += -L$$EXTRA_PREFIX/libtaglib/lib -ltag$$STATIC_LIBRARY_SUFFIX
 }
 
-win32{
-    LIBS += -L$$EXTRA_PREFIX/libtaglib/lib -ltag
-}
+LIBS += -ltag
diff --git qmmp/src/plugins/Input/tracker/fc14/fc14.pro qmmp/src/plugins/Input/tracker/fc14/fc14.pro
index 91b6b53a0..764121db8 100644
--- qmmp/src/plugins/Input/tracker/fc14/fc14.pro
+++ qmmp/src/plugins/Input/tracker/fc14/fc14.pro
@@ -14,7 +14,7 @@ INCLUDEPATH += $$EXTRA_PREFIX/libttk/include
 
 unix{
     QMAKE_CLEAN = $$DESTDIR/lib$${TARGET}.so
-    LIBS += -L$$EXTRA_PREFIX/libttk/lib -lfc14$$STATIC_LIBRARY_SUFFIX
+    LIBS += -L$$EXTRA_PREFIX/libttk/lib -lfc14audiodecoder
 }
 
 win32{
diff --git qmmp/src/plugins/Input/tracker/stsound/stsound.pro qmmp/src/plugins/Input/tracker/stsound/stsound.pro
index c1524ed13..e889fadbb 100644
--- qmmp/src/plugins/Input/tracker/stsound/stsound.pro
+++ qmmp/src/plugins/Input/tracker/stsound/stsound.pro
@@ -14,7 +14,7 @@ INCLUDEPATH += $$EXTRA_PREFIX/libttk/include
 
 unix{
     QMAKE_CLEAN = $$DESTDIR/lib$${TARGET}.so
-    LIBS += -L$$EXTRA_PREFIX/libttk/lib -lstsound$$STATIC_LIBRARY_SUFFIX
+    LIBS += -L$$EXTRA_PREFIX/libttk/lib -lStSound
 }
 
 win32{
diff --git qmmp/src/plugins/Input/zed/adplug/adplug.pro qmmp/src/plugins/Input/zed/adplug/adplug.pro
index 177b3647e..68e1a4f36 100644
--- qmmp/src/plugins/Input/zed/adplug/adplug.pro
+++ qmmp/src/plugins/Input/zed/adplug/adplug.pro
@@ -21,7 +21,7 @@ INCLUDEPATH += $$EXTRA_PREFIX/libadplug/include \
 
 unix{
     QMAKE_CLEAN = $$DESTDIR/lib$${TARGET}.so
-    LIBS += -L$$EXTRA_PREFIX/libadplug/lib -ladplug$$STATIC_LIBRARY_SUFFIX -lbinio$$STATIC_LIBRARY_SUFFIX
+    LIBS += -ladplug$$STATIC_LIBRARY_SUFFIX -lbinio$$STATIC_LIBRARY_SUFFIX
 }
 
 win32{
diff --git qmmp/src/plugins/plugins.pri qmmp/src/plugins/plugins.pri
index 7723d52bc..fff18e9ab 100644
--- qmmp/src/plugins/plugins.pri
+++ qmmp/src/plugins/plugins.pri
@@ -1,9 +1,7 @@
 include($$PWD/../../qmmp.pri)
 
-EXTRA_PREFIX = $$PWD/../../../extra/gcc
-
-QMAKE_LIBDIR += $$OUT_PWD/../../../../bin/$$TTK_VERSION
-PLUGINS_PREFIX = $$OUT_PWD/../../../../bin/$$TTK_VERSION/plugins
+QMAKE_LIBDIR += $$OUT_PWD/../../../../lib/$$TTK_VERSION
+PLUGINS_PREFIX = $$OUT_PWD/../../../../lib/$$TTK_VERSION/plugins
 
 LIBS += -lTTKqmmp
 
diff --git qmmp/src/qmmp/qmmp.pro qmmp/src/qmmp/qmmp.pro
index 7bc8676e8..7aad12316 100644
--- qmmp/src/qmmp/qmmp.pro
+++ qmmp/src/qmmp/qmmp.pro
@@ -92,18 +92,11 @@ SOURCES += recycler.cpp \
     regularexpression.cpp \
     format.cpp
 
-DESTDIR = $$OUT_PWD/../../bin/$$TTK_VERSION
+DESTDIR = $$OUT_PWD/../../lib/$$TTK_VERSION
 
 TARGET = TTK$${TARGET}
 CONFIG += shared warn_off plugin lib qt thread
 TEMPLATE = lib
 
-INCLUDEPATH += $$PWD/ $$PWD/../../../extra/gcc/libtaglib/include
-
-win32{
-    LIBS += -L$$PWD/../../../extra/gcc/libtaglib/lib -ltag
-}
-
-unix{
-    LIBS += -L$$PWD/../../../extra/gcc/libtaglib/lib -ltag$$STATIC_LIBRARY_SUFFIX
-}
+INCLUDEPATH += $$PWD/
+LIBS += -ltag
