From e1f9e5551b043598b264ac071ae24825fe0830e8 Mon Sep 17 00:00:00 2001
From: Sergey Fedorov <barracuda@macos-powerpc.org>
Date: Thu, 3 Jul 2025 05:26:43 +0800
Subject: [PATCH 2/5] Fix linking

---
 qmmp/src/buld/buld.pro                          | 4 ++--
 qmmp/src/plugins/Input/main/cdaudio/cdaudio.pro | 3 ++-
 qmmp/src/plugins/Input/main/ffap/ffap.pro       | 5 +----
 qmmp/src/plugins/plugins.pri                    | 2 --
 qmmp/src/qmmp/qmmp.pro                          | 9 +--------
 5 files changed, 6 insertions(+), 17 deletions(-)

diff --git qmmp/src/buld/buld.pro qmmp/src/buld/buld.pro
index bc2797ce3..f413d35a8 100644
--- qmmp/src/buld/buld.pro
+++ qmmp/src/buld/buld.pro
@@ -17,12 +17,12 @@ win32:msvc:{
 }
 
 unix{
-    LIBS += -L$$PWD/../../../extra/gcc/libtaglib/lib -ltag$$STATIC_LIBRARY_SUFFIX
+    LIBS += -ltag
 }
 
 TEMPLATE = app
 
-SOURCES += main.cpp\
+SOURCES += main.cpp \
         mainwindow.cpp \
         musicplaylist.cpp \
         musicplayer.cpp
diff --git qmmp/src/plugins/Input/main/cdaudio/cdaudio.pro qmmp/src/plugins/Input/main/cdaudio/cdaudio.pro
index a5c838deb..ee27b53af 100644
--- qmmp/src/plugins/Input/main/cdaudio/cdaudio.pro
+++ qmmp/src/plugins/Input/main/cdaudio/cdaudio.pro
@@ -21,7 +21,8 @@ contains(CONFIG, WITH_LIBCDDB): DEFINES += WITH_LIBCDDB
 unix{
     QMAKE_CLEAN = $$DESTDIR/lib$${TARGET}.so
     LIBS += -L$$EXTRA_PREFIX/libcdio/lib -lcdio$$STATIC_LIBRARY_SUFFIX \
-            -L$$EXTRA_PREFIX/libcdio/lib -lcdio_paranoia$$STATIC_LIBRARY_SUFFIX -lcdio_cdda$$STATIC_LIBRARY_SUFFIX
+            -lcdio_cdda$$STATIC_LIBRARY_SUFFIX -lcdio_paranoia$$STATIC_LIBRARY_SUFFIX \
+            -lcddb$$STATIC_LIBRARY_SUFFIX
 }
 
 win32{
diff --git qmmp/src/plugins/Input/main/ffap/ffap.pro qmmp/src/plugins/Input/main/ffap/ffap.pro
index 914547a1b..b4c10c927 100644
--- qmmp/src/plugins/Input/main/ffap/ffap.pro
+++ qmmp/src/plugins/Input/main/ffap/ffap.pro
@@ -18,9 +18,6 @@ INCLUDEPATH += $$EXTRA_PREFIX/libtaglib/include
 
 unix{
     QMAKE_CLEAN = $$DESTDIR/lib$${TARGET}.so
-    LIBS += -L$$EXTRA_PREFIX/libtaglib/lib -ltag$$STATIC_LIBRARY_SUFFIX -lgcc
 }
 
-win32{
-    LIBS += -L$$EXTRA_PREFIX/libtaglib/lib -ltag
-}
+LIBS += -ltag
diff --git qmmp/src/plugins/plugins.pri qmmp/src/plugins/plugins.pri
index 7723d52bc..57d4b6850 100644
--- qmmp/src/plugins/plugins.pri
+++ qmmp/src/plugins/plugins.pri
@@ -1,7 +1,5 @@
 include($$PWD/../../qmmp.pri)
 
-EXTRA_PREFIX = $$PWD/../../../extra/gcc
-
 QMAKE_LIBDIR += $$OUT_PWD/../../../../bin/$$TTK_VERSION
 PLUGINS_PREFIX = $$OUT_PWD/../../../../bin/$$TTK_VERSION/plugins
 
diff --git qmmp/src/qmmp/qmmp.pro qmmp/src/qmmp/qmmp.pro
index 7bc8676e8..bafc3d4af 100644
--- qmmp/src/qmmp/qmmp.pro
+++ qmmp/src/qmmp/qmmp.pro
@@ -99,11 +99,4 @@ CONFIG += shared warn_off plugin lib qt thread
 TEMPLATE = lib
 
 INCLUDEPATH += $$PWD/ $$PWD/../../../extra/gcc/libtaglib/include
-
-win32{
-    LIBS += -L$$PWD/../../../extra/gcc/libtaglib/lib -ltag
-}
-
-unix{
-    LIBS += -L$$PWD/../../../extra/gcc/libtaglib/lib -ltag$$STATIC_LIBRARY_SUFFIX
-}
+LIBS += -ltag
