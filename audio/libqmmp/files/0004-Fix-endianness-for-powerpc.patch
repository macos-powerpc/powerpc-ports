From 30760a56c702dad9e633152f0cbb7a12ba1aedd8 Mon Sep 17 00:00:00 2001
From: Sergey Fedorov <barracuda@macos-powerpc.org>
Date: Thu, 10 Jul 2025 08:05:36 +0800
Subject: [PATCH 4/4] Fix endianness for powerpc

---
 qmmp/src/plugins/Input/main/aac/decoder_aac.cpp  |  4 ++++
 .../Input/main/cdaudio/decoder_cdaudio.cpp       |  5 ++++-
 .../plugins/Input/main/ffmpeg/decoder_ffmpeg.cpp | 11 +++++++++++
 .../src/plugins/Input/main/flac/decoder_flac.cpp | 10 ++++++++++
 .../Output/qtmultimedia/outputqtmultimedia.cpp   | 16 ++++++++++++++++
 qmmp/src/qmmp/audioparameters.cpp                |  9 +++++++++
 qmmp/src/qmmp/decoder.h                          |  8 ++++++++
 qmmp/src/qmmp/qmmpsettings.cpp                   |  4 ++++
 8 files changed, 66 insertions(+), 1 deletion(-)

diff --git qmmp/src/plugins/Input/main/aac/decoder_aac.cpp qmmp/src/plugins/Input/main/aac/decoder_aac.cpp
index 4c35a0e41..d5fab29f2 100644
--- qmmp/src/plugins/Input/main/aac/decoder_aac.cpp
+++ qmmp/src/plugins/Input/main/aac/decoder_aac.cpp
@@ -96,7 +96,11 @@ bool DecoderAAC::initialize()
     m_input_at -= res;
 
     setProperty(Qmmp::FORMAT_NAME, "AAC");
+#ifdef __POWERPC__
+    configure(freq, chan, Qmmp::PCM_S16BE);
+#else
     configure(freq, chan, Qmmp::PCM_S16LE);
+#endif
     qDebug("DecoderAAC: initialize success");
     return true;
 }
diff --git qmmp/src/plugins/Input/main/cdaudio/decoder_cdaudio.cpp qmmp/src/plugins/Input/main/cdaudio/decoder_cdaudio.cpp
index 945176a3e..d1e18fbc1 100644
--- qmmp/src/plugins/Input/main/cdaudio/decoder_cdaudio.cpp
+++ qmmp/src/plugins/Input/main/cdaudio/decoder_cdaudio.cpp
@@ -417,8 +417,11 @@ bool DecoderCDAudio::initialize()
         }
         qDebug("DecoderCDAudio: using cd audio capable drive \"%s\"", qPrintable(device_path));
     }
-
+#ifdef __POWERPC__
+    configure(44100, 2, Qmmp::PCM_S16BE);
+#else
     configure(44100, 2, Qmmp::PCM_S16LE);
+#endif
     m_bitrate = 1411;
     m_totalTime = tracks[track_at].info.duration();
     m_first_sector = tracks[track_at].first_sector;
diff --git qmmp/src/plugins/Input/main/ffmpeg/decoder_ffmpeg.cpp qmmp/src/plugins/Input/main/ffmpeg/decoder_ffmpeg.cpp
index cbf0ece69..0b8e60768 100644
--- qmmp/src/plugins/Input/main/ffmpeg/decoder_ffmpeg.cpp
+++ qmmp/src/plugins/Input/main/ffmpeg/decoder_ffmpeg.cpp
@@ -270,6 +270,16 @@ bool DecoderFFmpeg::initialize()
     case AV_SAMPLE_FMT_U8P:
         format = Qmmp::PCM_U8;
         break;
+#ifdef __POWERPC__
+    case AV_SAMPLE_FMT_S16:
+    case AV_SAMPLE_FMT_S16P:
+        format = Qmmp::PCM_S16BE;
+        break;
+    case AV_SAMPLE_FMT_S32:
+    case AV_SAMPLE_FMT_S32P:
+        format = Qmmp::PCM_S32BE;
+        break;
+#else
     case AV_SAMPLE_FMT_S16:
     case AV_SAMPLE_FMT_S16P:
         format = Qmmp::PCM_S16LE;
@@ -278,6 +288,7 @@ bool DecoderFFmpeg::initialize()
     case AV_SAMPLE_FMT_S32P:
         format = Qmmp::PCM_S32LE;
         break;
+#endif
     case AV_SAMPLE_FMT_FLT:
     case AV_SAMPLE_FMT_FLTP:
         format = Qmmp::PCM_FLOAT;
diff --git qmmp/src/plugins/Input/main/flac/decoder_flac.cpp qmmp/src/plugins/Input/main/flac/decoder_flac.cpp
index c76d41540..93d1e24b1 100644
--- qmmp/src/plugins/Input/main/flac/decoder_flac.cpp
+++ qmmp/src/plugins/Input/main/flac/decoder_flac.cpp
@@ -412,6 +412,15 @@ bool DecoderFLAC::initialize()
     case 8:
         configure(m_data->sample_rate, chmap, Qmmp::PCM_S8);
         break;
+#ifdef __POWERPC__
+    case 16:
+        configure(m_data->sample_rate, chmap, Qmmp::PCM_S16BE);
+        break;
+    case 24:
+    case 32:
+        configure(m_data->sample_rate, chmap, Qmmp::PCM_S32BE);
+        break;
+#else
     case 16:
         configure(m_data->sample_rate, chmap, Qmmp::PCM_S16LE);
         break;
@@ -419,6 +428,7 @@ bool DecoderFLAC::initialize()
     case 32:
         configure(m_data->sample_rate, chmap, Qmmp::PCM_S32LE);
         break;
+#endif
     default:
         return false;
     }
diff --git qmmp/src/plugins/Output/qtmultimedia/outputqtmultimedia.cpp qmmp/src/plugins/Output/qtmultimedia/outputqtmultimedia.cpp
index 652c71267..9a15e4063 100644
--- qmmp/src/plugins/Output/qtmultimedia/outputqtmultimedia.cpp
+++ qmmp/src/plugins/Output/qtmultimedia/outputqtmultimedia.cpp
@@ -28,7 +28,11 @@ bool OutputQtMultimedia::initialize(quint32 freq, ChannelMap map, Qmmp::AudioFor
     QAudioFormat qformat;
     qformat.setCodec("audio/pcm");
     qformat.setSampleRate(freq);
+#ifdef __POWERPC__
+    qformat.setByteOrder(QAudioFormat::BigEndian);
+#else
     qformat.setByteOrder(QAudioFormat::LittleEndian);
+#endif
     qformat.setChannelCount(map.size());
     qformat.setSampleType(QAudioFormat::SignedInt);
 
@@ -40,6 +44,17 @@ bool OutputQtMultimedia::initialize(quint32 freq, ChannelMap map, Qmmp::AudioFor
     case Qmmp::PCM_S8:
         qformat.setSampleSize(8);
         break;
+#ifdef __POWERPC__
+    case Qmmp::PCM_S16BE:
+        qformat.setSampleSize(16);
+        break;
+    case Qmmp::PCM_S24BE:
+        qformat.setSampleSize(24);
+        break;
+    case Qmmp::PCM_S32BE:
+        qformat.setSampleSize(32);
+        break;
+#else
     case Qmmp::PCM_S16LE:
         qformat.setSampleSize(16);
         break;
@@ -49,6 +64,7 @@ bool OutputQtMultimedia::initialize(quint32 freq, ChannelMap map, Qmmp::AudioFor
     case Qmmp::PCM_S32LE:
         qformat.setSampleSize(32);
         break;
+#endif
     default:
         break;
     }
diff --git qmmp/src/qmmp/audioparameters.cpp qmmp/src/qmmp/audioparameters.cpp
index 5df129ba7..34e3342ec 100644
--- qmmp/src/qmmp/audioparameters.cpp
+++ qmmp/src/qmmp/audioparameters.cpp
@@ -86,12 +86,21 @@ AudioParameters::ByteOrder AudioParameters::byteOrder() const
 {
     switch(m_format)
     {
+#ifdef __POWERPC__
+    case Qmmp::PCM_S16LE:
+    case Qmmp::PCM_S24LE:
+    case Qmmp::PCM_S32LE:
+        return LittleEndian;
+    default:
+        return BigEndian;
+#else
     case Qmmp::PCM_S16BE:
     case Qmmp::PCM_S24BE:
     case Qmmp::PCM_S32BE:
         return BigEndian;
     default:
         return LittleEndian;
+#endif
     }
 }
 
diff --git qmmp/src/qmmp/decoder.h qmmp/src/qmmp/decoder.h
index c0d749c24..bb2bbf9b0 100644
--- qmmp/src/qmmp/decoder.h
+++ qmmp/src/qmmp/decoder.h
@@ -203,14 +203,22 @@ protected:
      * @param map Map of channels.
      * @param f Audio format.
      */
+#ifdef __POWERPC__
+    void configure(quint32 srate, const ChannelMap &map, Qmmp::AudioFormat f = Qmmp::PCM_S16BE);
+#else
     void configure(quint32 srate, const ChannelMap &map, Qmmp::AudioFormat f = Qmmp::PCM_S16LE);
+#endif
     /*!
      * Use this function inside initialize() reimplementation to tell other plugins about audio parameters.
      * @param srate Sample rate.
      * @param channels Number of channels (internal channel sequence).
      * @param f Audio format.
      */
+#ifdef __POWERPC__
+    void configure(quint32 srate, int channels, Qmmp::AudioFormat f = Qmmp::PCM_S16BE);
+#else
     void configure(quint32 srate, int channels, Qmmp::AudioFormat f = Qmmp::PCM_S16LE);
+#endif
     /*!
      * Use this function inside initialize() reimplementation to tell other plugins about audio parameters.
      * @param p Audio parameters.
diff --git qmmp/src/qmmp/qmmpsettings.cpp qmmp/src/qmmp/qmmpsettings.cpp
index cbd0563c7..8868a1e82 100644
--- qmmp/src/qmmp/qmmpsettings.cpp
+++ qmmp/src/qmmp/qmmpsettings.cpp
@@ -22,7 +22,11 @@ QmmpSettings::QmmpSettings(QObject *parent)
     settings.endGroup();
     //audio settings
     m_aud_software_volume = settings.value("Output/software_volume", true).toBool();
+#ifdef __POWERPC__
+    m_aud_format = static_cast<Qmmp::AudioFormat>(settings.value("Output/format", Qmmp::PCM_S16BE).toInt());
+#else
     m_aud_format = static_cast<Qmmp::AudioFormat>(settings.value("Output/format", Qmmp::PCM_S16LE).toInt());
+#endif
     m_aud_dithering = settings.value("Output/dithering", true).toBool();
     m_volume_step = settings.value("Output/volume_step", 10).toInt();
     m_average_bitrate = settings.value("Output/average_bitrate", false).toBool();
-- 
2.48.0

