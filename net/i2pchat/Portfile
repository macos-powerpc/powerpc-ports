github.tarball_from archive

patch.pre_args-replace  -p0 -p1

# Qt4 builds on aarch64 but does not work correctly.
# For Linux Qt4 is probably not supported at all.
if {${os.platform} ne "darwin" || ${os.arch} eq "arm"} {
    PortGroup       qmake5 1.0

    qt5.depends_component qtmultimedia qtsvg
} else {
    PortGroup       qmake 1.0

    # https://github.com/vituperative/i2pchat/issues/31
    patchfiles-append \
                    0001-Fix-build-with-Qt4.patch
}

compiler.cxx_standard   2011

destroot {
    copy ${worksrcpath}/I2PChat.app ${destroot}${applications_dir}
}
