# We need to dig out legacy version of ADVobfuscator due to:
# https://github.com/Windscribe/wsnet/issues/2

github.tarball_from archive

set obfuscator_hash 1852a0eb75b03ab3139af7f938dfb617c292c600

master_sites-append https://github.com/andrivet/ADVobfuscator/archive/${obfuscator_hash}/:obfuscator
distfiles-append    ADVobfuscator-${obfuscator_hash}.tar.gz:obfuscator

checksums           ${distname}${extract.suffix} \
                    rmd160  b957f4bdacee7090a103c844caba8e6a1f50fd43 \
                    sha256  0fba92592571889da6a65c1d14314f0a99a006a55ae8f75b580494721e618ef8 \
                    size    264713 \
                    ADVobfuscator-${obfuscator_hash}${extract.suffix} \
                    rmd160  55cff4370ac2b5739ed2fe009f70d68274ebd192 \
                    sha256  7ca04a95d35d9c91095aa89c4cbfb451e10f5e624e3ed89fe5bb2ba824eb41df \
                    size    6485571

post-extract {
    move ${workpath}/ADVobfuscator-${obfuscator_hash} ${worksrcpath}/advobfuscator
}

patch.pre_args-replace  -p0 -p1

# https://github.com/Windscribe/wsnet/pull/4
patchfiles-append   0001-requesterror.cpp-add-missing-header.patch
# https://github.com/Windscribe/wsnet/issues/5
patchfiles-append   0002-curlnetworkmanager.cpp-avoid-non-existing-macros.patch
# https://github.com/Windscribe/wsnet/pull/6
patchfiles-append   0003-CMakeLists.txt-fix-linking-for-macOS.patch

patchfiles-append   wsnet-macos-compat.patch

post-patch {
    reinplace "s|CMAKE_CXX_STANDARD 17|CMAKE_CXX_STANDARD 23|" ${worksrcpath}/CMakeLists.txt
}

set libfmt_v        11
cmake.module_path-append \
                    ${prefix}/lib/libfmt${libfmt_v}/cmake

depends_build-append \
                    port:cmrc \
                    port:cpp-base64 \
                    port:gtest \
                    path:bin/pkg-config:pkgconfig

# Requires rapidjson-devel currently:
# persistentsettings.cpp:25:31: error: no member named 'GetObj' in 'rapidjson::GenericDocument<rapidjson::UTF8<>>'
depends_lib-append  port:c-ares \
                    port:curl \
                    port:libfmt${libfmt_v} \
                    port:range-v3 \
                    path:lib/pkgconfig/RapidJSON.pc:rapidjson-devel \
                    port:skyr-url \
                    port:spdlog \
                    port:tl-expected

compiler.cxx_standard   2023

configure.args-append \
    -DADVOBFUSCATOR_INCLUDE_DIRS=${worksrcpath}/advobfuscator \
    -DCPP_BASE64_INCLUDE_DIRS=${prefix}/include \
    -DWSNET_VERSION_FALLBACK=${version}
