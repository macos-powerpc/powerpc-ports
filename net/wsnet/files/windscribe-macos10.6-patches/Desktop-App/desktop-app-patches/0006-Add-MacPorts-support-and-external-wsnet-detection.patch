From ef4ba584b5a78681edffd7aee02023d4d6be7223 Mon Sep 17 00:00:00 2001
From: sgr <sgr@localhost>
Date: Sat, 2 May 2026 14:35:10 +0000
Subject: [PATCH] Add MacPorts support and external wsnet detection
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- Remove vcpkg integration for macOS builds
- Use MacPorts OpenVPN and OpenSSL
- Add external wsnet support with find_package + FetchContent fallback
- Auto-detect OpenVPN from standard paths

🤖 Generated with [Claude Code](https://claude.ai/code)

Co-Authored-By: Claude <noreply@anthropic.com>
---
 CMakeLists.txt            | 12 ---------
 cmake/fetch_wsnet.cmake   | 20 +++++++++-----
 src/client/CMakeLists.txt | 55 ++++++++++++++++++++++++++++++++-------
 3 files changed, 60 insertions(+), 27 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 9e7206ff..64c202cb 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -17,9 +17,6 @@ if(APPLE AND NOT CI_MODE AND NOT DEFINED CMAKE_OSX_ARCHITECTURES)
     set(CMAKE_OSX_ARCHITECTURES "${MACOS_HOST_ARCH}" CACHE STRING "macOS architecture")
 endif()
 
-# Enable vcpkg dependency installation
-set(X_VCPKG_APPLOCAL_DEPS_INSTALL ON)
-
 # C++ standard
 set(CMAKE_CXX_STANDARD 17)
 set(CMAKE_CXX_STANDARD_REQUIRED ON)
@@ -117,11 +114,6 @@ endif()
 # Project Configuration
 # ------------------------------------------------------------------------------
 
-# vcpkg integration (only needed for build operations, must be before project())
-if(BUILD_APP OR BUILD_INSTALLER OR BUILD_BOOTSTRAP)
-    include(cmake/vcpkg.cmake)
-endif()
-
 project(Windscribe
     VERSION ${WINDSCRIBE_VERSION_MAJOR}.${WINDSCRIBE_VERSION_MINOR}.${WINDSCRIBE_VERSION_BUILD}
     DESCRIPTION "Windscribe VPN Client"
@@ -161,10 +153,6 @@ endif()
 message(STATUS "==================================================")
 message(STATUS "")
 
-if(BUILD_APP OR BUILD_INSTALLER OR BUILD_BOOTSTRAP)
-    install_vcpkg_dependencies()
-endif()
-
 # ------------------------------------------------------------------------------
 # Custom Dependencies (WireGuard, WSTunnel, Wintun, OpenVPN DCO)
 # ------------------------------------------------------------------------------
diff --git a/cmake/fetch_wsnet.cmake b/cmake/fetch_wsnet.cmake
index 51507d7b..c6951b6b 100644
--- a/cmake/fetch_wsnet.cmake
+++ b/cmake/fetch_wsnet.cmake
@@ -1,8 +1,16 @@
 if(NOT TARGET wsnet::wsnet)
-    include(FetchContent)
-    FetchContent_Declare(wsnet
-        GIT_REPOSITORY git@github.com:Windscribe/wsnet.git
-        GIT_TAG        1.4.8
-    )
-    FetchContent_MakeAvailable(wsnet)
+    # Try to find system-installed wsnet first
+    find_package(wsnet QUIET CONFIG)
+
+    if(wsnet_FOUND)
+        message(STATUS "Using system-installed wsnet library")
+    else()
+        message(STATUS "System wsnet not found, fetching from git repository")
+        include(FetchContent)
+        FetchContent_Declare(wsnet
+            GIT_REPOSITORY https://github.com/Windscribe/wsnet.git
+            GIT_TAG        1.4.8
+        )
+        FetchContent_MakeAvailable(wsnet)
+    endif()
 endif()
diff --git a/src/client/CMakeLists.txt b/src/client/CMakeLists.txt
index 8999f88c..b5ace6a6 100644
--- a/src/client/CMakeLists.txt
+++ b/src/client/CMakeLists.txt
@@ -1,7 +1,6 @@
 cmake_minimum_required(VERSION 3.23)
 
 set(CMAKE_POLICY_DEFAULT_CMP0077 NEW)
-set(X_VCPKG_APPLOCAL_DEPS_INSTALL ON)
 
 set(CMAKE_OSX_DEPLOYMENT_TARGET "12" CACHE STRING "Minimum OS X deployment version")
 
@@ -22,6 +21,40 @@ find_package(OpenSSL REQUIRED)
 find_package(Boost REQUIRED COMPONENTS serialization)
 find_package(spdlog CONFIG REQUIRED)
 
+# Configure OpenVPN binary location for macOS
+if(APPLE)
+    # Allow explicit path configuration via cmake -DOPENVPN_PATH=/path/to/openvpn
+    set(OPENVPN_PATH "" CACHE FILEPATH "Explicit path to OpenVPN binary")
+
+    if(OPENVPN_PATH)
+        # Use explicitly configured path
+        set(OPENVPN_BINARY "${OPENVPN_PATH}")
+        message(STATUS "Using configured OpenVPN path: ${OPENVPN_BINARY}")
+    else()
+        # Fallback: search in common macOS locations
+        find_program(OPENVPN_BINARY
+            NAMES openvpn
+            PATHS /opt/local/sbin /usr/local/sbin /usr/sbin
+            DOC "OpenVPN binary location"
+        )
+        if(OPENVPN_BINARY)
+            message(STATUS "Found OpenVPN: ${OPENVPN_BINARY}")
+        else()
+            message(WARNING "OpenVPN binary not found. Install via MacPorts: sudo port install openvpn, or set -DOPENVPN_PATH=/path/to/openvpn")
+        endif()
+    endif()
+
+    # Find ctrld binary (optional, check common macOS locations)
+    find_program(CTRLD_BINARY
+        NAMES ctrld
+        PATHS /opt/local/bin /usr/local/bin /usr/bin
+        DOC "ctrld binary location"
+    )
+    if(NOT CTRLD_BINARY)
+        message(STATUS "ctrld binary not found (optional)")
+    endif()
+endif()
+
 include("${CMAKE_CURRENT_LIST_DIR}/../../cmake/fetch_wsnet.cmake")
 
 # build_all.py sets this option when invoked with the '--sign' flag. Disabled by default
@@ -170,10 +203,10 @@ elseif (APPLE)
         add_custom_command(TARGET Windscribe POST_BUILD
             COMMAND ${CMAKE_COMMAND} -E echo "Copying dependency libraries to Frameworks..."
             COMMAND ${CMAKE_COMMAND} -E copy_if_different
-                    ${VCPKG_INSTALLED_DIR}/${VCPKG_TARGET_TRIPLET}/lib/libcrypto.3.dylib
+                    ${OPENSSL_CRYPTO_LIBRARY}
                     $<TARGET_FILE_DIR:Windscribe>/../Frameworks/libcrypto.3.dylib
             COMMAND ${CMAKE_COMMAND} -E copy_if_different
-                    ${VCPKG_INSTALLED_DIR}/${VCPKG_TARGET_TRIPLET}/lib/libssl.3.dylib
+                    ${OPENSSL_SSL_LIBRARY}
                     $<TARGET_FILE_DIR:Windscribe>/../Frameworks/libssl.3.dylib
             COMMAND ${CMAKE_COMMAND} -E copy_if_different
                     $<TARGET_FILE:wsnet::wsnet>
@@ -184,8 +217,10 @@ elseif (APPLE)
 
         add_custom_command(TARGET Windscribe POST_BUILD COMMAND ${CMAKE_COMMAND} -E make_directory $<TARGET_FILE_DIR:Windscribe>/../Helpers)
 
-        add_custom_command(TARGET Windscribe POST_BUILD COMMAND ${CMAKE_COMMAND} -E copy_if_different
-                           ${VCPKG_INSTALLED_DIR}/${VCPKG_TARGET_TRIPLET}/tools/openvpn/sbin/openvpn $<TARGET_FILE_DIR:Windscribe>/../Helpers/windscribeopenvpn)
+        if(OPENVPN_BINARY)
+            add_custom_command(TARGET Windscribe POST_BUILD COMMAND ${CMAKE_COMMAND} -E copy_if_different
+                               ${OPENVPN_BINARY} $<TARGET_FILE_DIR:Windscribe>/../Helpers/windscribeopenvpn)
+        endif()
 
         # Copy split tunnel extension
         add_custom_command(TARGET Windscribe POST_BUILD COMMAND ${CMAKE_COMMAND} -E copy_directory
@@ -201,8 +236,10 @@ elseif (APPLE)
         add_custom_command(TARGET Windscribe POST_BUILD COMMAND ${CMAKE_COMMAND} -E copy_if_different
                            ${WINDSCRIBE_BUILD_LIBS_PATH}/wireguard/windscribeamneziawg $<TARGET_FILE_DIR:Windscribe>/../Helpers/windscribeamneziawg)
 
-        add_custom_command(TARGET Windscribe POST_BUILD COMMAND ${CMAKE_COMMAND} -E copy_if_different
-                          ${VCPKG_INSTALLED_DIR}/${VCPKG_TARGET_TRIPLET}/tools/ctrld/ctrld $<TARGET_FILE_DIR:Windscribe>/../Helpers/windscribectrld)
+        if(CTRLD_BINARY)
+            add_custom_command(TARGET Windscribe POST_BUILD COMMAND ${CMAKE_COMMAND} -E copy_if_different
+                              ${CTRLD_BINARY} $<TARGET_FILE_DIR:Windscribe>/../Helpers/windscribectrld)
+        endif()
 
         add_custom_command(TARGET Windscribe POST_BUILD COMMAND ${CMAKE_COMMAND} -E copy_if_different
                           ${WINDSCRIBE_BUILD_LIBS_PATH}/wstunnel/windscribewstunnel $<TARGET_FILE_DIR:Windscribe>/../Helpers/windscribewstunnel)
@@ -302,8 +339,8 @@ if (APPLE)
         LIBRARY DESTINATION "Windscribe.app/Contents/Frameworks"
         BUNDLE DESTINATION .
     )
-    install(FILES ${VCPKG_INSTALLED_DIR}/${VCPKG_TARGET_TRIPLET}/lib/libcrypto.3.dylib DESTINATION Windscribe.app/Contents/Frameworks)
-    install(FILES ${VCPKG_INSTALLED_DIR}/${VCPKG_TARGET_TRIPLET}/lib/libssl.3.dylib DESTINATION Windscribe.app/Contents/Frameworks)
+    install(FILES ${OPENSSL_CRYPTO_LIBRARY} DESTINATION Windscribe.app/Contents/Frameworks RENAME libcrypto.3.dylib)
+    install(FILES ${OPENSSL_SSL_LIBRARY} DESTINATION Windscribe.app/Contents/Frameworks RENAME libssl.3.dylib)
 else()
     install(TARGETS Windscribe
         RUNTIME DESTINATION .
