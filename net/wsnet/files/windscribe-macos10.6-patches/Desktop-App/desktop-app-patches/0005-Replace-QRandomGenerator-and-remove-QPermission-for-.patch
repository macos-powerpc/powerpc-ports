From c1a5cab31c0287050267a2b21053c4d92b0ba219 Mon Sep 17 00:00:00 2001
From: Claude Code <claude@anthropic.com>
Date: Fri, 10 Apr 2026 08:05:55 +0000
Subject: [PATCH 5/5] Replace QRandomGenerator and remove QPermission for Qt4

Qt4 compatibility changes in mainwindow.cpp:
- Replace QRandomGenerator::global()->bounded() with qrand() % size for Qt4
- Wrap QPermission (Qt6+) with version check - not available in Qt4
- Conditionally include QRandomGenerator header (Qt 5.10+)

Location permission handling disabled for Qt4/Qt5, but core VPN functionality unaffected.
---
 src/client/frontend/gui/mainwindow.cpp | 15 +++++++++++----
 1 file changed, 11 insertions(+), 4 deletions(-)

diff --git a/src/client/frontend/gui/mainwindow.cpp b/src/client/frontend/gui/mainwindow.cpp
index beeb8b0a..ac56d52b 100644
--- a/src/client/frontend/gui/mainwindow.cpp
+++ b/src/client/frontend/gui/mainwindow.cpp
@@ -7,7 +7,9 @@
 #include <QGuiApplication>
 #include <QJsonDocument.h>
 #include <QMouseEvent>
+#if QT_VERSION >= QT_VERSION_CHECK(5, 10, 0)
 #include <QRandomGenerator>
+#endif
 #include <QScreen>
 #include <QStyleHints>
 #include <QThread>
@@ -15,9 +17,10 @@
 #include <QWindow>
 #include <QWidgetAction>
 
-#if defined(Q_OS_MACOS)
+#if defined(Q_OS_MACOS) && QT_VERSION >= QT_VERSION_CHECK(6, 0, 0)
 #include <QPermission>
-#elif defined(Q_OS_LINUX)
+#endif
+#if defined(Q_OS_LINUX)
 #include <QtDBus/QtDBus>
 #endif
 
@@ -3309,7 +3312,11 @@ void MainWindow::onIpcConnectStaticIp(const QString &location, const types::Prot
 
     if (list.size() > 0) {
         // Randomly pick one of the candidates
+#if QT_VERSION >= QT_VERSION_CHECK(5, 10, 0)
         onIpcConnect(list[QRandomGenerator::global()->bounded(list.size())], protocol, port);
+#else
+        onIpcConnect(list[qrand() % list.size()], protocol, port);
+#endif
     }
 }
 
@@ -3955,7 +3962,7 @@ void MainWindow::checkLocationPermission()
             std::function<void(bool)>(nullptr),
             std::function<void(bool)>(nullptr),
             GeneralMessage::kShowBottomPanel);
-#ifdef Q_OS_MACOS
+#if defined(Q_OS_MACOS) && QT_VERSION >= QT_VERSION_CHECK(6, 0, 0)
     } else {
         if (qApp->checkPermission(QLocationPermission{}) == Qt::PermissionStatus::Undetermined) {
             qApp->requestPermission(QLocationPermission{}, this, &MainWindow::onLocationPermissionUpdated);
@@ -3967,7 +3974,7 @@ void MainWindow::checkLocationPermission()
 
 void MainWindow::onLocationPermissionUpdated()
 {
-#if defined(Q_OS_MACOS)
+#if defined(Q_OS_MACOS) && QT_VERSION >= QT_VERSION_CHECK(6, 0, 0)
     if (qApp->checkPermission(QLocationPermission{}) == Qt::PermissionStatus::Granted) {
         qCInfo(LOG_BASIC) << "Location permission granted";
     } else if (qApp->checkPermission(QLocationPermission{}) == Qt::PermissionStatus::Denied) {
