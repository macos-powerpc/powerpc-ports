From: Windscribe Contributors
Subject: [PATCH] Fix GCC compilation error with const_iterator in erase()

GCC's std::basic_string<char32_t>::erase() does not accept const_iterator
as the first parameter, unlike Clang/MSVC. The standard requires iterator,
not const_iterator.

This patch converts the const_iterator to a non-const iterator by computing
the offset and using begin() + offset.

Fixes: https://github.com/Windscribe/wsnet/issues/7

---
 include/skyr/domain/domain.hpp | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/include/skyr/domain/domain.hpp b/include/skyr/domain/domain.hpp
index abcdef1..1234567 100644
--- a/include/skyr/domain/domain.hpp
+++ b/include/skyr/domain/domain.hpp
@@ -125,7 +125,8 @@ inline auto domain_to_ascii_impl(domain_to_ascii_context&& context) -> std::expe
       [](domain_to_ascii_context&& ctx) -> std::expected<domain_to_ascii_context, domain_errc> {
     auto result = idna::map_code_points(ctx.domain_name, ctx.use_std3_ascii_rules, ctx.transitional_processing);
     if (result) {
-      ctx.domain_name.erase(result.value(), std::cend(ctx.domain_name));
+      auto pos = std::distance(std::cbegin(ctx.domain_name), result.value());
+      ctx.domain_name.erase(ctx.domain_name.begin() + pos, ctx.domain_name.end());
       return std::move(ctx);
     } else {
       return std::unexpected(result.error());
--
