+  let open_connection ~(host : Ipaddr.V4.t) ~port =
+    let open Lwt.Infix in
+    let addr = Unix.ADDR_INET (Ipaddr_unix.V4.to_inet_addr host, port) in
+    (* Create socket with Lwt_unix *)
+    let sock = Lwt_unix.socket Unix.PF_INET Unix.SOCK_STREAM 0 in
+    (* Set socket options before connecting *)
+    Unix.setsockopt (Lwt_unix.unix_file_descr sock) Unix.TCP_NODELAY false;
