@@ -418,11 +418,13 @@ let download_file output_file torrent_file =
   in
   (* Get Peers *)
   let random_peer = Bytes.create 20 in
-  let uri = build_tracker_url torrent_file random_peer 6881 in
-  Peers.request_peers uri >>= fun peers ->
+  let client_port = 6881 in
+  let uri = build_tracker_url torrent_file random_peer client_port in
+  let total_len = total_length torrent_file |> Int64.to_int in
+  let left = Stdint.Int64.of_int total_len in
+  Peers.request_peers uri torrent_file.info_hash random_peer client_port left >>= fun peers ->
   Logs.debug (fun m -> m "Got %d peers\n" (List.length peers));
   (* Download *)
-  let total_len = total_length torrent_file |> Int64.to_int in
   let pieces_count = Array.length torrent_file.piece_hashes in
 
   (* Load resume state if exists *)
