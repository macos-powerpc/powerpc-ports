From a05f9640cf1f23ed04480762e59ddfa6e2d61163 Mon Sep 17 00:00:00 2001
From: Claude Code <claude@anthropic.com>
Date: Fri, 10 Apr 2026 08:04:13 +0000
Subject: [PATCH 4/5] Adapt DPI scaling for Qt4 compatibility

Replace QScreen API with QDesktopWidget for Qt4:
- Use QDesktopWidget for screen geometry and DPI detection
- Conditionally compile QScreen-related signals and slots
- Simplify devicePixelRatio to 1.0 for Qt4 (no HiDPI support)
- Disable dynamic screen change notifications (acceptable for Qt4)

Main changes in dpiscalemanager.h/.cpp.
---
 src/client/frontend/gui/dpiscalemanager.cpp | 32 +++++++++++++++++++++
 src/client/frontend/gui/dpiscalemanager.h   | 14 +++++++++
 2 files changed, 46 insertions(+)

diff --git a/src/client/frontend/gui/dpiscalemanager.cpp b/src/client/frontend/gui/dpiscalemanager.cpp
index c39ffe3b..82ed82d4 100644
--- a/src/client/frontend/gui/dpiscalemanager.cpp
+++ b/src/client/frontend/gui/dpiscalemanager.cpp
@@ -2,10 +2,13 @@
 
 #include <QApplication>
 #include <QWidget>
+#if QT_VERSION >= QT_VERSION_CHECK(5, 0, 0)
 #include <QWindow>
+#endif
 
 #include "utils/log/categories.h"
 
+#if QT_VERSION >= QT_VERSION_CHECK(5, 0, 0)
 static QRect GetGeometryForScreen(const QScreen *screen)
 {
 #ifdef Q_OS_WIN
@@ -16,14 +19,24 @@
     return screen->geometry();
 #endif
 }
+#endif
 
 DpiScaleManager::DpiScaleManager() : QObject(nullptr)
 {
+#if QT_VERSION >= QT_VERSION_CHECK(5, 0, 0)
     curDPI_ = qApp->primaryScreen()->logicalDotsPerInch();
     setScale();
     curGeometry_ = GetGeometryForScreen(qApp->primaryScreen());
     curDevicePixelRatio_ = qApp->primaryScreen()->devicePixelRatio();
     curScreen_ = qApp->primaryScreen();
+#else
+    // Qt4: Use QDesktopWidget
+    QDesktopWidget *desktop = QApplication::desktop();
+    curDPI_ = desktop->logicalDpiX();
+    setScale();
+    curGeometry_ = desktop->screenGeometry();
+    curDevicePixelRatio_ = 1.0; // Qt4 doesn't have devicePixelRatio
+#endif
     qCDebug(LOG_BASIC) << "DpiScaleManager::constructor -> DPI:" << curDPI_ << "; scale:" << curScale_ << "; devicePixelRatio:" << curDevicePixelRatio_;
 }
 
@@ -31,6 +44,7 @@
 {
     mainWindow_ = mainWindow;
 
+#if QT_VERSION >= QT_VERSION_CHECK(5, 0, 0)
     disconnect(screenChangedConnection_);
     screenChangedConnection_ = connect(mainWindow->window()->windowHandle(), &QWindow::screenChanged, this, &DpiScaleManager::onWindowScreenChanged);
 
@@ -63,8 +77,25 @@
 
     qCDebug(LOG_BASIC) << "DpiScaleManager::setMainWindow -> no DPI or pixel ratio changes";
     return false;
+#else
+    // Qt4: Simplified DPI detection
+    QDesktopWidget *desktop = QApplication::desktop();
+    qreal dpi = desktop->logicalDpiX();
+    curGeometry_ = desktop->screenGeometry();
+
+    if (dpi != curDPI_) {
+        curDPI_ = dpi;
+        setScale();
+        qCDebug(LOG_BASIC) << "DpiScaleManager::setMainWindow -> DPI:" << curDPI_ << "; scale:" << curScale_;
+        return true;
+    }
+
+    qCDebug(LOG_BASIC) << "DpiScaleManager::setMainWindow -> no DPI changes";
+    return false;
+#endif
 }
 
+#if QT_VERSION >= QT_VERSION_CHECK(5, 0, 0)
 double DpiScaleManager::scaleOfScreen(const QScreen *screen) const
 {
 #ifdef Q_OS_WIN
@@ -148,6 +179,7 @@
     }
     curGeometry_ = GetGeometryForScreen(screen);
 }
+#endif
 
 void DpiScaleManager::setScale()
 {
diff --git a/src/client/frontend/gui/dpiscalemanager.h b/src/client/frontend/gui/dpiscalemanager.h
index 8a90d751..fd1b170e 100644
--- a/src/client/frontend/gui/dpiscalemanager.h
+++ b/src/client/frontend/gui/dpiscalemanager.h
@@ -1,7 +1,11 @@
 #pragma once
 
 #include <QObject>
+#if QT_VERSION < QT_VERSION_CHECK(5, 0, 0)
+#include <QDesktopWidget>
+#else
 #include <QScreen>
+#endif
 #include <QSet>
 
 #define G_SCALE  (DpiScaleManager::instance().curScale())
@@ -24,18 +28,24 @@
 
     int curDevicePixelRatio() const;
     QRect curScreenGeometry() const;
+#if QT_VERSION >= QT_VERSION_CHECK(5, 0, 0)
     double scaleOfScreen(const QScreen *screen) const;
+#endif
     bool setMainWindow(QWidget *mainWindow);    // return true if DPI is changed
 
 signals:
     void scaleChanged(double newScale);
+#if QT_VERSION >= QT_VERSION_CHECK(5, 0, 0)
     void screenConfigurationChanged(QSet<QScreen *> screens);
     void newScreen(QScreen *screen);
+#endif
 
 private slots:
+#if QT_VERSION >= QT_VERSION_CHECK(5, 0, 0)
     void onWindowScreenChanged(QScreen *screen);
     void onLogicalDotsPerInchChanged(qreal dpi);
     void onScreenAdded(QScreen *screen);
+#endif
 
 private:
     explicit DpiScaleManager();
@@ -47,9 +57,13 @@
     qreal curDPI_;
     QRect curGeometry_;
     QWidget *mainWindow_ = nullptr;
+#if QT_VERSION >= QT_VERSION_CHECK(5, 0, 0)
     QMetaObject::Connection screenChangedConnection_;
     QScreen* curScreen_;
+#endif
 
     void setScale();
+#if QT_VERSION >= QT_VERSION_CHECK(5, 0, 0)
     void update(QScreen *screen);
+#endif
 };
