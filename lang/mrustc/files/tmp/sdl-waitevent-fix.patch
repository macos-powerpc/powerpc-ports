From: Sergey Fedorov <vital.had@gmail.com>
Subject: [PATCH] Cocoa: Add WaitEventTimeout and SendWakeupEvent for modern SDL

Modern SDL 2.24+ expects video drivers to implement WaitEventTimeout
and SendWakeupEvent callbacks for efficient event handling. Without
these, the event loop falls back to inefficient polling with SDL_Delay(10)
which can cause the spinning ball (beach ball) on macOS as the system
thinks the application is unresponsive.

This patch adds these functions to the legacy Cocoa driver:
- Cocoa_WaitEventTimeout: Uses NSApp nextEventMatchingMask with
  proper timeout to efficiently wait for events
- Cocoa_SendWakeupEvent: Posts an NSApplicationDefined event to
  wake up the event loop from another thread
- Cocoa_SuspendScreenSaver: Stub (already handled in PumpEvents)

---
 src/video/cocoa/SDL_cocoaevents.h |  5 +++
 src/video/cocoa/SDL_cocoaevents.m | 58 +++++++++++++++++++++++++++++++
 src/video/cocoa/SDL_cocoavideo.m  |  3 ++
 3 files changed, 66 insertions(+)

diff --git src/video/cocoa/SDL_cocoaevents.h src/video/cocoa/SDL_cocoaevents.h
index 123456789..abcdefghi 100644
--- src/video/cocoa/SDL_cocoaevents.h
+++ src/video/cocoa/SDL_cocoaevents.h
@@ -27,6 +27,11 @@
 extern void Cocoa_RegisterApp(void);
 extern void Cocoa_PumpEvents(_THIS);

+/* Modern SDL 2.24+ event interface */
+extern int Cocoa_WaitEventTimeout(_THIS, int timeout);
+extern void Cocoa_SendWakeupEvent(_THIS, SDL_Window *window);
+extern void Cocoa_SuspendScreenSaver(_THIS);
+
 #endif /* SDL_cocoaevents_h_ */

 /* vi: set ts=4 sw=4 expandtab: */
diff --git src/video/cocoa/SDL_cocoaevents.m src/video/cocoa/SDL_cocoaevents.m
index 123456789..abcdefghi 100644
--- src/video/cocoa/SDL_cocoaevents.m
+++ src/video/cocoa/SDL_cocoaevents.m
@@ -343,6 +343,64 @@ Cocoa_PumpEvents(_THIS)
     [pool release];
 }

+int
+Cocoa_WaitEventTimeout(_THIS, int timeout)
+{
+    NSAutoreleasePool *pool = [[NSAutoreleasePool alloc] init];
+    NSDate *limitDate;
+    int result = 0;
+
+    if (timeout > 0) {
+        limitDate = [NSDate dateWithTimeIntervalSinceNow:(double)timeout / 1000.0];
+    } else if (timeout == 0) {
+        limitDate = [NSDate distantPast];
+    } else {
+        /* Negative timeout means wait indefinitely */
+        limitDate = [NSDate distantFuture];
+    }
+
+    /* Peek at the event queue without dequeuing - just check if event exists */
+    NSEvent *event = [NSApp nextEventMatchingMask:NSAnyEventMask
+                                        untilDate:limitDate
+                                           inMode:NSDefaultRunLoopMode
+                                          dequeue:NO];
+    if (event != nil) {
+        result = 1;
+    }
+
+    [pool release];
+    return result;
+}
+
+void
+Cocoa_SendWakeupEvent(_THIS, SDL_Window *window)
+{
+    NSAutoreleasePool *pool = [[NSAutoreleasePool alloc] init];
+    SDL_WindowData *data = (SDL_WindowData *)window->driverdata;
+    NSInteger windowNumber = 0;
+
+    if (data && data->nswindow) {
+        windowNumber = [data->nswindow windowNumber];
+    }
+
+    /* Post an application-defined event to wake up the event loop */
+    NSEvent *event = [NSEvent otherEventWithType:NSApplicationDefined
+                                        location:NSMakePoint(0, 0)
+                                   modifierFlags:0
+                                       timestamp:0.0
+                                    windowNumber:windowNumber
+                                         context:nil
+                                         subtype:0
+                                           data1:0
+                                           data2:0];
+
+    [NSApp postEvent:event atStart:YES];
+    [pool release];
+}
+
+void
+Cocoa_SuspendScreenSaver(_THIS)
+{
+    /* Screensaver prevention is handled in Cocoa_PumpEvents via UpdateSystemActivity */
+}
+
 #endif /* SDL_VIDEO_DRIVER_COCOA */

 /* vi: set ts=4 sw=4 expandtab: */
diff --git src/video/cocoa/SDL_cocoavideo.m src/video/cocoa/SDL_cocoavideo.m
index 123456789..abcdefghi 100644
--- src/video/cocoa/SDL_cocoavideo.m
+++ src/video/cocoa/SDL_cocoavideo.m
@@ -90,6 +90,9 @@ Cocoa_CreateDevice(void)
     device->SetDisplayMode = Cocoa_SetDisplayMode;
     device->PumpEvents = Cocoa_PumpEvents;
+    device->SuspendScreenSaver = Cocoa_SuspendScreenSaver;
+    device->WaitEventTimeout = Cocoa_WaitEventTimeout;
+    device->SendWakeupEvent = Cocoa_SendWakeupEvent;

     device->CreateSDLWindow = Cocoa_CreateWindow;
     device->CreateSDLWindowFrom = Cocoa_CreateWindowFrom;
--
