From: Sergey Fedorov <vital.had@gmail.com>
Subject: [PATCH] std: Use arc4random_buf on legacy macOS without CCRandomGenerateBytes

CCRandomGenerateBytes was added in macOS 10.10 and is not available on
PowerPC macOS (10.4/10.5). This patch adds a check for PowerPC Apple
before the general Apple check, routing to arc4random_buf which is
available via MacPorts legacy-support.

---
 library/std/src/sys/random/mod.rs | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/library/std/src/sys/random/mod.rs b/library/std/src/sys/random/mod.rs
--- a/library/std/src/sys/random/mod.rs
+++ b/library/std/src/sys/random/mod.rs
@@ -XX,6 +XX,11 @@ cfg_if::cfg_if! {
         mod linux;
         pub use linux::{fill_bytes, hashmap_random_keys};
     }
+    // Legacy macOS on PowerPC lacks CCRandomGenerateBytes (added in 10.10)
+    // Use arc4random_buf instead, available via MacPorts legacy-support
+    else if #[cfg(all(target_vendor = "apple", any(target_arch = "powerpc", target_arch = "powerpc64")))] {
+        mod arc4random;
+        pub use arc4random::fill_bytes;
+    }
     else if #[cfg(target_vendor = "apple")] {
         mod apple;
         pub use apple::fill_bytes;
--
