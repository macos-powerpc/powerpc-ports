From: Sergey Fedorov <vital.had@gmail.com>
Subject: [PATCH] std: Replace ptr_mask intrinsic usage for mrustc

mrustc does not implement the ptr_mask intrinsic which was added in
newer Rust versions. Replace all .mask() calls with equivalent pointer
arithmetic using casts to usize and back.

This affects the sync primitives in:
- library/std/src/sys/sync/once/queue.rs
- library/std/src/sys/sync/rwlock/queue.rs

The replacement ((ptr as usize) & mask) as *T is equivalent to
ptr.mask(mask) but uses only basic operations.

---
 library/std/src/sys/sync/once/queue.rs   |  4 ++--
 library/std/src/sys/sync/rwlock/queue.rs | 14 +++++++-------
 2 files changed, 9 insertions(+), 9 deletions(-)

diff --git a/library/std/src/sys/sync/once/queue.rs b/library/std/src/sys/sync/once/queue.rs
--- a/library/std/src/sys/sync/once/queue.rs
+++ b/library/std/src/sys/sync/once/queue.rs
@@ -62,7 +62,7 @@ fn to_state(current: StateAndQueue) -> usize {
 }

 fn to_queue(current: StateAndQueue) -> *const Waiter {
-    current.mask(QUEUE_MASK).cast()
+    ((current as usize) & QUEUE_MASK) as *const Waiter
 }

 /// # Safety
@@ -115,7 +115,7 @@ where
                 match state_and_queue.compare_exchange_weak(
                     current,
                     // Use `current` (instead of `RUNNING`) to preserve the pointer bits.
-                    current.mask(QUEUE_MASK).wrapping_byte_add(RUNNING),
+                    (((current as usize) & QUEUE_MASK) as StateAndQueue).wrapping_byte_add(RUNNING),
                     AcqRel,
                     Acquire,
                 ) {
diff --git a/library/std/src/sys/sync/rwlock/queue.rs b/library/std/src/sys/sync/rwlock/queue.rs
--- a/library/std/src/sys/sync/rwlock/queue.rs
+++ b/library/std/src/sys/sync/rwlock/queue.rs
@@ -249,7 +249,7 @@ impl Node {
 /// must point to a `Node`, since that is the only way to set the QUEUED bit.
 #[inline]
 unsafe fn to_node(state: State) -> NonNull<Node> {
-    unsafe { NonNull::new_unchecked(state.mask(NODE_MASK)).cast() }
+    unsafe { NonNull::new_unchecked(((state as usize) & NODE_MASK) as *mut ()).cast() }
 }

 impl RwLock {
@@ -360,7 +360,7 @@ impl RwLock {
             // uncontested path, we need an acquire barrier so that we can
             // access the node data.
             node.next.0 =
-                AtomicPtr::new(state.mask(NODE_MASK).cast());
+                AtomicPtr::new(((state as usize) & NODE_MASK) as *mut Node);

             // Set the QUEUED bit and add ourselves to the queue.
             let next = ptr::from_ref(&node)
@@ -477,7 +477,7 @@ impl RwLock {
             // The unlocking thread will wake us if there is no next node.

             // Clear the locked bit.
-            let next = current.mask(!LOCKED);
+            let next = ((current as usize) & !LOCKED) as State;

             match self.state.compare_exchange_weak(current, next, Release, Relaxed) {
                 Ok(_) => return,
@@ -576,7 +576,7 @@ impl RwLock {
                 // The readers can continue to read. We are only "releasing" the queue,
                 // so no synchronization is needed (the readers would've already observed
                 // the write that happened before `downgrade` anyway).
-                let next = state.mask(!QUEUE_LOCKED);
+                let next = ((state as usize) & !QUEUE_LOCKED) as State;

                 match self.state.compare_exchange_weak(state, next, Relaxed, Relaxed) {
                     Ok(_) => return,
@@ -600,7 +600,7 @@ impl RwLock {
                 // Release the queue lock.
                 // SAFETY: We just checked that `state` is `QUEUE_LOCKED` without `DOWNGRADED`,
                 // which only happens while there is a writer waiting in the queue.
-                let next = state.mask(!QUEUE_LOCKED);
+                let next = ((state as usize) & !QUEUE_LOCKED) as State;
                 state = self.state.swap(next, Release);
                 debug_assert!(state.addr() & QUEUE_LOCKED != 0);
                 unsafe {
@@ -640,7 +640,7 @@ impl RwLock {
                 // Release the queue lock.
                 // SAFETY: We just checked that `state` has `DOWNGRADED` and `QUEUE_LOCKED` set,
                 // which only happens after all readers have been woken up.
-                let next = state.mask(!QUEUE_LOCKED);
+                let next = ((state as usize) & !QUEUE_LOCKED) as State;
                 state = self.state.swap(next, Release);
                 debug_assert!(state.addr() & QUEUE_LOCKED != 0);
                 unsafe {
@@ -682,7 +682,7 @@ impl RwLock {
                 // pointer to wake up the entire list.
                 // Release the queue lock.
                 // All readers have been woken up, so we can clear the `DOWNGRADED` bit.
-                let next = state.mask(!QUEUE_LOCKED);
+                let next = ((state as usize) & !QUEUE_LOCKED) as State;
                 state = self.state.swap(next, Release);
                 debug_assert!(state.addr() & QUEUE_LOCKED != 0);
                 unsafe {
