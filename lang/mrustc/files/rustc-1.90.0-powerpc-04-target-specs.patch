+use crate::abi::Endian;
+use crate::spec::base::apple::{Arch, TargetAbi, base};
+use crate::spec::{FramePointer, Target, TargetMetadata, TargetOptions};
+
+pub(crate) fn target() -> Target {
+    let (mut opts, llvm_target, arch) = base("macos", Arch::PowerPc64, TargetAbi::Normal);
+    opts.frame_pointer = FramePointer::Always;
+
+    Target {
+        llvm_target,
+        metadata: TargetMetadata {
+            description: Some("64-bit PowerPC macOS (10.5, Leopard)".into()),
+            tier: Some(3),
+            host_tools: Some(false),
+            std: Some(true),
+        },
+        pointer_width: 64,
+        data_layout: "E-m:o-i64:64-n32:64".into(),
+        arch,
+        options: TargetOptions {
+            endian: Endian::Big,
+            mcount: "\u{1}mcount".into(),
+            ..opts
+        },
+    }
+}
