+TomlValue TomlFile::parse_array_body()
+{
+    TomlValue   rv;
+    rv.m_type = TomlValue::Type::List;
+    TomlToken   t(TomlToken::Type::Newline);
+    while( (t = m_lexer.get_token()).m_type != TomlToken::Type::SquareClose )
+    {
+        while( t.m_type == TomlToken::Type::Newline )
+        {
+            t = m_lexer.get_token();
+        }
+        if( t.m_type == TomlToken::Type::SquareClose )
+            break;
+
+        switch(t.m_type)
+        {
+        case TomlToken::Type::String:
+            rv.m_sub_values.push_back(TomlValue { t.as_string() });
+            break;
+        case TomlToken::Type::Integer:
+            rv.m_sub_values.push_back(TomlValue { t.m_intval });
+            break;
+        case TomlToken::Type::Ident:
+            if( t.m_data == "true" )
+                rv.m_sub_values.push_back(TomlValue { true });
+            else if( t.m_data == "false" )
+                rv.m_sub_values.push_back(TomlValue { false });
+            else
+                throw ::std::runtime_error(::format(m_lexer, ": Unexpected identifier in array value position - ", t));
+            break;
+        // Nested array, e.g. `package.metadata.deb.assets = [["target/release/...", "usr/bin/", "755"], ...]`
+        case TomlToken::Type::SquareOpen:
+            rv.m_sub_values.push_back(this->parse_array_body());
+            break;
+        // Inline table: only appears in sections minicargo ignores (e.g. package metadata), so
+        // consume the balanced token stream and store an empty list as a placeholder
+        case TomlToken::Type::BraceOpen: {
+            unsigned depth = 1;
+            while(depth > 0)
+            {
+                t = m_lexer.get_token();
+                switch(t.m_type)
+                {
+                case TomlToken::Type::BraceOpen:    depth ++;   break;
+                case TomlToken::Type::BraceClose:   depth --;   break;
+                case TomlToken::Type::Eof:
+                    throw ::std::runtime_error(::format(m_lexer, ": Unexpected EOF in inline table in array"));
+                default:
+                    break;
+                }
+            }
+            TomlValue   placeholder;
+            placeholder.m_type = TomlValue::Type::List;
+            rv.m_sub_values.push_back(::std::move(placeholder));
+            break; }
+        default:
+            throw ::std::runtime_error(::format(m_lexer, ": Unexpected token in array value position - ", t));
+        }
+
+        t = m_lexer.get_token();
+        if(t.m_type != TomlToken::Type::Comma)
+            break;
+    }
+    while( t.m_type == TomlToken::Type::Newline )
+    {
+        t = m_lexer.get_token();
+    }
+    if(t.m_type != TomlToken::Type::SquareClose)
+        throw ::std::runtime_error(::format(m_lexer, ": Unexpected token after array - ", t));
+    return rv;
+}
