@@ -481,7 +571,7 @@ TomlToken TomlToken::lex_from_inner(::std::ifstream& is, unsigned& m_line)
                     throw ::std::runtime_error("Unexpected EOF in double-quoted string");
                 if (c == '\\')
                 {
-                    handle_escape(str, is);
+                    handle_escape(str, is, m_line);
